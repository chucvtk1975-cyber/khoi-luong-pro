    { id: 'gach8080',  label: 'Gạch 80×80',    unit: 'm²', waste: 0.07 },



    { id: 'gach12060', label: 'Gạch 120×60',   unit: 'm²', waste: 0.07 },



    { id: 'daTN',      label: 'Đá tự nhiên',   unit: 'm²', waste: 0.08 },



    { id: 'epoxy',     label: 'Epoxy',          unit: 'm²', waste: 0.05 },



