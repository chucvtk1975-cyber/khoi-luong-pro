    { id: 'sonNuoc',    label: 'Sơn nước',         unit: 'm²', waste: 0.10 },



    { id: 'opG3060',    label: 'Gạch 30×60',       unit: 'm²', waste: 0.07 },



    { id: 'opG6060',    label: 'Gạch 60×60',       unit: 'm²', waste: 0.07 },



    { id: 'wallpaper',  label: 'Giấy dán tường',   unit: 'm²', waste: 0.15 },



    { id: 'opNhua',     label: 'Ốp nhựa PVC',      unit: 'm²', waste: 0.05 },



    { id: 'opGo',       label: 'Ốp gỗ trang trí',  unit: 'm²', waste: 0.12 },



    { id: 'other',      label: 'Khác',             unit: 'm²', waste: 0.07 },



  ],



  // Tường — Vùng 2 (phía trên, không có gạch)



  wallZ2: [



    { id: 'none',       label: 'Bỏ qua',           unit: '',   waste: 0    },



    { id: 'sonNuoc',    label: 'Sơn nước',         unit: 'm²', waste: 0.10 },



    { id: 'wallpaper',  label: 'Giấy dán tường',   unit: 'm²', waste: 0.15 },



    { id: 'opNhua',     label: 'Ốp nhựa PVC',      unit: 'm²', waste: 0.05 },



    { id: 'opGo',       label: 'Ốp gỗ trang trí',  unit: 'm²', waste: 0.12 },



    { id: 'other',      label: 'Khác',             unit: 'm²', waste: 0.07 },



  ],



  ceiling: [



    { id: 'none',       label: 'Bỏ qua',            unit: '',   waste: 0    },



    { id: 'sonNuoc',    label: 'Sơn nước',          unit: 'm²', waste: 0.10 },



    { id: 'tcPhang',    label: 'Thạch cao phẳng',    unit: 'm²', waste: 0.12 },



    { id: 'tcNoi',      label: 'Thạch cao nổi',     unit: 'm²', waste: 0.10 },



    { id: 'tcGiatCap',  label: 'TC giật cấp',        unit: 'm²', waste: 0.15 },



    { id: 'tcGo',       label: 'Trần gỗ',            unit: 'm²', waste: 0.12 },



    { id: 'nhomChinh',  label: 'Tấm nhôm',           unit: 'm²', waste: 0.08 },



    { id: 'tramAm',     label: 'Trần âm thanh',      unit: 'm²', waste: 0.10 },



  ],



};



// =============================================



// 2. TIỆN ÍCH



// =============================================



function genId() {



  return Date.now().toString(36) + Math.random().toString(36).slice(2, 7);



}



// Định dạng số thập phân theo tiếng Việt: dấu phẩy = thập phân, dấu chấm = nghìn



// Dùng toFixed + regex để luôn hiện đúng số chữ số thập phân





function categorizeSummaryItem(item) {

  const labelNorm = (item.label || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/đ/g, 'd').trim();

  const elecKeywords = [

    'den ', 'spotlight', 'panel', 'tuyp', 'led', 'cong tac', 'o cam', 'cb ', 'pha', 'tu dien',

    'may lanh', 'dieu hoa', 'quat hut', 'day dien', 'vat tu phu dien', 'nep nhua', 'ong ruot ga', 'ong cung', 'cadivi', 'panasonic', 'downlight'

  ];

  if (elecKeywords.some(kw => labelNorm.includes(kw))) {

    return 'elec';

  }

  const sanitaryKeywords = [

    'bon cau', 'lavabo', 'chau rua', 'voi sen', 'sen tam', 'chau tam', 'tieu nam', 've sinh',

    'thoat san', 'ong nuoc', 'ro nuoc', 'thiet bi ve sinh', 'lap dat ve sinh', 'sen cay', 'voi rua'

  ];

  if (sanitaryKeywords.some(kw => labelNorm.includes(kw))) {

    return 'sanitary';

  }

  const furnitureKeywords = [

    'giuong', 'tu ao', 'tu bep', 'ban an', 'ban trang diem', 'ban lam viec', 'ghe ', 'sofa',

    'ke tivi', 'tap dau giuong', 'quay bar', 'noi that', 'tu giay', 'quay le tan', 'dem ', 'rem',

    'vach op', 'lam go', 'woodwork', 'ke sach', 'ke trang tri', 'ban tra', 'go'

  ];

  if (furnitureKeywords.some(kw => labelNorm.includes(kw))) {

    return 'furniture';

  }

  return 'construction';

}



function fmt(n, dec = 2) {



  const v = parseFloat(n);



  if (isNaN(v)) return '0,' + '0'.repeat(dec);



  // Format fixed decimals dấu chấm, rồi chuyển sang vi-VN:



  // - dấu thập phân '.' → ','



  // - dấu phân cách nghìn: thêm '.' mỗi 3 chữ số phần nguyên



  const [intPart, decPart] = v.toFixed(dec).split('.');



  const intFormatted = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, '.');



  return dec > 0 ? `${intFormatted},${decPart}` : intFormatted;



}



// Toggle hiển thị công thức tính khi click vào ô SỐ LƯỢNG



function toggleFormula(td) {



  const expanded = td.classList.toggle('formula-expanded');



  if (expanded) {



    td.dataset.qty = td.textContent.trim();



    td.innerHTML = `<span class="formula-text">= ${td.dataset.formula}</span>`;



  } else {



    td.textContent = td.dataset.qty;



  }



}



// Định dạng số nguyên mm: 8930 → 8.930



function fmtMM(n) {



  const v = Math.round(parseFloat(n) || 0);



  return v.toLocaleString('vi-VN');



}



// Dùng cho Excel export (số thuần, không format string)



function fmtNum(n, dec = 2) {



  const v = parseFloat(n);



  return isNaN(v) ? 0 : Math.round(v * Math.pow(10, dec)) / Math.pow(10, dec);



}



function getMat(type, id) {



  return MATERIALS[type].find(m => m.id === id) || MATERIALS[type][0];



}



function today() {



  return new Date().toISOString().split('T')[0];



}



function reIcons() {



  if (window.lucide) window.lucide.createIcons();



}



// ── Đọc số thành chữ tiếng Việt ─────────────────────────



function numberToWords(n) {



  if (!n || isNaN(n)) return 'không đồng';



  const num = Math.round(+n);



  if (num === 0) return 'không đồng';



  const CH  = ['không','một','hai','ba','bốn','năm','sáu','bảy','tám','chín'];



  const DON = ['','nghìn','triệu','tỷ'];



  function readGroup(g) {



    let s = '';



    const h = Math.floor(g / 100);



    const t = Math.floor((g % 100) / 10);



    const u = g % 10;



    if (h) s += CH[h] + ' trăm ';



    if (t === 0 && u && h) s += 'linh ';



    else if (t === 1) s += 'mười ';



    else if (t > 1) s += CH[t] + ' mươi ';



    if (u === 1 && t > 1) s += 'mốt';



    else if (u === 5 && t > 0) s += 'lăm';



    else if (u) s += CH[u];



    return s.trim();



  }



  if (num < 0) return 'âm ' + numberToWords(-num);



  let parts = [], temp = num, idx = 0;



  while (temp > 0) {



    parts.push({ val: temp % 1000, don: DON[idx++] });



    temp = Math.floor(temp / 1000);



  }



  const words = parts.reverse().filter(p => p.val > 0)



    .map(p => readGroup(p.val) + (p.don ? ' ' + p.don : '')).join(', ');



  // Viết hoa chữ đầu



  return words.charAt(0).toUpperCase() + words.slice(1) + ' đồng';



}



// =============================================



// PARSER GHI CHÚ → HẠNG MỤC



// Phân tích văn bản ghi chú thành từng dòng BOQ có số lượng



// =============================================



function parseNoteItems(room) {



  const note = room.roomNote || '';



  if (!note.trim()) return [];



  const D = (+room.D || 0) / 1000;



  const R = (+room.R || 0) / 1000;



  const perim = 2 * (D + R);



  const perimMm = Math.round(perim * 1000);



  const items = [];



  const ni = (label, unit, qty, formula, note2) => ({



    surface: 'noteItem', label, unit,



    qty: +qty || 0, dai: '', rong: '', cao: '',



    price: 0, total: 0,



    formula: formula || (qty ? `${qty} ${unit}` : ''),



    note: note2 || '',



  });



  // Normalize: bỏ dấu tiếng Việt để match ASCII-safe



  const norm = note.toLowerCase()



    .normalize('NFD')



    .replace(/[\u0300-\u036f]/g, '')



    .replace(/\u0111/g, 'd').replace(/\u0110/g, 'd');



  // Helper: đọc số có dấu phẩy ("1,8m" -> 1800)



  const parseM = (s) => {



    if (!s) return 0;



    // '1,8m' -> 1800, '1800' -> 1800, '1.8m' -> 1800



    const n = parseFloat(String(s).replace(',', '.'));



    return isNaN(n) ? 0 : (n < 20 ? Math.round(n * 1000) : n); // < 20 thì tính bằng m



  };



  const mE = {



    cb20:   +room.elecCb20   || 0, cb10:   +room.elecCb10   || 0,



    outlet: +room.elecOutlet || 0, fan:    +room.elecFan    || 0,



    ac:     (+room.elecAcWall||0)+(+room.elecAcCeil||0)+(+room.elecAcCentral||0), lights: (+room.elecLightDl||0)+(+room.elecLightSl||0)+(+room.elecLightPanel||0)+(+room.elecLightTuyp1200||0)+(+room.elecLightTuyp600||0),



    sw2:    +room.elecSw2    || 0, sw1:    +room.elecSw1    || 0,



  };



  const hasAnyElec = Object.values(mE).some(v => v > 0);



  // ── XÂY DỰNG ──────────────────────────────────



  // Tường ốp gạch / đá cao X (nhiều biến thể)



  // "tường ốp gạch cao 1800", "ốp gạch tường cao 1,8m", "gạch ốp tường h = 1800"



  const rGach = norm.match(/(?:tuong\s*)?(?:op\s*)?(?:gach|da)(?:\s*op)?(?:\s*tuong)?\s*(?:cao|h\s*=\s*|h:\s*)([\d,.]+m?)/)



             || norm.match(/op\s*(?:gach|da)\s*cao\s*([\d,.]+m?)/);



  if (rGach) {



    const heightMm = parseM(rGach[1]);



    const area = perim * (heightMm / 1000);



    items.push(ni(`Tường ốp gạch/đá (cao ${fmtMM(heightMm)}mm)`, 'm²',



      +area.toFixed(2), `CV(${fmtMM(perimMm)}) x ${fmtMM(heightMm)}mm = ${fmt(area)} m²`, ''));



  }



  // Gạch hoa / gạch lát nền đặc biệt



  const rGachHoa = norm.match(/gach\s*hoa|gach\s*lat\s*hoa/);



  if (rGachHoa) {



    const area = D * R;



    items.push(ni('Gạch hoa ốp / lát nền', 'm²',



      +area.toFixed(2), `${fmtMM(+room.D)} x ${fmtMM(+room.R)} = ${fmt(area)} m²`, ''));



  }



  // Tường sơn cao X



  // "tường sơn cao 1800", "sơn 3 nước cao 2m", "sơn nước toàn bộ"



  const rSon = norm.match(/(?:tuong\s*)?son\s*(?:\d+\s*nuoc\s*)?cao\s*([\d,.]+m?)/)



            || norm.match(/son\s*nuoc\s*toan\s*bo/);



  if (rSon) {



    if (rSon[1]) {



      const heightMm = parseM(rSon[1]);



      const area = perim * (heightMm / 1000);



      items.push(ni(`Tường sơn (cao ${fmtMM(heightMm)}mm)`, 'm²',



        +area.toFixed(2), `CV(${fmtMM(perimMm)}) x ${fmtMM(heightMm)}mm = ${fmt(area)} m²`, ''));



    } else {



      // "sơn nước toàn bộ" = toàn bộ tường



      const area = perim * (+room.H || 0) / 1000;



      items.push(ni('Tường sơn toàn bộ', 'm²',



        +area.toFixed(2), `CV(${fmtMM(perimMm)}) x H(${fmtMM(+room.H)}) = ${fmt(area)} m²`, ''));



    }



  }



  // Chống thấm nền / tường



  if (/chong\s*tham/.test(norm)) {



    const area = D * R;



    const isWall = /chong\s*tham\s*tuong|tuong\s*chong\s*tham/.test(norm);



    if (isWall) {



      const wArea = perim * (+room.H || 0) / 1000;



      items.push(ni('Chống thấm tường', 'm²',



        +wArea.toFixed(2), `CV x H = ${fmt(wArea)} m²`, ''));



    } else {



      items.push(ni('Chống thấm nền/sàn', 'm²',



        +area.toFixed(2), `${fmtMM(+room.D)} x ${fmtMM(+room.R)} = ${fmt(area)} m²`, ''));



    }



  }



  // Ốp gỗ cao X



  const rGo = norm.match(/(?:op\s*)?go\s*(?:trang\s*tri\s*)?cao\s*([\d,.]+m?)/);



  if (rGo) {



    const heightMm = parseM(rGo[1]);



    const area = perim * (heightMm / 1000);



    items.push(ni(`Ốp gỗ trang trí (cao ${fmtMM(heightMm)}mm)`, 'm²',



      +area.toFixed(2), `CV(${fmtMM(perimMm)}) x ${fmtMM(heightMm)}mm = ${fmt(area)} m²`, ''));



  }



  // Tấm ốp trần / trần nhựa PVC



  if (/tam\s*op\s*tran|tran\s*nhua|tran\s*pvc|tam\s*tran/.test(norm)) {



    const area = D * R;



    items.push(ni('Tấm ốp trần PVC', 'm²',



      +area.toFixed(2), `${fmtMM(+room.D)} x ${fmtMM(+room.R)} = ${fmt(area)} m²`, ''));



  }



  // Rèm cửa



  if (/rem\s*cua/.test(norm)) {



    const nWin = +room.windows || 1;



    items.push(ni('Rèm cửa', 'bộ', nWin, `${nWin} bộ`, 'Tận dụng / lắp mới'));



  }



  // Bọc nilong



  if (/boc\s*ni.?long/.test(norm)) {



    items.push(ni('Bọc nilong bảo vệ cửa sổ', 'hạng mục', 1, '1 hạng mục', ''));



  }



  // Tháo gỡ



  if (/thao\s*go/.test(norm)) {



    items.push(ni('Công tháo gỡ vật tư cũ', 'hạng mục', 1, '1 hạng mục', ''));



  }



  // Phá dỡ / đập



  if (/pha\s*do|dap\s*(?:go|cot|tuong)/.test(norm)) {



    items.push(ni('Phá dỡ / đập cấu kiện cũ', 'hạng mục', 1, '1 hạng mục', ''));



  }



  // Sàn cũ làm lại



  if (/san.{0,25}lam\s*lai/.test(norm)) {



    const area = D * R;



    items.push(ni('Sàn cũ — thi công lại', 'm²',



      +area.toFixed(2), `${fmtMM(+room.D)} x ${fmtMM(+room.R)} = ${fmt(area)} m²`, ''));



  }



  // Trần cũ làm lại



  if (/tran.{0,25}lam\s*lai|lam\s*lai.{0,15}tran/.test(norm)) {



    const area = D * R;



    items.push(ni('Trần cũ — thi công lại', 'm²',



      +area.toFixed(2), `${fmtMM(+room.D)} x ${fmtMM(+room.R)} = ${fmt(area)} m²`, ''));



  }



  // Xi trát tường



  if (/xi\s*trat|trat\s*xi/.test(norm)) {



    const area = perim * (+room.H || 0) / 1000;



    items.push(ni('Xi trát tường', 'm²',



      +area.toFixed(2), `CV x H = ${fmt(area)} m²`, ''));



  }



  // ── ĐIỆN (chỉ khi chưa nhập modal) ───────────────────────



  if (!hasAnyElec) {



    // Đèn: "đèn X bộ", "X bộ đèn", "X đèn", "đèn panel X"



    const rDen = norm.match(/den\s+(?:\w+\s+){0,4}(\d+)\s*bo|(\d+)\s*(?:bo\s*)?den|den\s+(\d+)/);



    if (rDen) {



      const q = +(rDen[1] || rDen[2] || rDen[3] || 1);



      items.push(ni('Đèn panel Điện Quang', 'bộ', q, '', ''));



    }



    // Tủ điện / tủ CB: "tủ điện X đường"



    const rTu = norm.match(/tu\s*dien\s*(\d+)|(\d+)\s*duong.*cb|tu\s*cb\s*(\d+)/);



    if (rTu) {



      const q = +(rTu[1] || rTu[2] || rTu[3] || 1);



      items.push(ni(`Tủ điện ${q} đường`, 'cái', 1, '', ''));



    }



    // CB 40A



    const rCb40 = norm.match(/(\d+)\s*(?:cai\s*)?cb\s*40|cb\s*40\s*(?:a\s*)?(\d+)/);



    const hasCb40 = rCb40 || /cb\s*40/.test(norm);



    if (hasCb40) items.push(ni('CB 40A', 'cái', rCb40 ? +(rCb40[1]||rCb40[2]||1) : 1, '', ''));



    // CB 20A



    const rCb20 = norm.match(/(\d+)\s*(?:cai\s*)?cb\s*(?:o\s*cam|oc)?\s*20|cb\s*(?:o\s*cam\s*)?20\s*(?:a\s*)?(\d+)?/);



    const hasCb20 = rCb20 || /cb.*20/.test(norm);



    if (hasCb20) {



      const q = rCb20 ? +(rCb20[1]||rCb20[2]||1) : 1;



      items.push(ni('CB 20A', 'cái', q, '', ''));



    }



    // CB 15A / đèn 15A



    const rCb15 = norm.match(/(\d+)\s*(?:cai\s*)?cb\s*(?:den\s*)?15|cb\s*(?:den\s*)?15\s*(?:a\s*)?(\d+)?/);



    const hasCb15 = rCb15 || /cb.*15/.test(norm);



    if (hasCb15) items.push(ni('CB 15A', 'cái', rCb15 ? +(rCb15[1]||rCb15[2]||1) : 1, '', ''));



    // CB 10A



    const rCb10 = norm.match(/(\d+)\s*(?:cai\s*)?cb\s*10|cb\s*10\s*(?:a\s*)?(\d+)?/);



    const hasCb10 = rCb10 || /cb.*10[^a-z]/.test(norm);



    if (hasCb10) items.push(ni('CB 10A', 'cái', rCb10 ? +(rCb10[1]||rCb10[2]||1) : 1, '', ''));



    // Ổ cắm: "o cam X bo", "X bo o cam"



    const rOC = norm.match(/o\s*cam\s*(\d+)\s*bo/) || norm.match(/(\d+)\s*bo\s*o\s*cam/) || norm.match(/o\s*cam\s*(\d+)(?!\s*a)/);



    if (rOC) items.push(ni('Ổ cắm đôi 2 cực Panasonic', 'bộ', +(rOC[1]||rOC[2]||1), '', ''));



    // Quạt



    const rFan = norm.match(/(\d+)\s*quat|quat\s*(\d+)/);



    const hasFan = rFan || /quat/.test(norm);



    if (hasFan) items.push(ni('Quạt hút âm trần Panasonic', 'cái', rFan ? +(rFan[1]||rFan[2]||1) : 1, '', ''));



    // Máy lạnh / điều hòa



    const rAC = norm.match(/(\d+)\s*(?:may\s*lanh|dieu\s*hoa)|(?:may\s*lanh|dieu\s*hoa)\s*(\d+)/);



    const hasAC = rAC || /may\s*lanh|dieu\s*hoa/.test(norm);



    if (hasAC) items.push(ni('Máy lạnh (điều hòa)', 'cái', rAC ? +(rAC[1]||rAC[2]||1) : 1, '', ''));



    // Công tắc 2 mặt



    const rSw2 = norm.match(/(\d+)\s*(?:mat\s*)?(?:cong\s*tac\s*2|ct2)|mat\s*2\s*(?:cong\s*tac\s*)?(\d+)/);



    if (rSw2) items.push(ni('Mặt 2 công tắc Panasonic', 'mặt', +(rSw2[1]||rSw2[2]||1), '', ''));



    // Công tắc 1 mặt



    const rSw1 = norm.match(/(\d+)\s*(?:mat\s*)?(?:cong\s*tac\s*1|ct1)|mat\s*1\s*(?:cong\s*tac\s*)?(\d+)/);



    if (rSw1) items.push(ni('Mặt 1 công tắc Panasonic', 'mặt', +(rSw1[1]||rSw1[2]||1), '', ''));



    // Dây điện âm tường



    if (/day\s*dien/.test(norm)) {



      items.push(ni('Dây điện âm tường', 'bộ', 0, '', 'Xem mục dây điện ở phần Điện'));



    }



  }



  return items;



}



// =============================================



// 3. DATABASE (localStorage)



// =============================================



const DB = {



  KEY: 'bkl_v1_projects',



  load() {



    try { return JSON.parse(localStorage.getItem(this.KEY) || '[]'); }



    catch { return []; }



  },



  save(data) {



    localStorage.setItem(this.KEY, JSON.stringify(data));



  },



  all() { return this.load(); },



  get(id) { return this.load().find(p => p.id === id) || null; },



  create(data) {



    const projects = this.load();



    const project = { id: genId(), rooms: [], createdAt: Date.now(), ...data };



    projects.push(project);



    this.save(projects);



    return project;



  },



  update(id, patch) {



    const projects = this.load();



    const i = projects.findIndex(p => p.id === id);



    if (i === -1) return null;



    projects[i] = { ...projects[i], ...patch };



    this.save(projects);



    return projects[i];



  },



  remove(id) {



    this.save(this.load().filter(p => p.id !== id));



  },



  addRoom(projectId, roomData) {



    const p = this.get(projectId);



    if (!p) return null;



    const room = { id: genId(), ...roomData };



    p.rooms.push(room);



    this.update(projectId, { rooms: p.rooms });



    return room;



  },



  updateRoom(projectId, roomId, patch) {



    const p = this.get(projectId);



    if (!p) return;



    const i = p.rooms.findIndex(r => r.id === roomId);



    if (i === -1) return;



    p.rooms[i] = { ...p.rooms[i], ...patch };



    this.update(projectId, { rooms: p.rooms });



  },



  removeRoom(projectId, roomId) {



    const p = this.get(projectId);



    if (!p) return;



    this.update(projectId, { rooms: p.rooms.filter(r => r.id !== roomId) });



  },



};



// =============================================



// 4. TÍNH TOÁN KHỐI LƯỢNG



// =============================================



const CALC = {



  room(room) {



    // Chuyển từ mm → m để tính diện tích



    const D  = (+room.D || 0) / 1000;



    const R  = (+room.R || 0) / 1000;



    const H  = (+room.H || 0) / 1000;



    const nd = +room.doors  || 0;



    const dw = (+room.doorW   || 900)  / 1000;



    const dh = (+room.doorH   || 2100) / 1000;



    const nw = +room.windows || 0;



    const ww = (+room.windowW || 1200) / 1000;



    const wh = (+room.windowH || 1200) / 1000;



    const da    = dw * dh;           // dt 1 cửa đi (m²)



    const wa    = ww * wh;           // dt 1 cửa sổ (m²)



    const perim = 2 * (D + R);       // chu vi phòng (m)



    const fMat = getMat('floor',   room.floorMat);



    const wMat = getMat('wall',    room.wallMat);



    // ceilMats là array; lấy phần tử đầu để tính waste (đại diện)



    const ceilMatId = Array.isArray(room.ceilMats) && room.ceilMats.length ? room.ceilMats[0] : (room.ceilMat || 'none');



    const cMat = getMat('ceiling', ceilMatId);



    const rawFloor = D * R;



    const rawCeil  = D * R;



    let   rawWall  = Math.max(0, perim * H - nd * da - nw * wa);



    // mm gốc cho hiển thị



    const Dmm    = +room.D || 0;



    const Rmm    = +room.R || 0;



    const Hmm    = +room.H || 0;



    const perimM = Math.round(perim * 1000);   // chu vi dạng mm (để fmtMM)



    const items = [];



    // ══════════════════════════════════════════════



    // 1. DIỆN TÍCH SÀN (luôn hiển thị)



    // ══════════════════════════════════════════════



    if (D > 0 && R > 0) {



      const hasMat = fMat.id !== 'none';



      const price  = hasMat ? (+room.floorPrice || 0) : 0;



      const qty    = hasMat ? rawFloor * (1 + fMat.waste) : rawFloor;



      items.push({



        surface: 'floor',



        label:   hasMat ? `Sàn ${fMat.label}` : 'Diện tích sàn',



        unit:    'm²',



        qty:     +qty.toFixed(2),



        dai: Dmm, rong: Rmm, cao: '',



        price, total: qty * price,



        formula: `${fmtMM(Dmm)} × ${fmtMM(Rmm)} = ${fmt(rawFloor)} m²${hasMat ? ` (+${(fMat.waste*100).toFixed(0)}% = ${fmt(qty)} m²)` : ''}`,



        note:    hasMat ? `+${(fMat.waste*100).toFixed(0)}% hao hụt → ${fmt(qty, 2)} m²` : '',



      });



    }



    // ══════════════════════════════════════════════



    // 2. DIEN TICH TUONG



    // ══════════════════════════════════════════════



    if (D > 0 && R > 0 && H > 0) {



      const grossWall = perim * H;



      const dDeduct   = nd * da;



      const wDeduct   = nw * wa;



      const doorFml   = nd > 0 ? ` − ${nd}×(${fmtMM(+room.doorW||900)}×${fmtMM(+room.doorH||2100)}) = ${fmt(dDeduct)} m²` : '';



      const winFml    = nw > 0 ? ` − ${nw}×(${fmtMM(+room.windowW||1200)}×${fmtMM(+room.windowH||1200)}) = ${fmt(wDeduct)} m²` : '';



      if (!room.wallZone) {



        // Chế độ 1 vùng



        const hasMat = wMat.id !== 'none';



        const price  = hasMat ? (+room.wallPrice || 0) : 0;



        const qty    = hasMat ? rawWall * (1 + wMat.waste) : rawWall;



        items.push({



          surface: 'wall',



          label:   hasMat ? `Tường ${wMat.label}` : 'Diện tích tường',



          unit:    'm²',



          qty:     +qty.toFixed(2),



          dai: perimM, rong: '', cao: Hmm,



          price, total: qty * price,



          formula: `CV(${fmtMM(perimM)}) × H(${fmtMM(Hmm)}) = ${fmt(grossWall)} m²${doorFml}${winFml} → ${fmt(rawWall)} m²${hasMat ? ` (+${(wMat.waste*100).toFixed(0)}% = ${fmt(qty)} m²)` : ''}`,



          note:    hasMat ? `+${(wMat.waste*100).toFixed(0)}% hao hụt → ${fmt(qty, 2)} m²` : '',



        });



      } else if (+room.wallZ1H > 0) {



        // Chế độ 2 vùng zone



        const z1H   = (+room.wallZ1H || 0) / 1000;



        const z2H   = Math.max(0, H - z1H);



        const sill  = (+room.wallSill || 900) / 1000;



        const wTop  = sill + wh;



        const z1Hmm = +room.wallZ1H || 0;



        const z2Hmm = Math.round(z2H * 1000);



        const rawZ1 = perim * z1H;



        const rawZ2 = perim * z2H;



        const doorInZ1 = nd * dw * Math.min(dh, z1H);



        const doorInZ2 = nd * dw * Math.max(0, dh - z1H);



        const winInZ1  = nw * ww * Math.max(0, Math.min(wTop, z1H) - Math.max(0, sill));



        const winInZ2  = nw * ww * Math.max(0, Math.min(wTop, H) - Math.max(sill, z1H));



        const finalZ1 = Math.max(0, rawZ1 - doorInZ1 - winInZ1);



        const finalZ2 = Math.max(0, rawZ2 - doorInZ2 - winInZ2);



        const mat1 = getMat('wall', room.wallMatZ1);



        const mat2 = getMat('wall', room.wallMatZ2);



        // Vùng 1



        const hasMat1 = mat1.id !== 'none';



        const price1  = hasMat1 ? (+room.wallPriceZ1 || 0) : 0;



        const qty1    = hasMat1 ? finalZ1 * (1 + mat1.waste) : finalZ1;



        if (finalZ1 > 0) items.push({



          surface: 'wallZ1',



          label:   hasMat1 ? `Tường Vùng 1 — ${mat1.label}` : `Tường Vùng 1 (cao ${fmtMM(z1Hmm)})`,



          unit: 'm²', qty: +qty1.toFixed(2),



          dai: perimM, rong: '', cao: z1Hmm,



          price: price1, total: qty1 * price1,



          formula: `CV(${fmtMM(perimM)}) × ${fmtMM(z1Hmm)} = ${fmt(rawZ1)} m² − cửa → ${fmt(finalZ1)} m²${hasMat1?` (+${(mat1.waste*100).toFixed(0)}% = ${fmt(qty1)} m²)`:''}`,



          note: hasMat1 ? `+${(mat1.waste*100).toFixed(0)}% hao hụt → ${fmt(qty1, 2)} m²` : '',



        });



        // Vùng 2



        const hasMat2 = mat2.id !== 'none';



        const price2  = hasMat2 ? (+room.wallPriceZ2 || 0) : 0;



        const qty2    = hasMat2 ? finalZ2 * (1 + mat2.waste) : finalZ2;



        if (finalZ2 > 0) items.push({



          surface: 'wallZ2',



          label:   hasMat2 ? `Tường Vùng 2 — ${mat2.label}` : `Tường Vùng 2 (cao ${fmtMM(z2Hmm)})`,



          unit: 'm²', qty: +qty2.toFixed(2),



          dai: perimM, rong: '', cao: z2Hmm,



          price: price2, total: qty2 * price2,



          formula: `CV(${fmtMM(perimM)}) × ${fmtMM(z2Hmm)} = ${fmt(rawZ2)} m² − cửa sổ → ${fmt(finalZ2)} m²${hasMat2?` (+${(mat2.waste*100).toFixed(0)}% = ${fmt(qty2)} m²)`:''}`,



          note: hasMat2 ? `+${(mat2.waste*100).toFixed(0)}% hao hụt → ${fmt(qty2, 2)} m²` : '',



        });



        rawWall = finalZ1 + finalZ2;



      }



    }



    // ══════════════════════════════════════════════



    // 3. LEN CHÂN TƯỜNG (thuộc nhóm tường — chu vi trừ cửa đi)



    // ══════════════════════════════════════════════



    if (D > 0 && R > 0) {



      const lenChanTuong = Math.max(0, perim - nd * dw);



      items.push({



        surface: 'perimeter',



        label:   'Len chân tường (chu vi trừ cửa đi)',



        unit:    'm',



        qty:     +lenChanTuong.toFixed(2),



        dai: Dmm, rong: Rmm, cao: '',



        price: 0, total: 0,



        formula: `${fmtMM(Dmm)}×2 + ${fmtMM(Rmm)}×2 = ${fmtMM(perimM)}mm${nd>0?` − ${nd} cửa đi(${fmtMM(+room.doorW||900)})`:''} ÷ 1.000 = ${fmt(lenChanTuong)} m`,



        note: '',



      });



    }



    // ══════════════════════════════════════════════



    // 4. DIỆN TÍCH CỬA ĐI (luôn hiển thị nếu có cửa)



    // ══════════════════════════════════════════════



    if (nd > 0 && da > 0) {



      const doorTotalArea = nd * da;



      items.push({



        surface: 'door',



        label:   'Diện tích cửa đi',



        unit:    'm²',



        qty:     +doorTotalArea.toFixed(2),



        dai:     '',



        rong:    +room.doorW || 900,



        cao:     +room.doorH || 2100,



        price: 0, total: 0,



        formula: `${nd} cửa × (${fmtMM(+room.doorW||900)} × ${fmtMM(+room.doorH||2100)}) = ${fmt(doorTotalArea)} m²`,



        note:    `${nd} cửa đi`,



      });



    }



    // ══════════════════════════════════════════════



    // 5. DIỆN TÍCH CỬA SỔ (luôn hiển thị nếu có)



    // ══════════════════════════════════════════════



    if (nw > 0 && wa > 0) {



      const winArea = nw * wa;



      items.push({



        surface: 'window',



        label:   'Diện tích cửa sổ',



        unit:    'm²',



        qty:     +winArea.toFixed(2),



        dai:     '',



        rong:    +room.windowW || 1200,



        cao:     +room.windowH || 1200,



        price: 0, total: 0,



        formula: `${nw} cửa sổ × (${fmtMM(+room.windowW||1200)} × ${fmtMM(+room.windowH||1200)}) = ${fmt(winArea)} m²`,



        note:    `${nw} cửa sổ — dùng tính rèm / vật liệu kính`,



      });



    }



    // ══════════════════════════════════════════════



    // 6. DIỆN TÍCH TRẦN (luôn hiển thị)



    // ══════════════════════════════════════════════



    if (D > 0 && R > 0) {



      const hasMat = cMat.id !== 'none';



      const price  = hasMat ? (+room.ceilPrice || 0) : 0;



      const qty    = hasMat ? rawCeil * (1 + cMat.waste) : rawCeil;



      items.push({



        surface: 'ceiling',



        label:   hasMat ? `Trần ${cMat.label}` : 'Diện tích trần',



        unit:    'm²',



        qty:     +qty.toFixed(2),



        dai: Dmm, rong: Rmm, cao: '',



        price, total: qty * price,



        formula: `${fmtMM(Dmm)} × ${fmtMM(Rmm)} = ${fmt(rawCeil)} m²${hasMat ? ` (+${(cMat.waste*100).toFixed(0)}% = ${fmt(qty)} m²)` : ''}`,



        note:    hasMat ? `+${(cMat.waste*100).toFixed(0)}% hao hụt → ${fmt(qty, 2)} m²` : '',



      });



    }



    // ══════════════════════════════════════════════



    // 7. CHU VI TRẦN



    // ══════════════════════════════════════════════



    if (D > 0 && R > 0) {



      items.push({



        surface: 'ceilPerim',



        label:   'Chu vi trần',



        unit:    'm',



        qty:     +perim.toFixed(2),



        dai: Dmm, rong: Rmm, cao: '',



        price: 0, total: 0,



        formula: `${fmtMM(Dmm)}×2 + ${fmtMM(Rmm)}×2 = ${fmtMM(perimM)}mm ÷ 1.000 = ${fmt(perim)} m`,



        note:    'Len trần / chỉ trần',



      });



    }



    // ── THIẾT BỊ ĐIỆN ────────────────────────────



    const eLightDl       = +room.elecLightDl       || 0;



    const eLightSl       = +room.elecLightSl       || 0;



    const eLightPanel    = +room.elecLightPanel     || 0;



    const eLightTuyp1200 = +room.elecLightTuyp1200  || 0;



    const eLightTuyp600  = +room.elecLightTuyp600   || 0;



    const eLightLed      = +room.elecLightLed       || 0;



    const eLights        = eLightDl + eLightSl + eLightPanel + eLightTuyp1200 + eLightTuyp600; // tổng để tính dây



    const eSw2     = +room.elecSw2     || 0;



    const eSw1     = +room.elecSw1     || 0;



    const eOutlet  = +room.elecOutlet  || 0;



    const eCb1      = +room.elecCb1       || 0;



    const eCb2      = +room.elecCb2       || 0;



    const eCb3      = +room.elecCb3       || 0;



    const ePanelBox = +room.elecPanelBox  || 0;



    const eCB20     = eCb1 + eCb2 + eCb3; // tổng CB cho tính dây



    const eCB10 = 0; // deprecated



    const eFan     = +room.elecFan     || 0;



    const eAcWall    = +room.elecAcWall    || 0;



    const eAcCeil    = +room.elecAcCeil    || 0;



    const eAcCentral = +room.elecAcCentral || 0;



    const eAC        = eAcWall + eAcCeil + eAcCentral; // tổng máy lạnh cho tính dây



    const hasElec  = (eLights+eLightLed+eSw2+eSw1+eOutlet+eCb1+eCb2+eCb3+ePanelBox+eFan+eAC) > 0;



    if (hasElec) {



      // Header section điện



      items.push({ surface: 'elecHeader', label: 'THIẾT BỊ ĐIỆN', unit: '', qty: 0, dai: '', rong: '', cao: '', price: 0, total: 0, formula: '', note: '' });



      // Từng thiết bị



      if (eLightDl       > 0) items.push({ surface:'elec', label:'Đèn downlight',       unit:'bộ', qty:eLightDl,       dai:'',rong:'',cao:'',price:0,total:0,formula:`${eLightDl} bộ`,       note:'' });



      if (eLightSl       > 0) items.push({ surface:'elec', label:'Đèn spotlight',       unit:'bộ', qty:eLightSl,       dai:'',rong:'',cao:'',price:0,total:0,formula:`${eLightSl} bộ`,       note:'' });



      if (eLightPanel    > 0) items.push({ surface:'elec', label:'Đèn panel',           unit:'bộ', qty:eLightPanel,    dai:'',rong:'',cao:'',price:0,total:0,formula:`${eLightPanel} bộ`,    note:'' });



      if (eLightTuyp1200 > 0) items.push({ surface:'elec', label:'Đèn tuýp 1200mm',    unit:'bộ', qty:eLightTuyp1200, dai:'',rong:'',cao:'',price:0,total:0,formula:`${eLightTuyp1200} bộ`, note:'' });



      if (eLightTuyp600  > 0) items.push({ surface:'elec', label:'Đèn tuýp 600mm',     unit:'bộ', qty:eLightTuyp600,  dai:'',rong:'',cao:'',price:0,total:0,formula:`${eLightTuyp600} bộ`,  note:'' });



      if (eLightLed      > 0) items.push({ surface:'elec', label:'Đèn LED dây',         unit:'m',  qty:eLightLed,      dai:'',rong:'',cao:'',price:0,total:0,formula:`${eLightLed} m`,       note:'' });



      if (eSw2    > 0)  items.push({ surface: 'elec', label: 'Mặt 2 công tắc Panasonic',         unit: 'mặt', qty: eSw2,     dai:'',rong:'',cao:'', price:0,total:0, formula:`${eSw2} mặt`,   note:'' });



      if (eSw1    > 0)  items.push({ surface: 'elec', label: 'Mặt 1 công tắc Panasonic',         unit: 'mặt', qty: eSw1,     dai:'',rong:'',cao:'', price:0,total:0, formula:`${eSw1} mặt`,   note:'' });



      if (eOutlet > 0)  items.push({ surface: 'elec', label: 'Ổ cắm đôi 2 cấu Panasonic',        unit: 'bộ',  qty: eOutlet,  dai:'',rong:'',cao:'', price:0,total:0, formula:`${eOutlet} bộ`, note:'' });



      if (eCb1      > 0) items.push({ surface:'elec', label:'CB 1 pha',    unit:'cái', qty:eCb1,      dai:'',rong:'',cao:'',price:0,total:0,formula:`${eCb1} cái`,      note:'' });



      if (eCb2      > 0) items.push({ surface:'elec', label:'CB 2 pha',    unit:'cái', qty:eCb2,      dai:'',rong:'',cao:'',price:0,total:0,formula:`${eCb2} cái`,      note:'' });



      if (eCb3      > 0) items.push({ surface:'elec', label:'CB 3 pha',    unit:'cái', qty:eCb3,      dai:'',rong:'',cao:'',price:0,total:0,formula:`${eCb3} cái`,      note:'' });



      if (ePanelBox > 0) items.push({ surface:'elec', label:'Tủ điện',     unit:'bộ',  qty:ePanelBox, dai:'',rong:'',cao:'',price:0,total:0,formula:`${ePanelBox} bộ`,  note:'' });



      if (eAcWall    > 0) items.push({ surface:'elec', label:'Máy lạnh treo tường',   unit:'cái', qty:eAcWall,    dai:'',rong:'',cao:'',price:0,total:0,formula:`${eAcWall} cái`,    note:'' });



      if (eAcCeil    > 0) items.push({ surface:'elec', label:'Máy lạnh âm trần',     unit:'cái', qty:eAcCeil,    dai:'',rong:'',cao:'',price:0,total:0,formula:`${eAcCeil} cái`,    note:'' });



      if (eAcCentral > 0) items.push({ surface:'elec', label:'Máy lạnh trung tâm',   unit:'cái', qty:eAcCentral, dai:'',rong:'',cao:'',price:0,total:0,formula:`${eAcCentral} cái`, note:'' });



      if (eFan       > 0) items.push({ surface:'elec', label:'Quạt hút âm trần',     unit:'cái', qty:eFan,       dai:'',rong:'',cao:'',price:0,total:0,formula:`${eFan} cái`,       note:'' });



      // Dây điện: tính mét → đổi ra cuộn 100m



      const m15 = perim * 2 + eLights * 5 + (eSw2 + eSw1) * 3;



      const cuon15 = Math.ceil(m15 / 100);



      if (cuon15 > 0) items.push({



        surface: 'elec',



        label: 'Dây điện 1,5mm² Cadivi (đèn, công tắc)',



        unit: 'cuộn',



        qty: cuon15,



        dai:'',rong:'',cao:'', price:0,total:0,



        formula: `CV×2(${fmt(perim*2,1)}m) + đèn×5(${fmt(eLights*5,1)}m) + CT×3(${fmt((eSw2+eSw1)*3,1)}m) = ${fmt(m15,1)}m → ${cuon15} cuộn`,



        note: '1 cuộn = 100m',



      });



      // Dây 2,5mm²: ổ cắm → perim×1.5 + 4m/ổ cắm



      const m25 = perim * 1.5 + eOutlet * 4;



      const cuon25 = Math.ceil(m25 / 100);



      if (cuon25 > 0) items.push({



        surface: 'elec',



        label: 'Dây điện 2,5mm² Cadivi (ổ cắm)',



        unit: 'cuộn',



        qty: cuon25,



        dai:'',rong:'',cao:'', price:0,total:0,



        formula: `CV×1,5(${fmt(perim*1.5,1)}m) + ổcắm×4(${fmt(eOutlet*4,1)}m) = ${fmt(m25,1)}m → ${cuon25} cuộn`,



        note: '1 cuộn = 100m',



      });



      // Dây 4,0mm²: máy lạnh + CB20A → (perim + 5m) × số thiết bị nặng



      const heavyLoad = eAC + eCB20;



      if (heavyLoad > 0) {



        const m40 = (perim + 5) * heavyLoad;



        const cuon40 = Math.ceil(m40 / 100);



        items.push({



          surface: 'elec',



          label: 'Dây điện 4,0mm² Cadivi (máy lạnh, CB20A)',



          unit: 'cuộn',



          qty: cuon40,



          dai:'',rong:'',cao:'', price:0,total:0,



          formula: `(CV+5m)×${heavyLoad} = ${fmt(m40,1)}m → ${cuon40} cuộn`,



          note: '1 cuộn = 100m',



        });



      }



      // Vật tư phụ: 1 gói/phòng



      items.push({ surface: 'elec', label: 'Vật tư phụ điện (băng keo, đinh vít, co nối)', unit: 'gói', qty: 1, dai:'',rong:'',cao:'', price:0,total:0, formula:'1 gói/phòng', note:'' });



      // Mục nhắc nhở — luôn liệt kê, số lượng tự điền



      const eNep     = +room.elecNep     || 0;



      const eOngRuot = +room.elecOngRuot || 0;



      const eOngCung = +room.elecOngCung || 0;



      items.push({ 



        surface: 'elecManual', 



        label: 'Nẹp nhựa 3-4 cm', 



        unit: 'thanh',   



        qty: eNep,     



        dai:'',rong:'',cao:'', price:0,total:0, 



        formula: eNep ? `${eNep} thanh` : '', 



        note: eNep ? '1 thanh = 2m' : '← Tự điền' 



      });



      items.push({ 



        surface: 'elecManual', 



        label: 'Ống ruột gà phi 20 (luồn dây)', 



        unit: 'cuộn',   



        qty: eOngRuot, 



        dai:'',rong:'',cao:'', price:0,total:0, 



        formula: eOngRuot ? `${eOngRuot} cuộn` : '', 



        note: eOngRuot ? '1 cuộn = 50m' : '← Tự điền' 



      });



      items.push({ 



        surface: 'elecManual', 



        label: 'Ống cứng PVC phi 20 (conduit)',   



        unit: 'thanh',   



        qty: eOngCung, 



        dai:'',rong:'',cao:'', price:0,total:0, 



        formula: eOngCung ? `${eOngCung} thanh` : '', 



        note: eOngCung ? '1 thanh = 2,92m' : '← Tự điền' 



      });



    }



    // ── HẠNG MỤC THỦ CÔNG (do user thêm tay) ──



    (room.customItems || []).forEach(ci => {



      items.push({



        surface: 'custom',



        itemId:  ci.id,



        label:   ci.label || '(chưa đặt tên)',



        unit:    ci.unit  || '',



        qty:     +ci.qty  || 0,



        dai: '', rong: '', cao: '',



        price:   +ci.price || 0,



        total:   (+ci.qty || 0) * (+ci.price || 0),



        formula: ci.qty ? `${ci.qty} ${ci.unit}` : '',



        note:    ci.note || '',



      });



    });



    // ── GHI CHÚ → HẠNG MỤC (parser tự động) ──



    const noteItems = parseNoteItems(room);



    if (noteItems.length > 0) {



      items.push({ surface: 'noteHeader', label: 'CHI TIET TU GHI CHU', unit:'',qty:0,dai:'',rong:'',cao:'',price:0,total:0,formula:'',note:'' });



      noteItems.forEach(ni => items.push(ni));



    }



    // Gan _key on dinh cho moi item



    const _kc = {};



    items.forEach(it => {



      if (it.surface === 'custom') {



        it._key = 'ci:' + (it.itemId || it.id || '?');



      } else if (it.surface === 'elec' || it.surface === 'elecManual') {



        const slug = (it.label||'').replace(/[^a-zA-Z0-9]/g,'').substr(0,12);



        it._key = it.surface + '_' + slug;



      } else if (it.surface === 'noteItem') {



        _kc.ni = (_kc.ni||0)+1;



        it._key = 'ni_' + _kc.ni;



      } else {



        it._key = it.surface || 'x';



      }



    });



    // Apply thu tu da luu



    if (room.rowOrder && room.rowOrder.length) {



      items.sort((a,b) => {



        const ai = room.rowOrder.indexOf(a._key);



        const bi = room.rowOrder.indexOf(b._key);



        return (ai<0?99999:ai)-(bi<0?99999:bi);



      });



    }



    return { rawFloor, rawWall, rawCeil, perim, items };



  },



  project(project) {



    let tFloor = 0, tWall = 0, tItems = 0;



    (project.rooms || []).forEach(r => {



      const c = this.room(r);



      tFloor += c.rawFloor;



      tWall  += c.rawWall;



      tItems += c.items.length;



    });



    return {



      rooms: (project.rooms || []).length,



      items: tItems,



      floor: tFloor,



      wall:  tWall,



    };



  },



  projectSummary(project) {



    const summary = {};



    (project.rooms || []).forEach(room => {



      const calc = this.room(room);



      calc.items.forEach(item => {



        if (item.surface === 'elecHeader' || item.surface === 'noteHeader') return;



        const key = `${item.label.trim()}|||${item.unit.trim()}`;



        if (!summary[key]) {



          summary[key] = {



            label: item.label,



            unit: item.unit,



            qty: 0,



            price: item.price || 0,



            total: 0,



            rooms: [],



            notes: []



          };



        }



        summary[key].qty += item.qty || 0;



        summary[key].total += item.total || 0;



        if (!summary[key].price && item.price) {



          summary[key].price = item.price;



        }



        if (item.qty > 0) {



          summary[key].rooms.push(`${room.name} (${fmt(item.qty)} ${item.unit})`);



        }



        if (item.note && item.note.trim()) {



          const cleanNote = item.note.trim();



          if (!summary[key].notes.includes(cleanNote)) {



            summary[key].notes.push(cleanNote);



          }



        }



      });



    });



    return Object.values(summary).filter(item => item.qty > 0).map(item => {



      item.note = item.notes ? item.notes.join('; ') : '';



      return item;



    });



  },



};



// =============================================



// 5. TRẠNG THÁI ỨNG DỤNG



// =============================================



let state = {



  currentProjectId: null,



  editingRoomId: null,



  selMat: { floor: 'none', wall: 'none', ceilMats: [], wallZ1: 'none', wallZ2: 'none' },



  wallZoneMode: false,



  originalRoomData: null,



  elecPhotos: [],



};



// =============================================



// 6. RENDER SIDEBAR DỰ ÁN



// =============================================



function renderProjectList() {



  const allProjects = DB.all();



  const list = document.getElementById('project-list');



  const badge = document.getElementById('header-project-count');



  badge.textContent = `${allProjects.length} dự án`;



  if (allProjects.length === 0) {



    list.innerHTML = `<p style="padding:20px;text-align:center;color:var(--text-muted);font-size:12px;">Chưa có dự án nào</p>`;



    return;



  }



  // Sort: AZ theo tên, ZA, hoặc theo ngày tạo mới nhất (mặc định)



  const sortMode = window._projSortMode || 'date';



  const projects = [...allProjects].sort((a, b) => {



    if (sortMode === 'az')   return a.name.localeCompare(b.name, 'vi');



    if (sortMode === 'za')   return b.name.localeCompare(a.name, 'vi');



    return 0; // date: giữ thứ tự gốc



  });



  // Nút sort ở đầu danh sách



  const sortBtnHtml = `



    <div style="display:flex;gap:4px;padding:8px 12px 4px;border-bottom:1px solid var(--border-color);">



      <span style="font-size:11px;color:var(--text-muted);align-self:center;margin-right:4px;">Sắp xếp:</span>



      <button onclick="_projSortMode='date';renderProjectList()" style="font-size:11px;padding:2px 8px;border-radius:4px;border:1px solid var(--border-color);background:${sortMode==='date'?'var(--brand-gold)':'var(--bg-elevated)'};color:${sortMode==='date'?'#000':'var(--text-secondary)'};cursor:pointer;">Mới nhất</button>



      <button onclick="_projSortMode='az';renderProjectList()" style="font-size:11px;padding:2px 8px;border-radius:4px;border:1px solid var(--border-color);background:${sortMode==='az'?'var(--brand-gold)':'var(--bg-elevated)'};color:${sortMode==='az'?'#000':'var(--text-secondary)'};cursor:pointer;">A → Z</button>



      <button onclick="_projSortMode='za';renderProjectList()" style="font-size:11px;padding:2px 8px;border-radius:4px;border:1px solid var(--border-color);background:${sortMode==='za'?'var(--brand-gold)':'var(--bg-elevated)'};color:${sortMode==='za'?'#000':'var(--text-secondary)'};cursor:pointer;">Z → A</button>



    </div>`;



  list.innerHTML = sortBtnHtml + projects.map(p => {



    const s = CALC.project(p);



    const active = p.id === state.currentProjectId;



    return `



      <div class="project-item ${active ? 'active' : ''}" data-id="${p.id}">



        <div class="project-item-name">${p.name}</div>



        <div class="project-item-meta">



          <span>${s.rooms} phòng</span>



          <span>${s.items} hạng mục</span>



        </div>



      </div>`;



  }).join('');



  list.querySelectorAll('.project-item').forEach(el => {



    el.addEventListener('click', () => openProject(el.dataset.id));



  });



}



// =============================================



// 7. MỞ DỰ ÁN



// =============================================



function openProject(id) {



  const project = DB.get(id);



  if (!project) return;



  state.currentProjectId = id;



  document.getElementById('empty-state').style.display = 'none';



  const ws = document.getElementById('project-workspace');



  ws.style.display = 'block';



  ws.classList.add('visible');



  // Điền thông tin



  document.getElementById('ws-project-name').textContent = project.name;



  document.getElementById('ws-project-client').textContent  = project.client  ? `👤 ${project.client}`  : '';



  document.getElementById('ws-project-address').textContent = project.address ? `📍 ${project.address}` : '';



  document.getElementById('ws-project-date').textContent    = project.date    ? `📅 ${project.date}`    : '';



  renderProjectList();



  refreshWorkspace();



}



function refreshWorkspace() {



  const project = DB.get(state.currentProjectId);



  if (!project) return;



  renderStats(project);



  renderRooms(project);



  renderBOQ(project);



}



// =============================================



// 8. RENDER STATS



// =============================================



function renderStats(project) {



  const s = CALC.project(project);



  document.getElementById('stat-rooms').textContent      = s.rooms;



  document.getElementById('stat-items').textContent      = s.items;



  document.getElementById('stat-floor-area').textContent = fmt(s.floor);



  document.getElementById('stat-wall-area').textContent  = fmt(s.wall);



}



// =============================================



// 9. RENDER DANH SÁCH PHÒNG



// =============================================



function renderRooms(project) {



  const grid = document.getElementById('rooms-grid');



  if (!project.rooms || project.rooms.length === 0) {



    grid.innerHTML = `



      <div style="grid-column:1/-1;text-align:center;padding:52px 20px;color:var(--text-muted);">



        <div style="font-size:44px;margin-bottom:14px;">🏠</div>



        <p style="font-size:14px;">Chưa có phòng nào. Bấm <strong>+ Thêm Phòng</strong> để bắt đầu.</p>



      </div>`;



    return;



  }



  grid.innerHTML = project.rooms.map(room => {



    const calc  = CALC.room(room);



    const fMat  = getMat('floor',   room.floorMat);



    const wMat  = getMat('wall',    room.wallMat);



    const ceilMatId = Array.isArray(room.ceilMats) && room.ceilMats.length ? room.ceilMats[0] : (room.ceilMat || 'none');



    const cMat  = getMat('ceiling', ceilMatId);



    // Hiển thị kích thước gốc theo mm (format vi-VN)



    const dimLabel = `${fmtMM(room.D||0)} × ${fmtMM(room.R||0)} × cao ${fmtMM(room.H||0)} mm`;



    const badges = [



      fMat.id !== 'none' ? `<span class="mat-badge floor">Sàn: ${fMat.label}</span>` : '',



      wMat.id !== 'none' ? `<span class="mat-badge wall">Tường: ${wMat.label}</span>` : '',



      cMat.id !== 'none' ? `<span class="mat-badge ceiling">Trần: ${cMat.label}</span>` : '',



    ].filter(Boolean).join('');



    return `



      <div class="room-card">



        <div class="room-card-header">



          <div>



            <div class="room-card-name">${room.name}</div>



            <div class="room-card-dim">${dimLabel}</div>



          </div>



          <div class="room-card-actions">



            <button class="btn-icon-xs" onclick="editRoom('${room.id}')" title="Sửa phòng">



              <i data-lucide="edit-2"></i>



            </button>



            <button class="btn-icon-xs danger" onclick="deleteRoom('${room.id}')" title="Xóa phòng">



              <i data-lucide="trash-2"></i>



            </button>



          </div>



        </div>



        <div class="room-materials">



          ${badges || '<span style="color:var(--text-muted);font-size:11px;">Chưa chọn vật liệu</span>'}



        </div>



        <div class="room-quick-stats">



          <div class="rqs-item">



            <span class="rqs-val">${fmt(calc.rawFloor)}</span>



            <span class="rqs-lbl">m² sàn</span>



          </div>



          <div class="rqs-item">



            <span class="rqs-val">${fmt(calc.rawWall)}</span>



            <span class="rqs-lbl">m² tường</span>



          </div>



          <div class="rqs-item">



            <span class="rqs-val">${(2*((+room.D||0)/1000 + (+room.R||0)/1000)).toFixed(2).replace('.',',')}</span>



            <span class="rqs-lbl">m chu vi</span>



          </div>



          <div class="rqs-item">



            <span class="rqs-val">${calc.items.length}</span>



            <span class="rqs-lbl">hạng mục</span>



          </div>



        </div>



      </div>`;



  }).join('');



  reIcons();



}



// =============================================



// 10. RENDER BẢNG DỰ TOÁN



// =============================================



function renderBOQ(project) {



  const tbody = document.getElementById('boq-tbody');



  const summaryTbody = document.getElementById('boq-summary-tbody');



  // Populate the room filter dropdown



  const filterSelect = document.getElementById('boq-room-filter');



  if (filterSelect) {



    const prevVal = filterSelect.value || 'all';



    let filterHtml = '<option value="all">File tổng</option>';



    (project.rooms || []).forEach(r => {



      filterHtml += `<option value="${r.id}">${r.name}</option>`;



    });



    filterSelect.innerHTML = filterHtml;



    // Restore value if it still exists in the options



    if (Array.from(filterSelect.options).some(opt => opt.value === prevVal)) {



      filterSelect.value = prevVal;



    } else {



      filterSelect.value = 'all';



    }



  }



  if (!project.rooms || project.rooms.length === 0) {



    if (tbody) tbody.innerHTML = `



      <tr><td colspan="10" style="text-align:center;padding:36px;color:var(--text-muted);">Chưa có dữ liệu. Hãy thêm phòng trước.</td></tr>`;



    if (summaryTbody) summaryTbody.innerHTML = `



      <tr><td colspan="7" style="text-align:center;padding:20px;color:var(--text-muted);">Chưa có dữ liệu. Hãy thêm phòng trước.</td></tr>`;



    return;



  }



  // --- Render Bảng Tổng Hợp (có cột riêng cho từng phòng) ---



  const summaryItems = CALC.projectSummary(project);



  const rooms = project.rooms || [];



  // Cập nhật header bảng tổng hợp động theo số phòng



  const sumTable = summaryTbody ? summaryTbody.closest('table') : null;



  if (sumTable) {



    const existThead = sumTable.querySelector('thead');



    if (existThead) {



      const roomCols = rooms.map(r => `<th style="width:90px;text-align:right;color:var(--brand-blue-light);font-size:11px;">${r.name.length > 12 ? r.name.substring(0,12)+'…' : r.name}</th>`).join('');



      existThead.innerHTML = `<tr>



        <th style="width:40px;text-align:center;">STT</th>



        <th>Hạng Mục</th>



        <th style="width:58px;text-align:center;">Đ.Vị</th>



        ${roomCols}



        <th style="width:100px;text-align:right;">Tổng SL</th>



        <th style="width:110px;text-align:right;">Đơn Giá</th>



        <th style="width:120px;text-align:right;">Thành Tiền</th>



      </tr>`;



    }



  }



  if (summaryTbody) {



    const totalCols = 4 + rooms.length; // STT + Hạng mục + ĐV + phòng... + Tổng + ĐG + TT = rooms.length+5



    if (summaryItems.length === 0) {

    summaryTbody.innerHTML = `<tr><td colspan="${totalCols + 2}" style="text-align:center;padding:20px;color:var(--text-muted);">Chưa có dữ liệu tổng hợp. Hãy chọn vật liệu hoặc thêm thiết bị cho phòng.</td></tr>`;

  } else {

    let sumHtml = '';

    const groups = { construction: [], furniture: [], elec: [], sanitary: [] };

    summaryItems.forEach(item => {

      groups[categorizeSummaryItem(item)].push(item);

    });

    const catRomNums = ['I', 'II', 'III', 'IV', 'V', 'VI'];

    let catRomIdx = 0;

    const categoriesConfig = [

      { key: 'construction', label: 'XÂY DỰNG CƠ BẢN (bao gồm tất cả các hạng mục sàn tường trần)' },

      { key: 'furniture',    label: 'THIẾT BỊ NỘI THẤT' },

      { key: 'elec',         label: 'THIẾT BỊ ĐIỆN' },

      { key: 'sanitary',     label: 'THIẾT BỊ VỆ SINH' }

    ];

    categoriesConfig.forEach(catConf => {

      const itemsInCat = groups[catConf.key];

      if (itemsInCat && itemsInCat.length > 0) {

        const rom = catRomNums[catRomIdx++];

        sumHtml += `<tr class="boq-room-header" style="background:rgba(255,255,255,0.05);"><td style="text-align:center;font-weight:700;color:var(--brand-blue-light);">${rom}</td><td colspan="${3 + rooms.length + 2}" style="font-weight:700;color:var(--text-main);">${catConf.label.toUpperCase()}</td></tr>`;

        let itemStt = 1;

        itemsInCat.forEach(item => {

          const roomQtyCols = rooms.map(r => {

            const calc = CALC.room(r);

            const match = calc.items.find(it => it.label === item.label && it.unit === item.unit);

            const q = match ? match.qty : 0;

            return `<td style="text-align:right;font-size:12px;color:var(--text-secondary);">${q > 0 ? fmt(q) : '—'}</td>`;

          }).join('');

          sumHtml += `

            <tr>

              <td style="text-align:center;color:var(--text-muted);font-size:12px;">${itemStt++}</td>

              <td style="font-weight:600;color:var(--text-main);">${item.label}</td>

              <td style="text-align:center;font-size:12px;color:var(--text-secondary);">${item.unit}</td>

              ${roomQtyCols}

              <td style="text-align:right;font-weight:700;color:var(--brand-blue-light);">${fmt(item.qty)}</td>

              <td style="text-align:right;color:var(--text-secondary);">${item.price ? fmt(item.price, 0) : '—'}</td>

              <td style="text-align:right;font-weight:700;color:var(--text-main);">${item.total ? fmt(item.total, 0) : '—'}</td>

            </tr>

          `;

        });

      }

    });

    // ── Chi Phí Khác (cấp dự án) ──────────────────────────

    const oc = project.otherCosts || {};

    const totalFloorSum = rooms.reduce((s, r) => s + (+r.D||0)/1000 * (+r.R||0)/1000, 0);

    const OC_SUM = [

      { key:'transport',   label:'Phí vận chuyển',   unit:'gói', autoQty:false, defaultQty:1 },

      { key:'debris',      label:'Phí tháo gỡ trần, vận chuyển + đổ xà bần, bao rác',      unit:'m²',     autoQty:true  },

      { key:'scaffold',    label:'Phí thuê giàn giáo',                                       unit:'m²',     autoQty:true  },

      { key:'design',      label:'Phí thiết kế',                                             unit:'m²',     autoQty:true  },

      { key:'supervision', label:'Phí giám sát ngoại tỉnh',                                  unit:'lần',    autoQty:false, defaultQty:1 },

    ];

    const blankRoomCols = rooms.map(() => `<td style="text-align:right;color:var(--text-muted);">—</td>`).join('');

    let hasOcRow = false;

    let ocSttSum = 1;

    OC_SUM.forEach(tmpl => {

      const saved = oc[tmpl.key] || {};

      const qty   = tmpl.autoQty ? +totalFloorSum.toFixed(2) : +(saved.qty != null ? saved.qty : tmpl.defaultQty);

      const price = +(saved.price || 0);

      const total = qty * price;

      if (qty > 0 || price > 0) {

        if (!hasOcRow) {

          const rom = catRomNums[catRomIdx++];

          sumHtml += `<tr class="boq-other-header" style="background:rgba(255,160,0,0.08);"><td style="text-align:center;font-weight:700;color:var(--brand-gold);">${rom}</td><td colspan="${3 + rooms.length + 2}" style="font-weight:700;color:var(--brand-gold);">${'CHI PHÍ KHÁC'}</td></tr>`;

          hasOcRow = true;

        }

        sumHtml += `<tr style="border-bottom:1px solid rgba(255,255,255,0.05);">

          <td style="text-align:center;color:var(--text-muted);font-size:12px;">${ocSttSum++}</td>

          <td style="color:var(--text-main);">${tmpl.label}${tmpl.autoQty ? ' <span style="font-size:10px;color:var(--brand-blue-light);">tự động theo sàn</span>' : ''}</td>

          <td style="text-align:center;font-size:12px;color:var(--text-secondary);">${tmpl.unit}</td>

          ${blankRoomCols}

          <td style="text-align:right;color:var(--brand-blue-light);">${fmt(qty)}</td>

          <td style="text-align:right;color:var(--text-secondary);">${price ? fmt(price, 0) : '<em style="color:var(--text-muted);font-size:11px;">chưa nhập</em>'}</td>

          <td style="text-align:right;font-weight:700;color:var(--text-main);">${total ? fmt(total, 0) : '—'}</td>

        </tr>`;

      }

    });

    summaryTbody.innerHTML = sumHtml;

  }



  }



  let html = '';



  let stt = 1;



  const romanNums = ['I','II','III','IV','V','VI','VII','VIII','IX','X',



                     'XI','XII','XIII','XIV','XV','XVI','XVII','XVIII','XIX','XX'];



  project.rooms.forEach((room, idx) => {



    const calc = CALC.room(room);



    stt = 1;   // Reset STT moi phong



    const D = (+room.D || 0) / 1000;



    const R = (+room.R || 0) / 1000;



    const H = (+room.H || 0) / 1000;



    const perim = (2 * (D + R)).toFixed(2).replace('.',',');



    const roman = 'I';

    let subRomIdx = 1; // sub-section Roman counter (1-indexed, I=construction, II=elec)

    // Header: BẢNG KHỐI LƯỢNG - [ROOM NAME] làm tiêu đề phụ, và dòng I. XÂY DỰNG CƠ BẢN

    html += `

      <tr class="boq-room-title" data-kr="${room.id}" style="background:rgba(255,255,255,0.02);border-top:2px solid var(--border-color);"><td colspan="10" style="text-align:center;font-weight:800;font-size:14px;color:var(--brand-blue-light);padding:10px 0;">BẢNG KHỐI LƯỢNG - ${room.name.toUpperCase()}</td></tr>

      <tr class="boq-room-header" data-kr="${room.id}">

        <td colspan="10">${roman}. XÂY DỰNG CƠ BẢN — ${room.name.toUpperCase()}</td>

      </tr>`;



    if (calc.items.length === 0) {



      html += `<tr data-kr="${room.id}"><td colspan="10" style="color:var(--text-muted);font-style:italic;padding:6px 14px;font-size:12px;">Chưa chọn vật liệu</td></tr>`;



    } else {



      const allItems = calc.items;



      allItems.forEach((item, itemIdx) => {



        const key = item._key || item.surface;



        const isFirst = itemIdx === 0;



        const isLast  = itemIdx === allItems.length - 1;



        // --- Section headers (no move buttons) ---



        if (item.surface === 'elecHeader') {



          stt = 1; // Reset STT khi vào phần Điện



          html += `<tr class="boq-elec-header" data-key="${key}" data-kr="${room.id}"><td colspan="10">${romanNums[subRomIdx++] || subRomIdx}. THIẾT BỊ ĐIỆN</td></tr>`;



          return;



        }



        if (item.surface === 'noteHeader') {



          stt = 1; // Reset STT khi vào phần Ghi chú



          html += `<tr class="boq-note-header" data-key="${key}" data-kr="${room.id}"><td colspan="10">${romanNums[subRomIdx++] || subRomIdx}. CHI TIẾT TỪ GHI CHÚ</td></tr>`;



          return;



        }



        // --- Custom items (IN HOA = sub-header + reset STT) ---



        if (item.surface === 'custom') {



          const ci = (room.customItems||[]).find(c => c.id === item.itemId);



          if (!ci) return;



          const labelTrim = (ci.label||'').trim();



          const isSubHdr  = labelTrim.length > 1 && labelTrim === labelTrim.toUpperCase();



          if (isSubHdr) {



            stt = 1; // reset STT

            const subRom = romanNums[subRomIdx++] || subRomIdx;



            html += `



              <tr class="boq-sub-header" data-key="ci:${ci.id}" data-kr="${room.id}" data-ci="${ci.id}">



                <td></td>



                <td colspan="8" class="boq-sub-header-cell" style="font-weight:700;color:var(--brand-purple-light);">${subRom}. ${ci.label}



                  <span class="ci-action-group">



                    <button onclick="moveBoqRow('${room.id}','ci:${ci.id}',-1)" class="btn-ci-action boq-move-up" title="Lên" ${isFirst?'disabled':''}>&#8593;</button>



                    <button onclick="moveBoqRow('${room.id}','ci:${ci.id}',1)"  class="btn-ci-action boq-move-dn" title="Xuống" ${isLast?'disabled':''}>&#8595;</button>



                    <button onclick="startEditRow('${room.id}','${ci.id}')" class="btn-ci-action btn-edit-ci" title="Sửa">&#9998;</button>



                    <button onclick="removeCustomItem('${room.id}','${ci.id}')" class="btn-del-ci" title="Xóa">&#215;</button>



                  </span>



                </td>



                <td></td>



              </tr>`;



            return;



          }



          const qty = +ci.qty||0, price = +ci.price||0;



          html += `



            <tr class="boq-custom-item" data-key="ci:${ci.id}" data-kr="${room.id}" data-ci="${ci.id}">



              <td style="color:var(--text-muted);font-size:12px;text-align:center;">${stt++}</td>



              <td style="color:#a78bfa;font-weight:600;">${ci.label}</td>



              <td class="boq-dim"></td><td class="boq-dim"></td><td class="boq-dim"></td>



              <td style="color:var(--text-secondary);text-align:center;font-size:12px;">${ci.unit}</td>



              <td class="boq-qty">${fmt(qty, 2)}</td>



              <td class="boq-price">${price ? fmt(price, 0) : ''}</td>



              <td class="boq-total">${(qty * price) ? fmt(qty * price, 0) : ''}</td>



              <td class="boq-note" style="white-space:nowrap;">



                <span style="margin-right:4px;color:var(--text-muted);font-size:11px;">${ci.note || ''}</span>



                <span class="ci-action-group">



                  <button onclick="startEditRow('${room.id}','${ci.id}')" class="btn-ci-action btn-edit-ci" title="Sửa">&#9998;</button>



                  <button onclick="moveBoqRow('${room.id}','ci:${ci.id}',-1)" class="btn-ci-action boq-move-up" title="Lên" ${isFirst?'disabled':''}>&#8593;</button>



                  <button onclick="moveBoqRow('${room.id}','ci:${ci.id}',1)"  class="btn-ci-action boq-move-dn" title="Xuống" ${isLast?'disabled':''}>&#8595;</button>



                  <button onclick="removeCustomItem('${room.id}','${ci.id}')" class="btn-del-ci" title="Xóa">&#215;</button>



                </span>



              </td>



            </tr>`;



          return;



        }



        // --- Regular items ---



        const noStt     = false;



        const isManual  = item.surface === 'elecManual';



        const isNoteItem= item.surface === 'noteItem';



        const qtyDisplay = (isManual && item.qty === 0)



          ? `<span style="color:var(--brand-gold);font-style:italic;">-- tự điền</span>`



          : (isNoteItem && item.qty === 0)



            ? `<span style="color:var(--text-muted);font-style:italic;">--</span>`



          : (item.formula



              ? `<span data-formula="${item.formula.replace(/"/g,'&quot;')}" onclick="toggleFormula(this)" class="boq-qty has-formula" title="Click để xem công thức">${fmt(item.qty,2)}</span>`



              : fmt(item.qty, 2));



        html += `



          <tr class="${isManual?'boq-elec-manual':''} ${isNoteItem?'boq-note-item':''}" data-key="${key}" data-kr="${room.id}">



            <td style="color:var(--text-muted);font-size:12px;text-align:center;">${noStt?'':stt++}</td>



            <td${isManual?' style="color:var(--brand-gold);font-style:italic;"':''}${isNoteItem?' style="color:var(--text-secondary);font-style:italic;"':''}>${item.label}</td>



            <td class="boq-dim">${item.dai  ? fmtMM(item.dai)  : ''}</td>



            <td class="boq-dim">${item.rong ? fmtMM(item.rong) : ''}</td>



            <td class="boq-dim">${item.cao  ? fmtMM(item.cao)  : (item.hFull?fmtMM(item.hFull):'')}</td>



            <td style="color:var(--text-secondary);text-align:center;">${item.unit}</td>



            <td class="boq-qty">${qtyDisplay}</td>



            <td class="boq-price">${item.price ? fmt(item.price,0) : ''}</td>



            <td class="boq-total">${item.total ? fmt(item.total,0) : ''}</td>



            <td class="boq-note">



              <span class="boq-note-txt">${item.note||''}</span>



              <span class="ci-action-group">



                <button onclick="moveBoqRow('${room.id}','${key}',-1)" class="btn-ci-action boq-move-up" title="Lên" ${isFirst?'disabled':''}>&#8593;</button>



                <button onclick="moveBoqRow('${room.id}','${key}',1)"  class="btn-ci-action boq-move-dn" title="Xuống" ${isLast?'disabled':''}>&#8595;</button>



              </span>



            </td>



          </tr>`;



      });



      // Insert-bar + Them button at end



      html += `



        <tr class="boq-add-row" data-kr="${room.id}">



          <td colspan="10">



            <button class="btn-add-custom-item" onclick="startInsertRow('${room.id}', null)">



              &#10010; Thêm hạng mục thủ công



            </button>



          </td>



        </tr>`;



      // ── Per-room Chi Phí Khác (ẩn mặc định, hiện khi lọc theo phòng) ──



      const roomArea = +(D * R).toFixed(2);



      const ocPR = project.otherCosts || {};



      const OC_PR = [



        { key:'transport',   label:'Phí vận chuyển',   unit:'gói', autoQty:false, defaultQty:1 },



        { key:'debris',      label:'Phí tháo gỡ trần, vận chuyển + đổ xà bần, bao đựng rác',     unit:'m²',     autoQty:true },



        { key:'scaffold',    label:'Phí thuê giàn giáo',                                           unit:'m²',     autoQty:true },



        { key:'design',      label:'Phí thiết kế',                                                 unit:'m²',     autoQty:true },



        { key:'supervision', label:'Phí giám sát ngoại tỉnh',                                      unit:'lần',    autoQty:false, defaultQty:1 },



      ];



      html += `<tr class="boq-room-oc-hdr" data-kr="${room.id}" style="display:none;">



        <td colspan="10" style="padding:6px 12px;font-weight:700;color:var(--brand-gold);font-size:12px;background:rgba(255,160,0,0.08);">



          ${romanNums[subRomIdx++] || subRomIdx}. 💰 CHI PHÍ KHÁC — ${room.name}



        </td>



      </tr>`;



      let prStt = 1;



      OC_PR.forEach(tmpl => {



        const saved  = ocPR[tmpl.key] || {};



        const qty    = tmpl.autoQty ? roomArea : +(saved.qty != null ? saved.qty : tmpl.defaultQty);



        const price  = +(saved.price || 0);



        const total  = qty * price;



        html += `<tr class="boq-room-oc-item" data-kr="${room.id}" style="display:none;">



          <td style="text-align:center;color:var(--text-muted);font-size:12px;">${prStt++}</td>



          <td>${tmpl.label}${tmpl.autoQty ? ' <span class="oc-auto-tag">diện tích phòng này</span>' : ''}</td>



          <td class="boq-dim"></td><td class="boq-dim"></td><td class="boq-dim"></td>



          <td style="color:var(--text-secondary);text-align:center;">${tmpl.unit}</td>



          <td class="boq-qty">${fmt(qty, 2)}</td>



          <td class="boq-price">${price ? fmt(price, 0) : '<em style="color:var(--text-muted);font-size:11px;">chưa nhập</em>'}</td>



          <td class="boq-total">${total ? fmt(total, 0) : '—'}</td>



          <td class="boq-note"></td>



        </tr>`;



      });



    }



  });



  // ══════════════════════════════════════════════



  // CHI PHÍ KHÁC — section cấp dự án, cuối bảng



  // ══════════════════════════════════════════════



  const totalFloor = (project.rooms || []).reduce((s, r) => {



    const d = (+r.D||0)/1000, rv = (+r.R||0)/1000;



    return s + d * rv;



  }, 0);



  const OC_TEMPLATE = [



    { key: 'transport',   label: 'Phí vận chuyển',   unit: 'gói',   autoQty: false, defaultQty: 1 },



    { key: 'debris',      label: 'Phí tháo gỡ trần, vận chuyển + đổ xà bần, bao đựng rác',       unit: 'm²',       autoQty: true },



    { key: 'scaffold',    label: 'Phí thuê giàn giáo',                                             unit: 'm²',       autoQty: true },



    { key: 'design',      label: 'Phí thiết kế',                                                   unit: 'm²',       autoQty: true },



    { key: 'supervision', label: 'Phí giám sát ngoại tỉnh',                                        unit: 'lần',      autoQty: false, defaultQty: 1 },



  ];



  const oc = project.otherCosts || {};



  stt = 1;  // Reset STT cho CHI PHI KHAC



  html += `<tr class="boq-other-header"><td colspan="10">💰 CHI PHÍ KHÁC</td></tr>`;



  OC_TEMPLATE.forEach(tmpl => {



    const saved   = oc[tmpl.key] || {};



    const qty     = tmpl.autoQty



      ? +(totalFloor).toFixed(2)



      : +(saved.qty != null ? saved.qty : tmpl.defaultQty);



    const price   = +(saved.price || 0);



    const total   = qty * price;



    const noteVal = saved.note || '';



    html += `



      <tr class="boq-other-item">



        <td style="color:var(--text-muted);font-size:12px;text-align:center;">${stt++}</td>



        <td class="boq-other-label">${tmpl.label}



          ${tmpl.autoQty ? '<span class="oc-auto-tag">tự động theo sàn</span>' : ''}



        </td>



        <td class="boq-dim"></td><td class="boq-dim"></td><td class="boq-dim"></td>



        <td style="color:var(--text-secondary);text-align:center;">${tmpl.unit}</td>



        <td class="boq-qty">



          ${tmpl.autoQty



            ? `<span title="= tổng sàn dự án">${fmt(qty,2)}</span>`



            : `<input class="oc-input oc-qty" type="number" min="0" step="0.01"



                 value="${qty}"



                 onchange="updateOtherCost('${tmpl.key}','qty',this.value)"



                 title="Số lượng"/>`



          }



        </td>



        <td class="boq-price">



          <input class="oc-input oc-price" type="number" min="0"



            value="${price || ''}"



            placeholder="Nhập đơn giá"



            onchange="updateOtherCost('${tmpl.key}','price',this.value)"



            title="Đơn giá (₫)"/>



        </td>



        <td class="boq-total oc-total" id="oc-total-${tmpl.key}">



          ${total ? fmt(total, 0) : ''}



        </td>



        <td class="boq-note">



          <input class="oc-input oc-note" type="text"



            value="${noteVal}"



            placeholder="Ghi chú"



            onchange="updateOtherCost('${tmpl.key}','note',this.value)"



            style="width:100%;font-size:11px;"/>



        </td>



      </tr>`;



  });



  // ── Tổng tiền hạng mục (dựa trên items đã tính) ──────



  const grandSubtotal = (project.rooms || []).reduce((s, room) => {



    const calc = CALC.room(room);



    const roomTotal = calc.items.reduce((rs, it) => rs + (+it.total || 0), 0);



    // Cộng chi phí khác per-room nếu có



    return s + roomTotal;



  }, 0);



  // Cộng chi phí khác cấp dự án



  const ocVat = project.otherCosts || {};



  const totalFloorVat = (project.rooms||[]).reduce((s,r)=>s+(+r.D||0)/1000*(+r.R||0)/1000,0);



  const ocSubtotal = [



    { key:'transport',   autoQty:false, defaultQty:1 },



    { key:'debris',      autoQty:true },



    { key:'scaffold',    autoQty:true },



    { key:'design',      autoQty:true },



    { key:'supervision', autoQty:false, defaultQty:1 },



  ].reduce((s, tmpl) => {



    const saved = ocVat[tmpl.key] || {};



    const qty   = tmpl.autoQty ? totalFloorVat : +(saved.qty != null ? saved.qty : tmpl.defaultQty || 0);



    const price = +(saved.price || 0);



    return s + qty * price;



  }, 0);



  const totalBeforeVat = grandSubtotal + ocSubtotal;



  const vatRate = +(project.vatRate ?? 8) / 100;



  const vatAmt  = Math.round(totalBeforeVat * vatRate);



  const grandTotal = totalBeforeVat + vatAmt;



  const colSpanLeft = 7; // STT + Hạng mục + Dài + Rộng + Cao + ĐV + SL



  html += `



    <tr class="boq-total-row boq-subtotal-row" id="boq-row-subtotal">



      <td colspan="${colSpanLeft}" style="text-align:right;font-weight:700;padding:10px 12px;border-top:2px solid var(--border-color);color:var(--text-secondary);">



        Thành tiền (trước VAT):



      </td>



      <td style="text-align:right;font-weight:700;padding:10px 12px;border-top:2px solid var(--border-color);color:var(--brand-gold);" colspan="3">



        ${fmt(totalBeforeVat, 0)} đ



      </td>



    </tr>



    <tr class="boq-total-row boq-vat-row" id="boq-row-vat">



      <td colspan="${colSpanLeft}" style="text-align:right;padding:6px 12px;color:var(--text-secondary);">



        VAT (<span id="boq-vat-label">${Math.round(vatRate*100)}%</span>):



      </td>



      <td style="text-align:right;padding:6px 12px;color:var(--text-secondary);" colspan="3">



        ${fmt(vatAmt, 0)} đ



      </td>



    </tr>



    <tr class="boq-total-row boq-grandtotal-row" id="boq-row-grandtotal">



      <td colspan="8" style="text-align:center;font-weight:800;padding:10px 12px;font-size:14px;border-top:2px solid var(--brand-gold);color:var(--text-main);">



        TỔNG CỘNG



      </td>



      <td style="text-align:right;font-weight:800;padding:10px 12px;font-size:14px;border-top:2px solid var(--brand-gold);color:var(--brand-gold);" colspan="2">



        ${fmt(grandTotal, 0)} đ



      </td>



    </tr>



        <tr class="boq-total-row boq-words-row" id="boq-row-words">

      <td colspan="10" style="padding:8px 12px;font-style:italic;color:var(--text-secondary);font-size:12px;border-top:1px dashed var(--border-color);">

        Bằng chữ: <strong style="color:var(--text-main);">${numberToWords(grandTotal)}</strong>

      </td>

    </tr>

    <tr class="boq-notes-row" style="border:none !important;">

      <td colspan="10" style="border:none !important;padding:12px 12px 4px 12px;font-style:italic;text-align:left;color:var(--text-secondary);">

        Báo giá trên có giá trị trong vòng 30 ngày<br>

        _ Báo giá trên không bao gồm:<br>

        _ Thời gian thi công:

      </td>

    </tr>

    <tr class="boq-signature-row" style="border:none !important;">

      <td style="border:none !important;width:70px;"></td>

      <td colspan="4" style="border:none !important;padding:24px 12px 12px 12px;font-weight:bold;text-align:left;vertical-align:top;color:var(--text-main);">

        Xác nhận của khách hàng

      </td>

      <td colspan="5" style="border:none !important;padding:24px 12px 12px 12px;text-align:center;vertical-align:top;font-style:italic;color:var(--text-secondary);">

        TP. HCM ngày ...... tháng ...... năm 2026

      </td>

    </tr>

    <tr class="boq-signature-row" style="border:none !important;">

      <td style="border:none !important;"></td>

      <td colspan="4" style="border:none !important;"></td>

      <td colspan="5" style="border:none !important;padding:0 12px;text-align:center;font-weight:bold;color:var(--text-main);">

        Giám đốc

      </td>

    </tr>

    <tr class="boq-signature-row" style="border:none !important;height:60px;">

      <td colspan="10" style="border:none !important;height:60px;"></td>

    </tr>

    <tr class="boq-signature-row" style="border:none !important;">

      <td style="border:none !important;"></td>

      <td colspan="4" style="border:none !important;"></td>

      <td colspan="5" style="border:none !important;padding:0 12px;text-align:center;font-weight:bold;color:var(--text-main);">

        VŨ THỊ KIM CHÚC

      </td>

    </tr>`;



  tbody.innerHTML = html;



  // Apply filter



  if (filterSelect) {



    filterBOQByRoom(filterSelect.value);



  }



}



function filterBOQByRoom(roomId) {



  const summarySection = document.getElementById('boq-summary-section');



  const detailSection  = document.getElementById('boq-detail-section');



  const sectionLabel   = document.getElementById('boq-section-label');



  if (roomId === 'all') {



    // File tổng: hiện Tổng Hợp, ẩn Chi Tiết



    if (summarySection) summarySection.style.display = '';



    if (detailSection)  detailSection.style.display  = 'none';



    if (sectionLabel)   sectionLabel.innerHTML = '📊 1. BẢNG TỔNG HỢP KHỐI LƯỢNG TOÀN DỰ ÁN';



    // Ẩn per-room OC, hiện project-level OC



    document.querySelectorAll('#boq-tbody tr.boq-room-oc-hdr, #boq-tbody tr.boq-room-oc-item')



      .forEach(r => r.style.display = 'none');



    document.querySelectorAll('#boq-tbody tr.boq-other-header, #boq-tbody tr.boq-other-item')



      .forEach(r => r.style.display = '');



  } else {



    // Phòng cụ thể: ẩn Tổng Hợp, hiện Chi Tiết



    if (summarySection) summarySection.style.display = 'none';



    if (detailSection)  detailSection.style.display  = '';



    if (sectionLabel) {



      const project = DB.get(state.currentProjectId);



      const room = (project?.rooms || []).find(r => r.id === roomId);



      const roomName = room ? room.name.toUpperCase() : '';



      sectionLabel.innerHTML = `📋 2. BẢNG CHI TIẾT — ${roomName}`;



    }



    // Lọc các dòng dữ liệu phòng



    document.querySelectorAll('#boq-tbody tr').forEach(row => {



      const kr = row.dataset.kr;



      // Ẩn project-level OC khi xem từng phòng cụ thể (rows này không có data-kr)

      if (row.classList.contains('boq-other-header') || row.classList.contains('boq-other-item')) {

        row.style.display = 'none';

        return;

      }

      if (!kr) return; // rows không có data-kr (không nên có)



      if (row.classList.contains('boq-other-header') || row.classList.contains('boq-other-item')) {



        // Ẩn project-level OC khi xem từng phòng



        row.style.display = 'none';



      } else if (row.classList.contains('boq-room-oc-hdr') || row.classList.contains('boq-room-oc-item')) {



        // Hiện per-room OC của phòng đang chọn



        row.style.display = (kr === roomId) ? '' : 'none';



      } else {



        // Các dòng dữ liệu thông thường



        row.style.display = (kr === roomId) ? '' : 'none';



      }



    });



  }



}



// =============================================



// HẠNG MỤC THỦ CÔNG — INLINE EDITING



// =============================================



// Tạo dòng nhập liệu inline



function _buildInlineRow(roomId, itemId, insertIdx, prefill = {}) {



  const tr = document.createElement('tr');



  tr.className = 'ci-edit-row';



  tr.dataset.eRoom = roomId;



  tr.dataset.eItem = itemId || '';



  tr.dataset.eIdx  = insertIdx ?? '';



  tr.innerHTML = `



    <td style="text-align:center;color:#a78bfa;font-size:14px;">&#9998;</td>



    <td colspan="2" style="padding:4px 6px;position:relative;">



      <input class="ci-il" data-f="label" tabindex="1"



        value="${(prefill.label||'').replace(/"/g,'&quot;')}"



        placeholder="T&#234;n h&#7841;ng m&#7909;c *" style="width:100%;" />



      <div class="ci-vattu-suggest" style="display:none;position:absolute;top:100%;left:0;right:0;background:var(--bg-card);border:1px solid var(--brand-gold);border-radius:6px;z-index:9999;max-height:160px;overflow-y:auto;font-size:12px;box-shadow:0 4px 16px rgba(0,0,0,0.4);"></div>



    </td>



    <td style="padding:4px 4px;">



      <input class="ci-il" data-f="unit" tabindex="2"



        value="${prefill.unit||''}" placeholder="&#272;VT"



        style="width:56px;text-align:center;" />



    </td>



    <td style="padding:4px 4px;">



      <input class="ci-il" data-f="qty" type="number" step="0.01" tabindex="3"



        value="${prefill.qty||''}" placeholder="SL"



        style="width:65px;text-align:right;" />



    </td>



    <td style="padding:4px 4px;">



      <input class="ci-il" data-f="price" type="number" tabindex="4"



        value="${prefill.price||''}" placeholder="&#272;&#417;n gi&#225;"



        style="width:100px;text-align:right;" />



    </td>



    <td></td>



    <td style="padding:4px 6px;white-space:nowrap;">



      <input class="ci-il" data-f="note" tabindex="5"



        value="${prefill.note||''}" placeholder="Ghi ch&#250;" style="width:90px;" />



    </td>



    <td style="padding:4px 6px;white-space:nowrap;">



      <button class="btn-ci-isave" onclick="saveInlineRow(false)" title="L&#432;u (Shift+Enter)">&#10003; L&#432;u</button>



      <button class="btn-ci-icancel" onclick="cancelInlineRow()" title="H&#7911;y (Esc)">&#215;</button>



      <div style="font-size:10px;color:var(--text-muted);margin-top:2px;">Enter=L&#432;u+M&#7899;i &nbsp; Shift+Enter=L&#432;u</div>



    </td>`;



  // === FEATURE #6: Gợi ý giá từ Thư Viện Vật Tư ===



  const labelInput = tr.querySelector('.ci-il[data-f="label"]');



  const suggestBox = tr.querySelector('.ci-vattu-suggest');



  const unitInput  = tr.querySelector('.ci-il[data-f="unit"]');



  const priceInput = tr.querySelector('.ci-il[data-f="price"]');



  labelInput.addEventListener('input', () => {



    const q = labelInput.value.trim().toLowerCase();



    if (q.length < 2) { suggestBox.style.display = 'none'; return; }



    const all = VatTuDB.get();



    const matches = all.filter(v =>



      v.name.toLowerCase().includes(q) || (v.code||'').toLowerCase().includes(q)



    ).slice(0, 8);



    if (matches.length === 0) { suggestBox.style.display = 'none'; return; }



    suggestBox.innerHTML = matches.map((v, i) => `



      <div class="ci-vattu-item" data-idx="${i}"



        style="padding:6px 10px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,0.06);



               display:flex;justify-content:space-between;align-items:center;"



        onmousedown="event.preventDefault()"



        onclick="_applyVatTuSuggest(this, '${v.name.replace(/'/g,"\\'")}',${'"'+v.unit+'"'},${'"'+v.price+'"'},${'"'+v.supplier+'"'})">



        <span style="font-weight:500;">${v.name}</span>



        <span style="color:var(--brand-gold);font-size:11px;">${v.price ? v.price.toLocaleString('vi-VN')+' đ/'+v.unit : v.unit}</span>



      </div>`).join('');



    suggestBox.style.display = 'block';



  });



  labelInput.addEventListener('blur', () => {



    setTimeout(() => { suggestBox.style.display = 'none'; }, 200);



  });



  // Excel-like keyboard navigation



  tr.addEventListener('keydown', e => {



    if (e.key === 'Escape') { cancelInlineRow(); return; }



    if (e.key === 'Enter' && e.target.tagName !== 'BUTTON') {



      e.preventDefault();



      if (e.shiftKey) {



        saveInlineRow(false);   // Shift+Enter: luu roi thoi



      } else {



        saveInlineRow(true);    // Enter: luu va mo dong moi



      }



      return;



    }



    // Tab tu o cuoi (note) -> tu dong sang o label cua dong moi



    if (e.key === 'Tab' && !e.shiftKey && e.target.dataset.f === 'note') {



      e.preventDefault();



      saveInlineRow(true);



    }



  });



  return tr;



}



// Callback áp dụng gợi ý vật tư vào các ô trong dòng inline



function _applyVatTuSuggest(el, name, unit, price, supplier) {



  const tr = el.closest('tr.ci-edit-row');



  if (!tr) return;



  const labelIn = tr.querySelector('.ci-il[data-f="label"]');



  const unitIn  = tr.querySelector('.ci-il[data-f="unit"]');



  const priceIn = tr.querySelector('.ci-il[data-f="price"]');



  const noteIn  = tr.querySelector('.ci-il[data-f="note"]');



  if (labelIn) labelIn.value = name;



  if (unitIn  && unit)  unitIn.value  = unit;



  if (priceIn && price) priceIn.value = price;



  if (noteIn  && supplier) noteIn.value = supplier;



  // Ẩn suggest box



  const sb = tr.querySelector('.ci-vattu-suggest');



  if (sb) sb.style.display = 'none';



  priceIn?.focus();



}



// Chèn dòng mới tại vị trí insertIdx (null = cuối)



function startInsertRow(roomId, insertIdx) {



  cancelInlineRow();



  let anchor;



  if (insertIdx === null) {



    anchor = document.querySelector(`tr.boq-add-row[data-kr=""]`);



    if (!anchor) anchor = document.querySelector(`tr.boq-add-row`); // fallback



  } else {



    anchor = document.querySelector(`tr.ci-insert-bar[data-ri="${roomId}"][data-ii="${insertIdx}"]`);



  }



  if (!anchor) return;



  const tr = _buildInlineRow(roomId, '', insertIdx);



  anchor.insertAdjacentElement('beforebegin', tr);



  tr.querySelector('.ci-il[data-f="label"]')?.focus();



}



// Sửa dòng hiện có



function startEditRow(roomId, itemId) {



  cancelInlineRow();



  const project = DB.get(state.currentProjectId);



  const room = (project?.rooms||[]).find(r => r.id === roomId);



  const ci = (room?.customItems||[]).find(c => c.id === itemId);



  if (!ci) return;



  const origRow = document.querySelector(`tr[data-ci="${itemId}"]`);



  if (!origRow) return;



  const tr = _buildInlineRow(roomId, itemId, null, ci);



  origRow.replaceWith(tr);



  tr.querySelector('.ci-il[data-f="label"]')?.focus();



}



// Lưu dòng inline



function saveInlineRow(autoNext = false) {



  const tr = document.querySelector('tr.ci-edit-row');



  if (!tr) return;



  const roomId    = tr.dataset.eRoom;



  const itemId    = tr.dataset.eItem;



  const insertIdx = tr.dataset.eIdx !== '' ? +tr.dataset.eIdx : null;



  const get = f => tr.querySelector(`.ci-il[data-f="${f}"]`)?.value?.trim() || '';



  const label = get('label');



  if (!label) {



    tr.querySelector('.ci-il[data-f="label"]').style.borderColor = '#ef4444';



    tr.querySelector('.ci-il[data-f="label"]').focus();



    return;



  }



  const unit  = get('unit');



  const qty   = parseFloat(get('qty'))   || 0;



  const price = parseFloat(get('price')) || 0;



  const note  = get('note');



  const project = DB.get(state.currentProjectId);



  const room = (project?.rooms||[]).find(r => r.id === roomId);



  if (!room) return;



  let ci = [...(room.customItems||[])];



  if (itemId) {



    const i = ci.findIndex(c => c.id === itemId);



    if (i !== -1) ci[i] = { ...ci[i], label, unit, qty, price, note };



  } else if (insertIdx != null) {



    ci.splice(insertIdx, 0, { id: genId(), label, unit, qty, price, note });



  } else {



    ci.push({ id: genId(), label, unit, qty, price, note });



  }



  DB.updateRoom(state.currentProjectId, roomId, { customItems: ci });



  if (autoNext) {



    // Luu va mo ngay dong nhap moi (Excel-like)



    refreshWorkspace();



    // Mo dong nhap moi o cuoi (sau khi re-render)



    setTimeout(() => startInsertRow(roomId, null), 50);



  } else {



    refreshWorkspace();



  }



}



function cancelInlineRow() {



  const tr = document.querySelector('tr.ci-edit-row');



  if (tr) {



    // Nếu đang edit (có itemId) thì refresh để hiện lại dòng gốc



    if (tr.dataset.eItem) refreshWorkspace();



    else tr.remove();



  }



}



// Giữ lại editCustomItem (legacy – gọi startEditRow)



function editCustomItem(roomId, itemId) { startEditRow(roomId, itemId); }



// openAddItemDialog legacy – gọi startInsertRow



function openAddItemDialog(roomId, editId, insertIdx) {



  if (editId) startEditRow(roomId, editId);



  else startInsertRow(roomId, insertIdx ?? null);



}



function saveAddItem()   { saveInlineRow(); }



function closeAddItem()  { cancelInlineRow(); }



// =============================================



// CHI PHÍ KHÁC — Cập nhật giá trị



// =============================================



function updateOtherCost(key, field, rawVal) {



  const project = DB.get(state.currentProjectId);



  if (!project) return;



  const oc = project.otherCosts ? { ...project.otherCosts } : {};



  if (!oc[key]) oc[key] = {};



  if (field === 'price' || field === 'qty') {



    oc[key][field] = parseFloat(rawVal) || 0;



  } else {



    oc[key][field] = rawVal;



  }



  DB.update(state.currentProjectId, { otherCosts: oc });



  // Cập nhật ô thành tiền của dòng này mà không re-render toàn bộ



  const saved = oc[key];



  const project2 = DB.get(state.currentProjectId);



  const totalFloor = (project2.rooms || []).reduce((s, r) => {



    const d = (+r.D||0)/1000, rv = (+r.R||0)/1000;



    return s + d * rv;



  }, 0);



  const OC_TEMPLATE = [



    { key: 'transport', autoQty: false, defaultQty: 1 },



    { key: 'debris',    autoQty: true },



    { key: 'scaffold',  autoQty: true },



    { key: 'design',    autoQty: true },



    { key: 'supervision', autoQty: false, defaultQty: 1 },



  ];



  const tmpl = OC_TEMPLATE.find(t => t.key === key);



  const qty  = tmpl?.autoQty ? totalFloor : +(saved.qty != null ? saved.qty : tmpl?.defaultQty || 1);



  const price = +saved.price || 0;



  const total = qty * price;



  // Cập nhật ô thành tiền dòng này



  const totalCell = document.getElementById(`oc-total-${key}`);



  if (totalCell) totalCell.textContent = total ? fmt(total, 0) : '';



  // === FIX #10: Tính lại Grand Total và cập nhật các dòng tổng ở cuối bảng ===



  const p3 = DB.get(state.currentProjectId);



  const vatRate3 = +(p3.vatRate ?? 8) / 100;



  // Tổng hạng mục phòng



  const grandSub = (p3.rooms || []).reduce((s, room) => {



    const calc = CALC.room(room);



    return s + calc.items.reduce((rs, it) => rs + (+it.total || 0), 0);



  }, 0);



  // Tổng chi phí khác



  const oc3 = p3.otherCosts || {};



  const tf3 = (p3.rooms||[]).reduce((s,r)=>s+(+r.D||0)/1000*(+r.R||0)/1000, 0);



  const ocSub = OC_TEMPLATE.reduce((s, tmpl3) => {



    const sv3 = oc3[tmpl3.key] || {};



    const q3  = tmpl3.autoQty ? tf3 : +(sv3.qty != null ? sv3.qty : tmpl3.defaultQty || 0);



    return s + q3 * (+(sv3.price || 0));



  }, 0);



  const totalBefore = grandSub + ocSub;



  const vatAmt3 = Math.round(totalBefore * vatRate3);



  const grandTotal3 = totalBefore + vatAmt3;



  // Cập nhật các dòng tổng (nếu chúng đang hiện trên màn hình)



  const subRow = document.getElementById('boq-row-subtotal');



  const vatRow = document.getElementById('boq-row-vat');



  const gtRow  = document.getElementById('boq-row-grandtotal');



  const wdRow  = document.getElementById('boq-row-words');



  const colSpanLeft = 7;



  if (subRow) subRow.innerHTML = `



    <td colspan="${colSpanLeft}" style="text-align:right;font-weight:700;padding:10px 12px;border-top:2px solid var(--border-color);color:var(--text-secondary);">Thành tiền (trước VAT):</td>



    <td style="text-align:right;font-weight:700;padding:10px 12px;border-top:2px solid var(--border-color);color:var(--brand-gold);" colspan="3">${fmt(totalBefore, 0)} đ</td>`;



  if (vatRow) vatRow.innerHTML = `



    <td colspan="${colSpanLeft}" style="text-align:right;padding:6px 12px;color:var(--text-secondary);">VAT (${Math.round(vatRate3*100)}%):</td>



    <td style="text-align:right;padding:6px 12px;color:var(--text-secondary);" colspan="3">${fmt(vatAmt3, 0)} đ</td>`;



  if (gtRow) gtRow.innerHTML = `



    <td colspan="8" style="text-align:center;font-weight:800;padding:10px 12px;font-size:14px;border-top:2px solid var(--brand-gold);color:var(--text-main);">TỔNG CỘNG</td>



    <td style="text-align:right;font-weight:800;padding:10px 12px;font-size:14px;border-top:2px solid var(--brand-gold);color:var(--brand-gold);" colspan="2">${fmt(grandTotal3, 0)} đ</td>`;



  if (wdRow) wdRow.innerHTML = `



    <td colspan="10" style="padding:8px 12px;font-style:italic;color:var(--text-secondary);font-size:12px;border-top:1px dashed var(--border-color);">Bằng chữ: <strong style="color:var(--text-main);">${numberToWords(grandTotal3)}</strong></td>`;



}



// =============================================



// HẠNG MỤC THỦ CÔNG — Thêm / Xóa



// (Các hàm openAddItemDialog/saveAddItem/closeAddItem đã được



//  định nghĩa ở trên — dùng inline row editing)



// =============================================



function moveBoqRow(roomId, key, dir) {



  const project = DB.get(state.currentProjectId);



  const room = (project?.rooms||[]).find(r => r.id === roomId);



  if (!room) return;



  // Lay thu tu hien tai tu CALC



  const calc = CALC.room(room);



  const keys = calc.items.map(it => it._key);



  const idx  = keys.indexOf(key);



  if (idx < 0) return;



  const newIdx = idx + dir;



  if (newIdx < 0 || newIdx >= keys.length) return;



  // Swap



  [keys[idx], keys[newIdx]] = [keys[newIdx], keys[idx]];



  // Neu swap 2 custom items -> update customItems order



  const aKey = calc.items[idx]._key;



  const bKey = calc.items[newIdx]._key;



  const updates = { rowOrder: keys };



  if (aKey.startsWith('ci:') && bKey.startsWith('ci:')) {



    const ci = [...(room.customItems||[])];



    const aId = aKey.slice(3), bId = bKey.slice(3);



    const ai = ci.findIndex(c=>c.id===aId), bi = ci.findIndex(c=>c.id===bId);



    if (ai>=0 && bi>=0) { [ci[ai],ci[bi]] = [ci[bi],ci[ai]]; updates.customItems = ci; }



  }



  DB.updateRoom(state.currentProjectId, roomId, updates);



  refreshWorkspace();



}



function moveCustomItem(roomId, itemId, dir) {



  const project = DB.get(state.currentProjectId);



  const room = (project?.rooms || []).find(r => r.id === roomId);



  if (!room) return;



  const ci = [...(room.customItems || [])];



  const idx = ci.findIndex(c => c.id === itemId);



  const newIdx = idx + dir;



  if (newIdx < 0 || newIdx >= ci.length) return;



  [ci[idx], ci[newIdx]] = [ci[newIdx], ci[idx]];



  DB.updateRoom(state.currentProjectId, roomId, { customItems: ci });



  refreshWorkspace();



}



function removeCustomItem(roomId, itemId) {



  if (!confirm('Xóa hạng mục này?')) return;



  const project = DB.get(state.currentProjectId);



  const room = (project?.rooms || []).find(r => r.id === roomId);



  if (!room) return;



  DB.updateRoom(state.currentProjectId, roomId, {



    customItems: (room.customItems || []).filter(ci => ci.id !== itemId)



  });



  refreshWorkspace();



}



// =============================================



// 11. MODAL VẬT LIỆU



// =============================================



function renderMaterialOptions() {



  // Helper: render single-select



  const render = (containerId, type, selectedId) => {



    const c = document.getElementById(containerId);



    if (!c) return;



    const matList = MATERIALS[type] || [];



    c.innerHTML = matList.map(m => {



      const pct = m.waste > 0 ? ` <span style="color:var(--brand-gold);font-size:10px;">+${(m.waste*100).toFixed(0)}%</span>` : '';



      return `<button class="mat-option${m.id === selectedId ? ' selected' : ''}" data-id="${m.id}" data-type="${type}" data-container="${containerId}">${m.label}${pct}</button>`;



    }).join('');



    // "Khác" input



    if (containerId === 'mat-wall-z1' || containerId === 'mat-wall-z2' || containerId === 'mat-wall') {



      const otherId = `${containerId}-other-label`;



      const otherVal = state.selMat[containerId.replace('mat-','').replace('-','').replace('z','Z')] === 'other'



        ? (state.selMat.otherLabel?.[containerId] || '') : '';



      c.insertAdjacentHTML('beforeend',



        `<input id="${otherId}" class="other-mat-input" type="text" placeholder="Nhập tên vật liệu…"



          value="${otherVal}" style="display:${selectedId==='other'?'inline-block':'none'};



          margin-top:6px;width:100%;padding:5px 8px;background:var(--bg-input);border:1px solid var(--brand-gold);



          border-radius:4px;color:var(--text-main);font-size:12px;"



          oninput="state.selMat.otherLabel=state.selMat.otherLabel||{};state.selMat.otherLabel['${containerId}']=this.value;updatePreview();"/>`);



    }



    c.querySelectorAll('.mat-option').forEach(btn => {



      btn.addEventListener('click', () => {



        c.querySelectorAll('.mat-option').forEach(b => b.classList.remove('selected'));



        btn.classList.add('selected');



        const cid = btn.dataset.container;



        if (cid === 'mat-wall-z1') state.selMat.wallZ1 = btn.dataset.id;



        else if (cid === 'mat-wall-z2') state.selMat.wallZ2 = btn.dataset.id;



        else state.selMat[btn.dataset.type] = btn.dataset.id;



        // Hiện/ẩn input "Khác"



        const oi = document.getElementById(`${cid}-other-label`);



        if (oi) oi.style.display = (btn.dataset.id === 'other') ? 'inline-block' : 'none';



        updatePreview();



      });



    });



  };



  // Helper: render multi-select cho ceiling



  const renderMulti = (containerId, type, selectedIds) => {



    const c = document.getElementById(containerId);



    if (!c) return;



    const sel = Array.isArray(selectedIds) ? selectedIds : (selectedIds ? [selectedIds] : []);



    const matList = MATERIALS[type] || [];



    c.innerHTML = matList.map(m => {



      const pct = m.waste > 0 ? ` <span style="color:var(--brand-gold);font-size:10px;">+${(m.waste*100).toFixed(0)}%</span>` : '';



      const isSelected = sel.includes(m.id);



      return `<button class="mat-option${isSelected ? ' selected' : ''}" data-id="${m.id}" data-type="${type}" data-container="${containerId}">${m.label}${pct}</button>`;



    }).join('');



    c.insertAdjacentHTML('afterbegin',



      `<span style="font-size:10px;color:var(--text-muted);margin-right:6px;align-self:center;">Chọn nhiều:</span>`);



    c.querySelectorAll('.mat-option').forEach(btn => {



      btn.addEventListener('click', () => {



        const id = btn.dataset.id;



        if (id === 'none') {



          // "Bỏ qua" xóa hết lựa chọn khác



          c.querySelectorAll('.mat-option').forEach(b => b.classList.remove('selected'));



          btn.classList.add('selected');



          state.selMat.ceilMats = [];



        } else {



          // Bỏ chọn "Bỏ qua" nếu đang chọn



          c.querySelectorAll('.mat-option[data-id="none"]').forEach(b => b.classList.remove('selected'));



          btn.classList.toggle('selected');



          const now = Array.from(c.querySelectorAll('.mat-option.selected')).map(b => b.dataset.id).filter(x => x !== 'none');



          state.selMat.ceilMats = now;



          if (now.length === 0) {



            c.querySelectorAll('.mat-option[data-id="none"]').forEach(b => b.classList.add('selected'));



          }



        }



        updatePreview();



      });



    });



  };



  render('mat-floor',    'floor',   state.selMat.floor);



  render('mat-wall',     'wall',    state.selMat.wall);



  render('mat-wall-z1',  'wall',    state.selMat.wallZ1);



  render('mat-wall-z2',  'wallZ2',  state.selMat.wallZ2);  // Vùng 2: không có gạch



  renderMulti('mat-ceiling', 'ceiling', state.selMat.ceilMats);



}



function updatePreview() {



  const D  = (+document.getElementById('room-D').value  || 0) / 1000;



  const R  = (+document.getElementById('room-R').value  || 0) / 1000;



  const H  = (+document.getElementById('room-H').value  || 0) / 1000;



  const nd = +document.getElementById('room-doors').value    || 0;



  const dw = (+document.getElementById('room-door-w').value  || 900)  / 1000;



  const dh = (+document.getElementById('room-door-h').value  || 2100) / 1000;



  const nw = +document.getElementById('room-windows').value  || 0;



  const ww = (+document.getElementById('room-window-w').value || 1200) / 1000;



  const wh = (+document.getElementById('room-window-h').value || 1200) / 1000;



  const da = dw * dh;



  const wa = ww * wh;



  const perim = 2 * (D + R);



  const fMat = getMat('floor',   state.selMat.floor);



  const wMat = getMat('wall',    state.selMat.wall);



  const ceilId0 = (state.selMat.ceilMats || [])[0] || 'none';



  const cMat = getMat('ceiling', ceilId0);



  const floor = D * R * (1 + fMat.waste);



  const wall  = Math.max(0, (perim * H - nd*da - nw*wa) * (1 + wMat.waste));



  const ceil  = D * R * (1 + cMat.waste);



  const pgEl = document.getElementById('preview-grid');



  if (!pgEl) return; // Section đã bị ẩn/xóa — bỏ qua



  pgEl.innerHTML = `



    <div class="preview-item">



      <span class="preview-val">${D && R ? fmt(floor) : '—'}</span>



      <span class="preview-lbl">m² sàn</span>



    </div>



    <div class="preview-item">



      <span class="preview-val">${D && R && H ? fmt(wall) : '—'}</span>



      <span class="preview-lbl">m² tường</span>



    </div>



    <div class="preview-item">



      <span class="preview-val">${D && R ? fmt(ceil) : '—'}</span>



      <span class="preview-lbl">m² trần</span>



    </div>



    <div class="preview-item" style="border-top:1px dashed var(--border);padding-top:8px;margin-top:4px;">



      <span class="preview-val" style="color:var(--brand-blue-light);">${D && R ? perim.toFixed(2).replace('.',',') : '—'}</span>



      <span class="preview-lbl">m chu vi</span>



    </div>`;



}



// Cập nhật hiển thị chiều cao Vùng 2 (tự động = H - Z1H)



function updateZ2HDisplay() {



  const H   = +document.getElementById('room-H').value || 0;



  const z1h = +document.getElementById('wall-z1-h').value || 0;



  const z2h = Math.max(0, H - z1h);



  const el  = document.getElementById('wall-z2-h-display');



  if (el) el.textContent = z2h > 0 ? `${z2h.toLocaleString('vi-VN')} mm` : '— mm';



}



// Tự điền chiều cao Vùng 1 khi nhập H phòng



// Mặc định: Vùng 1 = H (toàn bộ chiều cao), người dùng ghi đè thủ công



function autoFillZ1Height(hVal) {



  const H = +hVal || 0;



  const z1Input = document.getElementById('wall-z1-h');



  if (!z1Input) return;



  // Chỉ tự fill nếu người dùng chưa nhập hoặc đang để giá trị mặc định



  const currentZ1 = +z1Input.value || 0;



  const prevH = +z1Input.dataset.prevH || 0;



  if (currentZ1 === 0 || currentZ1 === prevH) {



    z1Input.value = H > 0 ? H : '';



  }



  z1Input.dataset.prevH = H;



  updateZ2HDisplay();



  updatePreview();



}



// =============================================



// 12. MODAL DỰ ÁN



// =============================================



function openProjectModal(project = null) {



  const isEdit = !!project;



  document.getElementById('modal-project-title').textContent = isEdit ? 'Sửa Dự Án' : 'Tạo Dự Án Mới';



  document.getElementById('proj-name').value         = project?.name        || '';



  document.getElementById('proj-client').value       = project?.client      || '';



  document.getElementById('proj-address').value      = project?.address     || '';



  document.getElementById('proj-date').value         = project?.date        || today();



  document.getElementById('proj-vat-rate').value     = project?.vatRate     ?? 8;



  document.getElementById('proj-sender').value       = project?.sender      || '';



  document.getElementById('proj-subtitle').value     = project?.subtitle    || '';



  document.getElementById('proj-company').value      = project?.company     || '';



  document.getElementById('proj-company-addr').value = project?.companyAddr || '';



  document.getElementById('proj-recipient').value    = project?.recipient   || '';



  document.getElementById('proj-client-co').value    = project?.clientCo    || '';



  document.getElementById('proj-client-addr').value  = project?.clientAddr  || '';



  document.getElementById('modal-project').classList.add('open');



  setTimeout(() => document.getElementById('proj-name').focus(), 50);



}



function closeProjectModal() {



  document.getElementById('modal-project').classList.remove('open');



}



function saveProject() {



  const name = document.getElementById('proj-name').value.trim();



  if (!name) {



    document.getElementById('proj-name').focus();



    document.getElementById('proj-name').style.borderColor = 'var(--brand-red)';



    return;



  }



  document.getElementById('proj-name').style.borderColor = '';



  const data = {



    name,



    client:      document.getElementById('proj-client').value.trim(),



    address:     document.getElementById('proj-address').value.trim(),



    date:        document.getElementById('proj-date').value,



    vatRate:     parseFloat(document.getElementById('proj-vat-rate').value) || 0,



    sender:      document.getElementById('proj-sender').value.trim(),



    subtitle:    document.getElementById('proj-subtitle').value.trim(),



    company:     document.getElementById('proj-company').value.trim(),



    companyAddr: document.getElementById('proj-company-addr').value.trim(),



    recipient:   document.getElementById('proj-recipient').value.trim(),



    clientCo:    document.getElementById('proj-client-co').value.trim(),



    clientAddr:  document.getElementById('proj-client-addr').value.trim(),



  };



  const isEdit = document.getElementById('modal-project-title').textContent === 'Sửa Dự Án';



  if (isEdit && state.currentProjectId) {



    DB.update(state.currentProjectId, data);



    // Cập nhật header



    document.getElementById('ws-project-name').textContent    = data.name;



    document.getElementById('ws-project-client').textContent  = data.client  ? `👤 ${data.client}`  : '';



    document.getElementById('ws-project-address').textContent = data.address ? `📍 ${data.address}` : '';



    document.getElementById('ws-project-date').textContent    = data.date    ? `📅 ${data.date}`    : '';



  } else {



    const project = DB.create(data);



    openProject(project.id);



  }



  closeProjectModal();



  renderProjectList();



}



function deleteCurrentProject() {



  const project = DB.get(state.currentProjectId);



  if (!project) return;



  if (!confirm(`Xóa dự án "${project.name}"?\n\nHành động này không thể hoàn tác.`)) return;



  DB.remove(state.currentProjectId);



  state.currentProjectId = null;



  document.getElementById('project-workspace').style.display = 'none';



  document.getElementById('project-workspace').classList.remove('visible');



  document.getElementById('empty-state').style.display = 'flex';



  renderProjectList();



}



// =============================================



// 13. MODAL PHÒNG



// =============================================



// ── Xử lý ảnh hiện trạng điện ──────────────



function handleElecPhotoSelect(files) {



  if (!files || files.length === 0) return;



  Array.from(files).forEach(file => {



    if (!file.type.startsWith('image/')) return;



    const reader = new FileReader();



    reader.onload = e => {



      state.elecPhotos = state.elecPhotos || [];



      state.elecPhotos.push({ name: file.name, data: e.target.result });



      renderElecPhotos();



    };



    reader.readAsDataURL(file);



  });



}



function handleElecPhotoDrop(event) {



  event.preventDefault();



  document.getElementById('elec-photo-zone')?.classList.remove('drag-over');



  handleElecPhotoSelect(event.dataTransfer.files);



}



function renderElecPhotos() {



  const thumbs = document.getElementById('elec-photo-thumbs');



  const prompt = document.getElementById('elec-photo-prompt');



  if (!thumbs) return;



  const photos = state.elecPhotos || [];



  thumbs.innerHTML = photos.map((p, i) => `



    <div class="elec-photo-thumb" title="${p.name}">



      <img src="${p.data}" alt="${p.name}" onclick="viewElecPhoto(${i})">



      <span class="thumb-del" onclick="removeElecPhoto(${i});event.stopPropagation();" title="Xóa ảnh">✕</span>



    </div>`).join('');



  // Ẩn/hiện prompt



  if (prompt) prompt.classList.toggle('hidden', photos.length > 0);



}



function removeElecPhoto(idx) {



  if (!state.elecPhotos) return;



  state.elecPhotos.splice(idx, 1);



  renderElecPhotos();



}



function viewElecPhoto(idx) {



  const p = (state.elecPhotos || [])[idx];



  if (!p) return;



  // Mở ảnh trong tab mới để xem full size



  const w = window.open();



  w.document.write(`<img src="${p.data}" style="max-width:100%;height:auto;" title="${p.name}">`);



}



function getRoomDataFromUI() {



  return {



    name:       document.getElementById('room-name').value.trim(),



    D:          parseFloat(document.getElementById('room-D').value)           || 0,



    R:          parseFloat(document.getElementById('room-R').value)           || 0,



    H:          parseFloat(document.getElementById('room-H').value)           || 0,



    doors:      parseInt(document.getElementById('room-doors').value)         || 0,



    doorW:      parseFloat(document.getElementById('room-door-w').value)      || 900,



    doorH:      parseFloat(document.getElementById('room-door-h').value)      || 2100,



    windows:    parseInt(document.getElementById('room-windows').value)       || 0,



    windowW:    parseFloat(document.getElementById('room-window-w').value)    || 1200,



    windowH:    parseFloat(document.getElementById('room-window-h').value)    || 1200,



    floorMat:   state.selMat.floor,



    wallMat:    state.selMat.wall,



    ceilMats:   state.selMat.ceilMats || [],



    floorPrice: parseFloat(document.getElementById('room-floor-price').value) || 0,



    wallPrice:  parseFloat(document.getElementById('room-wall-price').value)  || 0,



    ceilPrice:  parseFloat(document.getElementById('room-ceil-price').value)  || 0,



    roomNote:   document.getElementById('room-note').value.trim(),



    wallZone:   state.wallZoneMode,



    wallZ1H:    parseFloat(document.getElementById('wall-z1-h').value)        || 1800,



    wallMatZ1:  state.selMat.wallZ1,



    wallMatZ2:  state.selMat.wallZ2,



    wallPriceZ1: parseFloat(document.getElementById('room-wall-price-z1').value) || 0,



    wallPriceZ2: parseFloat(document.getElementById('room-wall-price-z2').value) || 0,



    wallSill:   parseFloat(document.getElementById('room-window-sill').value) || 900,



    wallOtherLabel: state.selMat.otherLabel || {},



    // Electrical inputs



    elecLightDl:      parseInt(document.getElementById('elec-light-dl').value)       || 0,



    elecLightSl:      parseInt(document.getElementById('elec-light-sl').value)       || 0,



    elecLightPanel:   parseInt(document.getElementById('elec-light-panel').value)    || 0,



    elecLightTuyp1200:parseInt(document.getElementById('elec-light-tuyp1200').value) || 0,



    elecLightTuyp600: parseInt(document.getElementById('elec-light-tuyp600').value)  || 0,



    elecLightLed:     parseInt(document.getElementById('elec-light-led').value)      || 0,



    elecSw2:     parseInt(document.getElementById('elec-sw2').value)     || 0,



    elecSw1:     parseInt(document.getElementById('elec-sw1').value)     || 0,



    elecOutlet:  parseInt(document.getElementById('elec-outlet').value)  || 0,



    elecCb1:      parseInt(document.getElementById('elec-cb1').value)       || 0,



    elecCb2:      parseInt(document.getElementById('elec-cb2').value)       || 0,



    elecCb3:      parseInt(document.getElementById('elec-cb3').value)       || 0,



    elecPanelBox: parseInt(document.getElementById('elec-panel-box').value) || 0,



    elecFan:     parseInt(document.getElementById('elec-fan').value)     || 0,



    elecAcWall:    parseInt(document.getElementById('elec-ac-wall').value)    || 0,



    elecAcCeil:    parseInt(document.getElementById('elec-ac-ceil').value)    || 0,



    elecAcCentral: parseInt(document.getElementById('elec-ac-central').value) || 0,



    elecNep:     parseInt(document.getElementById('elec-nep').value)     || 0,



    elecOngRuot: parseInt(document.getElementById('elec-ong-ruot').value)|| 0,



    elecOngCung: parseInt(document.getElementById('elec-ong-cung').value)|| 0,



    elecNote:    document.getElementById('elec-note')?.value.trim() || '',



    elecPhotos:  state.elecPhotos || [],



    noteWoodwork:  document.getElementById('note-woodwork')?.value.trim()  || '',



    notePlumbing:  document.getElementById('note-plumbing')?.value.trim()  || '',



    noteWaterproof: document.getElementById('note-waterproof')?.value.trim() || '',



  };



}



function isRoomFormDirty() {



  if (!document.getElementById('modal-room').classList.contains('open')) return false;



  return JSON.stringify(getRoomDataFromUI()) !== state.originalRoomData;



}



function openRoomModal(room = null) {



  state.editingRoomId = room?.id || null;



  const isEdit = !!room;



  const project = DB.get(state.currentProjectId);



  const projSuffix = project ? ` — Dự án: ${project.name}` : '';



  document.getElementById('modal-room-title').textContent     = (isEdit ? 'Sửa Phòng' : 'Thêm Phòng / Khu Vực') + projSuffix;



  document.getElementById('btn-save-room-label').textContent  = isEdit ? 'Lưu Thay Đổi' : 'Thêm Phòng';

  const mobileLabel = document.getElementById('btn-save-room-label-mobile');

  if (mobileLabel) mobileLabel.textContent = isEdit ? 'Lưu Thay Đổi' : 'Thêm Phòng';



  document.getElementById('room-name').value                  = room?.name     || '';



  document.getElementById('room-D').value                     = room?.D        || '';



  document.getElementById('room-R').value                     = room?.R        || '';



  document.getElementById('room-H').value                     = room?.H        || '';



  document.getElementById('room-doors').value                 = room?.doors    ?? 1;



  document.getElementById('room-door-w').value                = room?.doorW    ?? 900;



  document.getElementById('room-door-h').value                = room?.doorH    ?? 2100;



  document.getElementById('room-windows').value               = room?.windows  ?? 1;



  document.getElementById('room-window-w').value              = room?.windowW  ?? 1200;



  document.getElementById('room-window-h').value              = room?.windowH  ?? 1200;



  document.getElementById('room-floor-price').value           = room?.floorPrice || '';



  document.getElementById('room-wall-price').value            = room?.wallPrice  || '';



  document.getElementById('room-ceil-price').value            = room?.ceilPrice  || '';



  document.getElementById('room-note').value                  = room?.roomNote   || '';



  // Electrical inputs



  document.getElementById('elec-light-dl').value           = room?.elecLightDl       ?? 0;



  document.getElementById('elec-light-sl').value           = room?.elecLightSl       ?? 0;



  document.getElementById('elec-light-panel').value        = room?.elecLightPanel    ?? 0;



  document.getElementById('elec-light-tuyp1200').value     = room?.elecLightTuyp1200 ?? 0;



  document.getElementById('elec-light-tuyp600').value      = room?.elecLightTuyp600  ?? 0;



  document.getElementById('elec-light-led').value          = room?.elecLightLed      ?? 0;



  document.getElementById('elec-sw2').value                   = room?.elecSw2     ?? 0;



  document.getElementById('elec-sw1').value                   = room?.elecSw1     ?? 0;



  document.getElementById('elec-outlet').value                = room?.elecOutlet  ?? 0;



  document.getElementById('elec-cb1').value                = room?.elecCb1      ?? 0;



  document.getElementById('elec-cb2').value                = room?.elecCb2      ?? 0;



  document.getElementById('elec-cb3').value                = room?.elecCb3      ?? 0;



  document.getElementById('elec-panel-box').value          = room?.elecPanelBox ?? 0;



  document.getElementById('elec-fan').value                   = room?.elecFan     ?? 0;



  document.getElementById('elec-ac-wall').value            = room?.elecAcWall    ?? 0;



  document.getElementById('elec-ac-ceil').value            = room?.elecAcCeil    ?? 0;



  document.getElementById('elec-ac-central').value         = room?.elecAcCentral ?? 0;



  document.getElementById('elec-nep').value                   = room?.elecNep     ?? 0;



  document.getElementById('elec-ong-ruot').value              = room?.elecOngRuot ?? 0;



  document.getElementById('elec-ong-cung').value              = room?.elecOngCung ?? 0;



  if (document.getElementById('elec-note'))



    document.getElementById('elec-note').value = room?.elecNote || '';



  if (document.getElementById('note-woodwork'))



    document.getElementById('note-woodwork').value  = room?.noteWoodwork  || '';



  if (document.getElementById('note-plumbing'))



    document.getElementById('note-plumbing').value  = room?.notePlumbing  || '';



  if (document.getElementById('note-waterproof'))



    document.getElementById('note-waterproof').value = room?.noteWaterproof || '';



  // Load ảnh hiện trạng



  state.elecPhotos = room?.elecPhotos ? [...room.elecPhotos] : [];



  renderElecPhotos();



  // Zone mode



  const zoneOn = !!room?.wallZone;



  state.wallZoneMode = zoneOn;



  document.getElementById('wall-zone-toggle').checked = zoneOn;



  document.getElementById('wall-single-mode').style.display  = zoneOn ? 'none' : '';



  document.getElementById('wall-zone-mode').style.display    = zoneOn ? '' : 'none';



  document.getElementById('wall-z1-h').value                  = room?.wallZ1H   || 1800;



  document.getElementById('room-wall-price-z1').value         = room?.wallPriceZ1 || '';



  document.getElementById('room-wall-price-z2').value         = room?.wallPriceZ2 || '';



  document.getElementById('room-window-sill').value           = room?.wallSill   || 900;



  updateZ2HDisplay();



  state.selMat = {



    floor:     room?.floorMat   || 'none',



    wall:      room?.wallMat    || 'none',



    ceilMats:  Array.isArray(room?.ceilMats) ? room.ceilMats



               : (room?.ceilMat ? [room.ceilMat] : []),  // backward compat



    wallZ1:    room?.wallMatZ1  || 'none',



    wallZ2:    room?.wallMatZ2  || 'none',



    otherLabel: room?.wallOtherLabel || {},



  };



  renderMaterialOptions();



  updatePreview();



  document.getElementById('modal-room').classList.add('open');



  setTimeout(() => document.getElementById('room-name').focus(), 50);



  // Lưu trạng thái gốc của form phòng để dirty check



  state.originalRoomData = JSON.stringify(getRoomDataFromUI());



}



function closeRoomModal(forceClose = false) {



  if (!forceClose && isRoomFormDirty()) {



    if (!confirm('Bạn có thay đổi chưa lưu trong phòng này. Bạn có chắc chắn muốn hủy bỏ?')) {



      return;



    }



  }



  document.getElementById('modal-room').classList.remove('open');



  state.editingRoomId = null;



  state.originalRoomData = null;



}



function saveRoom() {



  const name = document.getElementById('room-name').value.trim();



  if (!name) {



    document.getElementById('room-name').focus();



    document.getElementById('room-name').style.borderColor = 'var(--brand-red)';



    return;



  }



  const D = parseFloat(document.getElementById('room-D').value);



  const R = parseFloat(document.getElementById('room-R').value);



  if (!D || !R) {



    alert('Vui lòng nhập kích thước Dài (D) và Rộng (R)!');



    return;



  }



  document.getElementById('room-name').style.borderColor = '';



  const roomData = getRoomDataFromUI();



  if (state.editingRoomId) {



    DB.updateRoom(state.currentProjectId, state.editingRoomId, roomData);



  } else {



    DB.addRoom(state.currentProjectId, roomData);



  }



  closeRoomModal(true); // force close



  refreshWorkspace();



  renderProjectList();



}



// =============================================



// 14. ACTIONS PHÒNG (GỌI TỪ HTML)



// =============================================



function editRoom(roomId) {



  const project = DB.get(state.currentProjectId);



  const room = project?.rooms.find(r => r.id === roomId);



  if (room) openRoomModal(room);



}



function deleteRoom(roomId) {



  if (!confirm('Xóa phòng này?')) return;



  DB.removeRoom(state.currentProjectId, roomId);



  refreshWorkspace();



  renderProjectList();



}



// =============================================



// 14b. XUẤT PDF DẠNG EXCEL



// =============================================



async function exportPDFExcel() {

  const project = DB.get(state.currentProjectId);

  if (!project || !project.rooms || project.rooms.length === 0) {

    alert('Chưa có dữ liệu để xuất!');

    return;

  }



  // Generate sheets using the shared helper

  const wbData = generateWorkbook(project);

  if (!wbData) return;



  // Store globally so confirm function can access it

  window.currentWbData = wbData;



  // Build the checkbox list in the modal

  const listContainer = document.getElementById('pdf-sheets-list');

  if (!listContainer) {

    console.error('pdf-sheets-list container not found');

    return;

  }



  let html = '';

  // 1. Summary sheet

  html += `

    <label style="display: flex; align-items: center; gap: 8px; padding: 6px; cursor: pointer; border-bottom: 1px solid var(--border-faint, rgba(255,255,255,0.04));">

      <input type="checkbox" id="chk-pdf-summary" value="summary" checked style="width: 16px; height: 16px; cursor: pointer;">

      <span style="font-weight: bold; font-size: 13px; color: var(--text-primary);">Bảng tổng hợp</span>

    </label>

  `;



  // 2. Room sheets

  wbData.roomSheets.forEach((rs, idx) => {

    html += `

      <label style="display: flex; align-items: center; gap: 8px; padding: 6px; cursor: pointer; border-bottom: 1px solid var(--border-faint, rgba(255,255,255,0.04));">

        <input type="checkbox" class="chk-pdf-room" value="${idx}" checked style="width: 16px; height: 16px; cursor: pointer;">

        <span style="font-size: 13px; color: var(--text-primary);">Phòng: ${rs.room.name}</span>

      </label>

    `;

  });



  // 3. Materials sheet

  html += `

    <label style="display: flex; align-items: center; gap: 8px; padding: 6px; cursor: pointer;">

      <input type="checkbox" id="chk-pdf-materials" value="materials" style="width: 16px; height: 16px; cursor: pointer;">

      <span style="font-size: 13px; color: var(--text-primary);">Bảng vật tư cần mua</span>

    </label>

  `;



  listContainer.innerHTML = html;



  // Open the modal overlay

  document.getElementById('modal-export-pdf-options').classList.add('open');

  

  if (window.lucide) {

    window.lucide.createIcons();

  }

}



function closeExportPdfModal() {

  document.getElementById('modal-export-pdf-options').classList.remove('open');

}



function toggleSelectAllPdfSheets(selected) {

  const checkboxes = document.querySelectorAll('#pdf-sheets-list input[type="checkbox"]');

  checkboxes.forEach(cb => cb.checked = selected);

}



function confirmExportPDFExcel() {

  const wbData = window.currentWbData;

  if (!wbData) {

    alert('Không tìm thấy dữ liệu xuất!');

    return;

  }



  const chkSummary = document.getElementById('chk-pdf-summary')?.checked;

  const chkMaterials = document.getElementById('chk-pdf-materials')?.checked;

  const roomCheckboxes = document.querySelectorAll('.chk-pdf-room');

  

  const selectedRoomIndexes = [];

  roomCheckboxes.forEach(cb => {

    if (cb.checked) {

      selectedRoomIndexes.push(parseInt(cb.value, 10));

    }

  });



  if (!chkSummary && !chkMaterials && selectedRoomIndexes.length === 0) {

    alert('Vui lòng chọn ít nhất một sheet để xuất PDF!');

    return;

  }



  const selectedSheets = [];

  if (chkSummary) {

    selectedSheets.push({ ws: wbData.wsSum });

  }

  selectedRoomIndexes.forEach(idx => {

    const rs = wbData.roomSheets[idx];

    if (rs) {

      selectedSheets.push({ ws: rs.ws });

    }

  });

  if (chkMaterials) {

    selectedSheets.push({ ws: wbData.wsVT });

  }



  const totalPages = selectedSheets.length;

  let finalHtml = '';



  selectedSheets.forEach((sheetObj, pageIndex) => {

    const wsHtml = renderWorksheetToHtml(sheetObj.ws);

    finalHtml += `

      <div class="ep-page">

        ${wsHtml}

        <div class="ep-footer">

          <span>Du-Toan- BlueAI Lab</span>

          <span>Trang ${pageIndex + 1}/${totalPages}</span>

        </div>

      </div>

    `;

  });



  // Inject into container, close modal, and print

  const container = document.getElementById('excel-pdf-content');

  if (!container) {

    alert('Không tìm thấy container excel-pdf-content!');

    return;

  }



  container.innerHTML = finalHtml;

  closeExportPdfModal();



  document.body.classList.add('print-excel-pdf');

  window.print();

  document.body.classList.remove('print-excel-pdf');

  container.innerHTML = '';

}



function renderWorksheetToHtml(ws) {

  if (!ws || !ws['!ref']) return '';

  

  const range = XLSX.utils.decode_range(ws['!ref']);

  const merges = ws['!merges'] || [];

  

  // Build a map of merged cells

  const mergeMap = {};

  merges.forEach(m => {

    for (let r = m.s.r; r <= m.e.r; r++) {

      for (let c = m.s.c; c <= m.e.c; c++) {

        const isStart = (r === m.s.r && c === m.s.c);

        mergeMap[`${r},${c}`] = { m, isStart };

      }

    }

  });



  // Calculate col widths

  let colHtml = '';

  if (ws['!cols']) {

    colHtml += '<colgroup>';

    for (let c = range.s.c; c <= range.e.c; c++) {

      const col = ws['!cols'][c];

      const w = col && col.wch ? col.wch * 8 : 80;

      colHtml += `<col style="width:${w}px;">`;

    }

    colHtml += '</colgroup>';

  }



  let rowsHtml = '';
  let titleRowsHtml = '';
  let headerRowsHtml = '';
  let dataRowsHtml = '';
  const headerStart = 8;
  const headerEnd = ws.isDetail ? 9 : 8;

  for (let r = range.s.r; r <= range.e.r; r++) {
    let rowHtml = '';

    // Check if row is empty

    let isRowEmpty = true;

    for (let c = range.s.c; c <= range.e.c; c++) {

      const cellRef = XLSX.utils.encode_cell({ r, c });

      if (ws[cellRef] && ws[cellRef].v !== undefined && ws[cellRef].v !== '') {

        isRowEmpty = false;

        break;

      }

    }

    

    rowHtml += '<tr>';

    for (let c = range.s.c; c <= range.e.c; c++) {

      const offset = 0;
      // 1. Logo cell gộp ở A1:B3
      if (r === 0 && c === 0) {
        rowHtml += `<td rowspan="3" colspan="2" style="vertical-align: middle; text-align: left; padding: 4px 6px; border: none;"><img src="logo-bluedecor.png" style="height: 96px; object-fit: contain;" onerror="this.style.display='none'"></td>`;
        continue;
      }
      if (r < 3 && c < 2) {
        // Bỏ qua vì đã gộp vào logo
        continue;
      }



      const mergeInfo = mergeMap[`${r},${c}`];

      if (mergeInfo && !mergeInfo.isStart) {

        continue; // Covered by merge

      }



      const cellRef = XLSX.utils.encode_cell({ r, c });

      const cell = ws[cellRef] || { t: 's', v: '' };

      

      let cellStyles = '';

      

      if (cell.s) {

        // Font

        if (cell.s.font) {

          const font = cell.s.font;

          if (font.name) cellStyles += `font-family:'${font.name}', 'Times New Roman', serif;`;

          if (font.sz) cellStyles += `font-size:${font.sz}pt;`;

          if (font.bold) cellStyles += `font-weight:bold;`;

          if (font.italic) cellStyles += `font-style:italic;`;

          if (font.color && font.color.rgb) cellStyles += `color:#${font.color.rgb};`;

        }

        // Fill

        if (cell.s.fill && cell.s.fill.fgColor && cell.s.fill.fgColor.rgb) {

          cellStyles += `background-color:#${cell.s.fill.fgColor.rgb};`;

        }

        // Alignment

        if (cell.s.alignment) {

          const align = cell.s.alignment;

          if (align.horizontal) cellStyles += `text-align:${align.horizontal};`;

          if (align.vertical) cellStyles += `vertical-align:${align.vertical};`;

          if (align.wrapText) cellStyles += `white-space:normal;word-break:break-word;`;

          else cellStyles += `white-space:nowrap;`;

          if (align.indent) {
            cellStyles += `padding-left:${align.indent * 15}px !important;`;
          }

        }

        // Borders

        if (cell.s.border) {

          const border = cell.s.border;

          const getBorderStyle = (b) => {

            if (!b || b.style === 'none') return 'none';

            const w = b.style === 'medium' ? '1.5pt' : '0.5pt';

            const t = b.style === 'dashed' ? 'dashed' : 'solid';

            const c = b.color && b.color.rgb ? `#${b.color.rgb}` : '#000000';

            return `${w} ${t} ${c}`;

          };

          const tS = getBorderStyle(border.top);

          const bS = getBorderStyle(border.bottom);

          const lS = getBorderStyle(border.left);

          const rS = getBorderStyle(border.right);

          if (tS === 'none' && bS === 'none' && lS === 'none' && rS === 'none') {

            cellStyles += 'border:none;';

          } else {

            if (border.top) cellStyles += `border-top:${tS};`;

            if (border.bottom) cellStyles += `border-bottom:${bS};`;

            if (border.left) cellStyles += `border-left:${lS};`;

            if (border.right) cellStyles += `border-right:${rS};`;

          }

        }

      }



      // Default padding

      cellStyles += `padding: 4px 6px; box-sizing: border-box;`;



      let colspanAttr = '';

      let rowspanAttr = '';

      if (mergeInfo && mergeInfo.isStart) {

        const m = mergeInfo.m;

        const colspan = m.e.c - m.s.c + 1;

        const rowspan = m.e.r - m.s.r + 1;

        if (colspan > 1) colspanAttr = ` colspan="${colspan}"`;

        if (rowspan > 1) rowspanAttr = ` rowspan="${rowspan}"`;

      }



      let valToShow = cell.v !== undefined ? cell.v : '';

      if (cell.w !== undefined) valToShow = cell.w;

      

      if (typeof valToShow === 'string') {

        valToShow = valToShow

          .replace(/&/g, '&amp;')

          .replace(/</g, '&lt;')

          .replace(/>/g, '&gt;')

          .replace(/\n/g, '<br>');

      }



      rowHtml += `<td style="${cellStyles}"${colspanAttr}${rowspanAttr}>${valToShow}</td>`;

    }

    rowHtml += '</tr>';
    rowsHtml += rowHtml;
    if (r < headerStart) {
      titleRowsHtml += rowHtml;
    } else if (r >= headerStart && r <= headerEnd) {
      headerRowsHtml += rowHtml;
    } else {
      dataRowsHtml += rowHtml;
    }
  }



  const tableClass = ws.isDetail ? 'class="ep-detail-table"' : '';
  if (range.e.r < headerStart) {
    return `
      <table ${tableClass} style="border-collapse: collapse; width: 100%; font-family: 'Times New Roman', Times, serif; margin: 0 auto; page-break-inside: auto; table-layout: fixed;">
        ${colHtml}
        <tbody>
          ${rowsHtml}
        </tbody>
      </table>
    `;
  }
  return `
    <table ${tableClass} style="border-collapse: collapse; width: 100%; font-family: 'Times New Roman', Times, serif; margin: 0 auto; page-break-inside: auto; table-layout: fixed; margin-bottom: 0; border-bottom: none;">
      ${colHtml}
      <tbody>
        ${titleRowsHtml}
      </tbody>
    </table>
    <table ${tableClass} style="border-collapse: collapse; width: 100%; font-family: 'Times New Roman', Times, serif; margin: 0 auto; page-break-inside: auto; table-layout: fixed; margin-top: 0; border-top: none;">
      ${colHtml}
      <thead>
        ${headerRowsHtml}
      </thead>
      <tbody>
        ${dataRowsHtml}
      </tbody>
    </table>
  `;

}



// =============================================



// 15. XUẤT EXCEL



// =============================================



// Helper: áp dụng cài đặt trang A4 ngang + số trang + rows repeat cho mỗi sheet



function applyPageSetup(ws, repeatRowsCount) {



  // Khổ giấy A4 ngang



  ws['!pageSetup'] = {



    paperSize:     9,           // 9 = A4



    orientation:   'landscape',



    fitToPage:     true,



    fitToWidth:    1,           // vừa 1 trang ngang (tự thu nhỏ nếu cần)



    fitToHeight:   0,           // tự do theo chiều dọc



    autoBreaks:    true,



    horizontalDpi: 300,



    verticalDpi:   300,



  };



  // Lề trang (đơn vị: inches)



  ws['!margins'] = {



    left:   0.3,



    right:  0.3,



    top:    0.4,



    bottom: 0.5,



    header: 0.2,



    footer: 0.2,



  };



  // Footer: góc trái = ngày giờ in | góc phải = Trang P/N



  ws['!headerFooter'] = {



    oddFooter:  '&L&"Arial,Italic"In ngày: &D &T&R&"Arial,Bold"Trang &P/&N',



    evenFooter: '&L&"Arial,Italic"In ngày: &D &T&R&"Arial,Bold"Trang &P/&N',



  };



  // Rows to repeat at top khi in: lặp lại từ dòng 0 đến repeatRowsCount-1 (0-indexed)



  const rpt = (repeatRowsCount && repeatRowsCount > 0) ? repeatRowsCount : 9;



  ws['!printHeader'] = { rows: { min: 0, max: rpt - 1 } };



}



function applyBorders(ws, headerRows) {



  if (!ws['!ref']) return;



  const range = XLSX.utils.decode_range(ws['!ref']);



  const hdr   = +headerRows || 0;



  const maxCols = range.e.c + 1;



  // Solid thin borders



  const thinBorder = { style: 'thin', color: { rgb: '000000' } };



  // Hair borders for internal gridlines in data cells



  const hairBorder = { style: 'hair', color: { rgb: '000000' } };



  // Find the headers in the table header row



  let headerRowIdx = hdr - 1;



  for (let r = Math.max(0, hdr - 3); r <= Math.min(range.e.r, hdr); r++) {



    const cRef = XLSX.utils.encode_cell({ r, c: 0 });



    if (ws[cRef] && String(ws[cRef].v).toUpperCase().trim() === 'STT') {



      headerRowIdx = r;



      break;



    }



  }



  const headers = [];



  for (let c = 0; c < maxCols; c++) {



    const cRef = XLSX.utils.encode_cell({ r: headerRowIdx, c });



    headers.push(ws[cRef] && ws[cRef].v ? String(ws[cRef].v).toUpperCase().trim() : '');



  }



  const subHeaders = [];



  if (headerRowIdx + 1 <= range.e.r) {



    for (let c = 0; c < maxCols; c++) {



      const cRef = XLSX.utils.encode_cell({ r: headerRowIdx + 1, c });



      subHeaders.push(ws[cRef] && ws[cRef].v ? String(ws[cRef].v).toUpperCase().trim() : '');



    }



  }



  for (let R = range.s.r; R <= range.e.r; R++) {



    for (let C = range.s.c; C <= range.e.c; C++) {



      const ref = XLSX.utils.encode_cell({ r: R, c: C });



      if (!ws[ref]) {



        if (R >= 8) ws[ref] = { t: 's', v: '' };



        else continue;



      }



      const cell = ws[ref];



      cell.s = cell.s || {};



      // Default font family is Times New Roman, size 12



      const font = { name: 'Times New Roman', sz: 12, color: { rgb: '000000' } };



      let fill = null;



      let alignment = { vertical: 'center' };



      let border = null;



      // ── Determine row category ──



      if (R < 8) {



        border = { top: null, bottom: null, left: null, right: null };



        if (R < 3 && C < 2) {



          font.sz = 14;



          font.bold = true;



          font.color = { rgb: '0A3D6B' }; // Navy brand color



          alignment.horizontal = 'center';



          alignment.vertical = 'center';



        } else if (R === 0) {



          font.sz = 24;



          font.bold = true;



          alignment.horizontal = 'center';



        } else if (R === 1 || R === 2) {



          font.sz = 14;



          font.bold = true;



          alignment.horizontal = 'center';



        } else if (R === 4 || R === 5) {



          font.bold = true;



          alignment.horizontal = 'left';



        } else if (R === 6) {



          font.bold = false;



          alignment.horizontal = 'left';



        }



      } else if (R < hdr) {



        // Table Header



        font.bold = true;



        alignment.horizontal = 'center';



        alignment.wrapText = true;



        fill = { type: 'pattern', patternType: 'solid', fgColor: { rgb: 'D9E1F2' } };



        border = { top: thinBorder, bottom: thinBorder, left: thinBorder, right: thinBorder };



      } else {



        // Data and total rows



        let isTotal = false;



        let isGroupHeader = false;



        let isSignatureTitle = false;



        let cellTextA = '';



        const cellARef = XLSX.utils.encode_cell({ r: R, c: 0 });



        if (ws[cellARef] && ws[cellARef].v) {



          cellTextA = String(ws[cellARef].v).toUpperCase().trim();



        }



        // Check if row contains signature keywords



        for (let colIdx = 0; colIdx < maxCols; colIdx++) {



          const cRef = XLSX.utils.encode_cell({ r: R, c: colIdx });



          const val = ws[cRef] ? ws[cRef].v : null;



          if (val && typeof val === 'string') {



            const vUpper = val.toUpperCase().trim();



            if (vUpper.includes('ĐẮK LẮK') || vUpper.includes('GIÁM ĐỐC') || vUpper.includes('ĐỒNG SÁNG LẬP') || vUpper.includes('VŨ THỊ KIM CHÚC') || vUpper.includes('KÝ XÁC NHẬN')) {



              isSignatureTitle = true;



            }



            if (vUpper.includes('CỘNG') || vUpper.includes('THÀNH TIỀN') || vUpper.includes('VAT') || vUpper.includes('THUẾ') || vUpper.includes('BẰNG CHỮ')) {



              isTotal = true;



            }



            if (vUpper.includes('PHÒNG') || vUpper.includes('CHI PHÍ KHÁC') || vUpper.includes('THIẾT BỊ ĐIỆN') || vUpper.includes('CHI TIẾT TỪ GHI CHÚ') || vUpper.includes('THIẾT BỊ NỘI THẤT') || vUpper.includes('PHẦN NƯỚC') || vUpper.includes('CHỐNG THẤM')) {



              isGroupHeader = true;



            }



          }



        }



        if (cellTextA && /^(I|II|III|IV|V|VI|VII|VIII|IX|X)$/.test(cellTextA)) {



          isGroupHeader = true;



        }



        if (isSignatureTitle) {



          border = { top: null, bottom: null, left: null, right: null };



          alignment.horizontal = 'center';



          



          const cRef = XLSX.utils.encode_cell({ r: R, c: C });



          const cellVal = ws[cRef] ? String(ws[cRef].v).toUpperCase() : '';



          if (cellVal.includes('KIM CHÚC') || cellVal.includes('GIÁM ĐỐC') || cellVal.includes('ĐỒNG SÁNG LẬP') || cellVal.includes('VŨ THỊ')) {



            if (cellVal.includes('KIM CHÚC') || cellVal.includes('VŨ THỊ')) {



              font.bold = true;



            }



            alignment.horizontal = 'center';



          }



        } else if (isTotal) {



          // Total row background `#D9E2F3`



          const rowValues = [];



          for (let colIdx = 0; colIdx < maxCols; colIdx++) {



            const cRef = XLSX.utils.encode_cell({ r: R, c: colIdx });



            if (ws[cRef] && ws[cRef].v) rowValues.push(String(ws[cRef].v).toUpperCase().trim());



          }



          const isBC = rowValues.some(v => v.includes('BẰNG CHỮ'));



          if (isBC) {



            fill = null;



            font.bold = true;



            border = { top: thinBorder, bottom: null, left: thinBorder, right: thinBorder };



            alignment.horizontal = 'left';



          } else {



            fill = { type: 'pattern', patternType: 'solid', fgColor: { rgb: 'D9E2F3' } };



            font.bold = true;



            border = { top: thinBorder, bottom: thinBorder, left: thinBorder, right: thinBorder };



            if (C === maxCols - 1 || C === maxCols - 2) {



              alignment.horizontal = 'right';



            } else {



              alignment.horizontal = C === 0 ? 'center' : 'left';



            }



          }



        } else if (isGroupHeader) {



          font.bold = true;



          border = { top: thinBorder, bottom: thinBorder, left: thinBorder, right: thinBorder };



          alignment.horizontal = C === 0 ? 'center' : 'left';



        } else {



          // Regular item row



          border = { top: hairBorder, bottom: hairBorder, left: thinBorder, right: thinBorder };



          const h = headers[C] || '';



          const sh = subHeaders[C] || '';



          if (h === 'STT') {



            alignment.horizontal = 'center';



          } else if (h.includes('HẠNG MỤC') || h.includes('TÊN VẬT TƯ') || h.includes('VẬT TƯ')) {



            alignment.horizontal = 'left';



          } else if (h.includes('Đ. VỊ') || h.includes('ĐVT') || h.includes('Đ.VỊ')) {



            alignment.horizontal = 'center';



          } else if (h.includes('GHI CHÚ') || h.includes('NHÀ CUNG CẤP') || h.includes('PHÒNG SỬ DỤNG')) {



            alignment.horizontal = 'left';



          } else if (sh === 'DÀI' || sh === 'RỘNG' || sh === 'CAO') {



            alignment.horizontal = 'center';



          } else if (h.includes('SỐ LƯỢNG') || h.includes('TỔNG SL') || h.includes('KL') || h.includes('SL') || h.includes('LƯỢNG')) {



            alignment.horizontal = 'right';



          } else if (h.includes('ĐƠN GIÁ')) {



            alignment.horizontal = 'right';



          } else if (h.includes('THÀNH TIỀN')) {



            alignment.horizontal = 'right';



          } else {



            alignment.horizontal = 'right';



          }



        }



      }



      cell.s.font = font;



      if (fill) cell.s.fill = fill;



      cell.s.alignment = alignment;



      if (border) cell.s.border = border;



    }



  }



}



// Helper: chuyển string nhị phân sang ArrayBuffer (dùng cho xlsx-style write)



function s2ab(s) {



  const buf  = new ArrayBuffer(s.length);



  const view = new Uint8Array(buf);



  for (let i = 0; i < s.length; i++) view[i] = s.charCodeAt(i) & 0xFF;



  return buf;



}



// Ghi workbook dưới dạng file xlsx (tương thích xlsx-style)



// Áp dụng cell styles (font, fill, alignment) cho toàn sheet theo chuẩn FILE MẪU

// headerDataRow: row index (0-based) của dòng đầu tiên có data (thường row 8 = index 8)

function applySheetStyles(ws, headerDataRow, sheetType) {
  const romanSet = new Set(['I','II','III','IV','V','VI','VII','VIII','IX','X','XI','XII','XIII','XIV','XV','XVI','XVII','XVIII','XIX','XX']);

  if (!ws['!ref']) return;

  const range = XLSX.utils.decode_range(ws['!ref']);

  // Màu nền header bảng = theme:8 tint:0.8 ≈ #BDD7EE (xanh nhạt Excel)

  const HDR_BG  = 'BDD7EE';

  const WHITE   = 'FFFFFF';



  // Font mặc định toàn sheet: Times New Roman 12

  const baseFont = { name: 'Times New Roman', sz: 12, bold: false, color: { rgb: '000000' } };

  const boldFont = { name: 'Times New Roman', sz: 12, bold: true,  color: { rgb: '000000' } };



  // Borders

  const solidBlack  = { style: 'thin',   color: { rgb: '000000' } };

  const solidMedium = { style: 'medium', color: { rgb: '000000' } };

  const dashedBlack = { style: 'dashed', color: { rgb: '000000' } };



  const hdrRow = (headerDataRow !== undefined) ? headerDataRow : 8; // row index 8,9 = Excel row 9,10

  const totalRows = new Set();
  let footerStartRow = 9999;
  let signatureStartRow = 9999;

  for (let r = range.s.r; r <= range.e.r; r++) {
    for (let c = range.s.c; c <= range.e.c; c++) {
      const cellRef = XLSX.utils.encode_cell({ r: r, c: c });
      if (ws[cellRef] && ws[cellRef].v !== undefined) {
        const valStr = String(ws[cellRef].v).trim();
        const valLower = valStr.toLowerCase();
        
        if (
          valLower.includes('thành tiền (trước vat)') ||
          valLower.includes('cộng trước vat') ||
          valLower.includes('thuế vat') ||
          valLower.startsWith('vat') ||
          valLower === 'tổng cộng' ||
          valLower === 'tổng cộng vật tư (theo dự toán)'
        ) {
          totalRows.add(r);
        }
        
        if (
          valLower.startsWith('bằng chữ:') ||
          valStr.startsWith('*') ||
          valLower.includes('xác nhận của khách') ||
          valLower.includes('xác nhận của kh') ||
          valLower.includes('người lập bảng') ||
          valLower.startsWith('tp. hcm ngày') ||
          valLower.startsWith('tp.hcm ngày')
        ) {
          if (r < footerStartRow) {
            footerStartRow = r;
          }
        }
        if (
          valLower.includes('xác nhận của khách') ||
          valLower.includes('xác nhận của kh') ||
          valLower.includes('người lập bảng') ||
          valLower === 'giám đốc' ||
          valLower.includes('vũ thị kim chúc')
        ) {
          if (r < signatureStartRow) {
            signatureStartRow = r;
          }
        }
      }
    }
  }

  for (let R = range.s.r; R <= range.e.r; R++) {

    for (let C = range.s.c; C <= range.e.c; C++) {

      const ref = XLSX.utils.encode_cell({ r: R, c: C });

      if (!ws[ref]) ws[ref] = { t: 's', v: '' };

      ws[ref].s = ws[ref].s || {};

      const val = ws[ref].v ? String(ws[ref].v).trim() : '';



      const isHeaderRow  = (sheetType === 'detail') ? (R === hdrRow || R === hdrRow + 1) : (R === hdrRow);

      const isTitleRow   = (R < 8); // Các dòng tiêu đề phía trên

      const isBigTitle   = (R === 0); // Dòng tiêu đề lớn nhất (Times 24 bold)

      const isMedTitle   = (R === 1 || R === 2); // Times 14 bold



      // Font

      let font;

      if (isBigTitle) {

        font = { name: 'Times New Roman', sz: 20, bold: true, color: { rgb: '000000' } };

      } else if (isMedTitle) {

        font = { name: 'Times New Roman', sz: 14, bold: true, color: { rgb: '000000' } };

      } else if (isHeaderRow) {

        font = { ...boldFont };

      } else if (isTitleRow && (R === 4 || R === 5)) {

        font = { ...boldFont };

      } else {

        font = { ...baseFont };

      }

      ws[ref].s.font = font;

    if (val === 'Xác nhận của khách hàng' || val === 'Người lập bảng' || val === 'Giám đốc' || val === 'VŨ THỊ KIM CHÚC') {

      ws[ref].s.font = { name: 'Times New Roman', sz: 12, bold: true, color: { rgb: '000000' } };

    } else if (val.startsWith('Báo giá trên có giá trị') || val.startsWith('_ Báo giá trên') || val.startsWith('_ Thời gian thi công') || val.startsWith('TP. HCM ngày ......')) {

      ws[ref].s.font = { name: 'Times New Roman', sz: 11, italic: true, color: { rgb: '000000' } };

    }



      // Fill

      if (R < hdrRow) {

        ws[ref].s.fill = { patternType: 'solid', fgColor: { rgb: WHITE }, bgColor: { rgb: WHITE } };

      } else if (R >= footerStartRow) {

        ws[ref].s.fill = { patternType: 'solid', fgColor: { rgb: WHITE }, bgColor: { rgb: WHITE } };

      } else if (isHeaderRow) {

        ws[ref].s.fill = { patternType: 'solid', fgColor: { rgb: HDR_BG }, bgColor: { rgb: HDR_BG } };

      }



      // Alignment

      if (sheetType === 'detail' && totalRows.has(R)) {
        if (C < 8) {
          ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };
        } else if (C === 8) {
          ws[ref].s.alignment = { horizontal: 'right', vertical: 'center', wrapText: true };
        } else {
          ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true };
        }
      } else if (sheetType === 'vt' && totalRows.has(R)) {
        if (C < 6) {
          ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };
        } else if (C === 6) {
          ws[ref].s.alignment = { horizontal: 'right', vertical: 'center', wrapText: true };
        } else {
          ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true };
        }
      } else if (R >= signatureStartRow) {

        if (val === 'Xác nhận của khách hàng' || val === 'Người lập bảng') {
          ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true };
        } else {
          ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };
        }

      } else if (R >= footerStartRow) {

        if (val === 'Giám đốc' || val === 'VŨ THỊ KIM CHÚC' || val.startsWith('TP. HCM ngày ......')) {

          ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };

        } else {

          ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true };

        }

      } else if (R === 4 || R === 5 || R === 6) {

        ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true };

      } else if (R === 0 || R === 1 || R === 2) {

        ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: false };

      } else if (isHeaderRow) {

        ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };

      } else if (val === 'Giám đốc' || val === 'VŨ THỊ KIM CHÚC' || val.startsWith('TP. HCM ngày ......')) {

      ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };

    } else if (val === 'Xác nhận của khách hàng') {

      ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true };

    } else if (sheetType === 'detail') {

      if (C === 0) {

        ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };

      } else if (C === 1) {

        const cellA = ws[XLSX.utils.encode_cell({r: R, c: 0})];
        const valA = cellA ? String(cellA.v || '').trim() : '';
        const isSectionHeader = romanSet.has(valA);
        if (!isTitleRow && !isHeaderRow && R < footerStartRow && !isSectionHeader && val !== '') {
          ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true, indent: 1 };
        } else {
          ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true };
        }

      } else if (C >= 2 && C <= 5) {

        ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };

      } else if (C >= 6 && C <= 9) {

        ws[ref].s.alignment = { horizontal: 'right', vertical: 'center', wrapText: true };

      }

    } else if (sheetType === 'vt') {

      if (C === 0) {
        ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };
      } else if (C === 1) {
        const cellA = ws[XLSX.utils.encode_cell({r: R, c: 0})];
        const valA = cellA ? String(cellA.v || '').trim() : '';
        const isSectionHeader = romanSet.has(valA);
        if (!isTitleRow && !isHeaderRow && R < footerStartRow && !isSectionHeader && val !== '') {
          ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true, indent: 1 };
        } else {
          ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true };
        }
      } else if (C === 2) {
        ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };
      } else if (C >= 3 && C <= 6) {
        ws[ref].s.alignment = { horizontal: 'right', vertical: 'center', wrapText: true };
      } else {
        ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true };
      }

    } else {

      if (C === 0) {

        ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };

      } else if (C === 1) {

        const cellA = ws[XLSX.utils.encode_cell({r: R, c: 0})];
        const valA = cellA ? String(cellA.v || '').trim() : '';
        const isSectionHeader = romanSet.has(valA);
        if (sheetType === 'sum' && !isTitleRow && !isHeaderRow && R < footerStartRow && !isSectionHeader && val !== '') {
          ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true, indent: 1 };
        } else {
          ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true };
        }

      } else if (C === 2) {

        ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };

      } else if (C >= 3) {

        ws[ref].s.alignment = { horizontal: 'right', vertical: 'center', wrapText: true };

      }

    }



      // Borders
      if (R < hdrRow) {
        ws[ref].s.border = {
          top:    { style: 'none' },
          bottom: { style: 'none' },
          left:   { style: 'none' },
          right:  { style: 'none' },
        };
      } else {
        if (R >= footerStartRow) {
          ws[ref].s.border = {
            top:    { style: 'none' },
            bottom: { style: 'none' },
            left:   { style: 'none' },
            right:  { style: 'none' },
          };
        } else if (totalRows.has(R)) {
          ws[ref].s.border = {
            top:    solidBlack,
            bottom: solidBlack,
            left:   solidBlack,
            right:  solidBlack,
          };
        } else if (isHeaderRow) {
          ws[ref].s.border = {
            top: solidMedium, bottom: solidMedium,
            left: solidMedium, right: solidMedium,
          };
        } else {
          ws[ref].s.border = {
            top:    dashedBlack,
            bottom: dashedBlack,
            left:   solidBlack,
            right:  solidBlack,
          };
        }
      }

    }

  }

}



  // Helper: bold cho section header rows

  function applyBoldSectionRows(ws, hdrDataRow, colOffset = 0) {

    if (!ws['!ref']) return;

    const romanSet = new Set(['I','II','III','IV','V','VI','VII','VIII',

      'IX','X','XI','XII','XIII','XIV','XV','XVI','XVII','XVIII','XIX','XX']);

    const range = XLSX.utils.decode_range(ws['!ref']);

    const startRow = (hdrDataRow !== undefined ? hdrDataRow : 8) + 2;

    for (let R = startRow; R <= range.e.r; R++) {

      const cellA = ws[XLSX.utils.encode_cell({r: R, c: colOffset})];

      const valA = cellA ? String(cellA.v || '').trim() : '';

      const cellB = ws[XLSX.utils.encode_cell({r: R, c: colOffset + 1})];

      const valB = cellB ? String(cellB.v || '') : '';

      let isSection = romanSet.has(valA);

      if (!isSection && valA === '') {

        let allEmpty = true;

        for (let c = colOffset + 2; c <= Math.min(range.e.c, 8 + colOffset); c++) {

          const cv = ws[XLSX.utils.encode_cell({r: R, c})];

          if (cv && cv.v !== '' && cv.v !== undefined) { allEmpty = false; break; }

        }

        if (allEmpty && valB && valB === valB.toUpperCase() && valB.trim().length > 2) isSection = true;

      }

      if (isSection) {

        for (let C = range.s.c; C <= range.e.c; C++) {

          const ref = XLSX.utils.encode_cell({r: R, c: C});

          if (!ws[ref]) ws[ref] = { t: 's', v: '' };

          ws[ref].s = ws[ref].s || {};

          ws[ref].s.font = { name: 'Times New Roman', sz: 12, bold: true, color: { rgb: '000000' } };

          // Outside borders for section row
          ws[ref].s.border = {
            top:    { style: 'thin', color: { rgb: '000000' } },
            bottom: { style: 'thin', color: { rgb: '000000' } },
            left:   C === range.s.c ? { style: 'thin', color: { rgb: '000000' } } : { style: 'none' },
            right:  C === range.e.c ? { style: 'thin', color: { rgb: '000000' } } : { style: 'none' },
          };

          // Alignments for section row
          if (C === colOffset) {
            ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };
          } else if (C === colOffset + 1) {
            ws[ref].s.alignment = { horizontal: 'left', vertical: 'center', wrapText: true };
          } else {
            ws[ref].s.alignment = { horizontal: 'center', vertical: 'center', wrapText: true };
          }

        }

      }

    }

  }

function xlsxWrite(wb, fileName) {



  try {



    const out = XLSX.write(wb, { bookType: 'xlsx', bookSST: false, type: 'binary' });



    saveAs(new Blob([s2ab(out)], { type: 'application/octet-stream' }), fileName);



  } catch (e) {



    // Fallback: nếu saveAs không có, dùng XLSX.writeFile thường



    console.warn('xlsx-style saveAs failed, using writeFile fallback', e);



    XLSX.writeFile(wb, fileName);



  }



}



function generateWorkbook(project) {



  



  



  if (!project.rooms || project.rooms.length === 0) {



    alert('Chưa có dữ liệu để xuất. Hãy thêm phòng trước!');



    return;



  }



  if (!window.XLSX) {



    alert('Thư viện xuất Excel chưa tải xong. Vui lòng thử lại sau vài giây!');



    return;



  }



  const wb   = XLSX.utils.book_new();

  const roomSheets = [];



  // Hàm phụ tạo khung Header cho mỗi sheet



  const buildHeader = (aoaArray, mergesArray, title, maxCols, colOffset = 0) => {

    const blk = () => Array(maxCols).fill('');

    // Row 0 (Excel row 1): Tiêu đề chính — center từ C(idx 2) đến hết

    const r0 = blk(); r0[2 + colOffset] = title; aoaArray.push(r0);

    // Row 1 (Excel row 2): Subtitle / tên dự án

    const r1 = blk(); r1[2 + colOffset] = project.subtitle || project.name || ''; aoaArray.push(r1);

    // Row 2 (Excel row 3): CÔNG TRÌNH: [tên]

    const r2 = blk(); r2[2 + colOffset] = `CÔNG TRÌNH: ${project.name || ''}`.toUpperCase(); aoaArray.push(r2);

    // Row 3 (Excel row 4): Blank

    aoaArray.push(blk());

    // Row 4 (Excel row 5): Từ | Kính gởi

    const r4 = blk(); r4[0 + colOffset] = `Từ : ${project.sender || ''}`; r4[4 + colOffset] = `Kính gởi: ${project.recipient || project.client || ''}`; aoaArray.push(r4);

    // Row 5 (Excel row 6): Công Ty bên A | Công Ty bên B

    const r5 = blk(); r5[0 + colOffset] = `Công Ty: ${project.company || ''}`; r5[4 + colOffset] = `Công Ty: ${project.clientCo || ''}`; aoaArray.push(r5);

    // Row 6 (Excel row 7): Địa chỉ bên A | Địa chỉ bên B

    const r6 = blk(); r6[0 + colOffset] = `Địa chỉ : ${project.companyAddr || ''}`; r6[4 + colOffset] = `Địa chỉ : ${project.clientAddr || project.address || ''}`; aoaArray.push(r6);

    // Row 7 (Excel row 8): Blank

    aoaArray.push(blk());



    // Merges phần header thông tin (rows 0-6, tức Excel rows 1-7)

    // Row 0,1,2: C(2) → cuối = merge [2..maxCols-1], A(0) chỉ 1 ô

    [0,1,2].forEach(r => mergesArray.push({s:{r,c:2 + colOffset}, e:{r,c:maxCols-1}}));

    // Row 4,5,6: Từ = A(0)..C(3), Kính gởi = E(4)..cuối

    [4,5,6].forEach(r => {

      mergesArray.push({s:{r,c:0 + colOffset}, e:{r,c:3 + colOffset}});

      mergesArray.push({s:{r,c:4 + colOffset}, e:{r,c:maxCols-1}});

    });

  };



  // ==========================================================



  // SHEET 1: TỔNG HỢP KHỐI LƯỢNG (có cột từng phòng)



  // ==========================================================



  const rooms = project.rooms || [];



  const sumCols = 7 + rooms.length; // STT + Hạng mục + ĐV + [phòng×N] + Tổng SL + ĐG + TT + Ghi chú



  const aoaSum = [];



  const mergesSum = [];



  buildHeader(aoaSum, mergesSum, 'BẢNG TỔNG HỢP KHỐI LƯỢNG', sumCols);



  // Row 8: Table Header động



  const sumHeaderRow = ['STT', 'HẠNG MỤC', 'Đ. VỊ'];



  rooms.forEach(r => sumHeaderRow.push(r.name.toUpperCase()));



  sumHeaderRow.push('TỔNG SỐ LƯỢNG', 'ĐƠN GIÁ', 'THÀNH TIỀN', 'GHI CHÚ');



  aoaSum.push(sumHeaderRow);



  const summaryItems = CALC.projectSummary(project);

  // Grouping

  const groups = { construction: [], furniture: [], elec: [], sanitary: [] };

  summaryItems.forEach(item => {

    groups[categorizeSummaryItem(item)].push(item);

  });

  const catRomNums = ['I', 'II', 'III', 'IV', 'V', 'VI'];

  let catRomIdx = 0;

  let curRowSum = 9;

  let grandTotalSum = 0;

  

  const categoriesConfig = [

    { key: 'construction', label: 'XÂY DỰNG CƠ BẢN (bao gồm tất cả các hạng mục sàn tường trần)' },

    { key: 'furniture',    label: 'THIẾT BỊ NỘI THẤT' },

    { key: 'elec',         label: 'THIẾT BỊ ĐIỆN' },

    { key: 'sanitary',     label: 'THIẾT BỊ VỆ SINH' }

  ];

  

  categoriesConfig.forEach(catConf => {

    const itemsInCat = groups[catConf.key];

    if (itemsInCat && itemsInCat.length > 0) {

      const catHdr = Array(sumCols).fill('');

      const rom = catRomNums[catRomIdx++];

      catHdr[0] = rom;

      catHdr[1] = catConf.label.toUpperCase();

      aoaSum.push(catHdr);

      // mergesSum.push({ s: { r: curRowSum, c: 1 }, e: { r: curRowSum, c: sumCols - 1 } });

      curRowSum++;

      

      let itemStt = 1;

      itemsInCat.forEach(item => {

        const row = [itemStt++, item.label, item.unit];

        rooms.forEach(r => {

          const calc = CALC.room(r);

          const match = calc.items.find(it => it.label === item.label && it.unit === item.unit);

          row.push(match && match.qty > 0 ? fmtNum(match.qty, 2) : '');

        });

        row.push(fmtNum(item.qty, 2));

        row.push(item.price ? fmtNum(item.price, 0) : '');

        row.push(item.total ? fmtNum(item.total, 0) : '');

        row.push(item.note || '');

        aoaSum.push(row);

        grandTotalSum += item.total || 0;

        curRowSum++;

      });

    }

  });

  

  // ========== CHI PHÍ KHÁC (Sheet Tổng Hợp) ==========

  let ocStt = 1;

  const oc = project.otherCosts || {};

  const totalFloor = (project.rooms || []).reduce((s, r) => {

    const d = (+r.D||0)/1000, rv = (+r.R||0)/1000;

    return s + d * rv;

  }, 0);

  const OC_TEMPLATE = [

    { key: 'transport',   label: 'Phí vận chuyển',   unit: 'gói',   autoQty: false, defaultQty: 1 },

    { key: 'debris',      label: 'Phí tháo gỡ trần, vận chuyển + đổ xà bần, bao đựng rác',       unit: 'm²',       autoQty: true },

    { key: 'scaffold',    label: 'Phí thuê giàn giáo',                                             unit: 'm²',       autoQty: true },

    { key: 'design',      label: 'Phí thiết kế',                                                   unit: 'm²',       autoQty: true },

    { key: 'supervision', label: 'Phí giám sát ngoại tỉnh',                                        unit: 'lần',      autoQty: false, defaultQty: 1 },

  ];

  let hasOcSum = false;

  OC_TEMPLATE.forEach(tmpl => {

    const saved = oc[tmpl.key] || {};

    const qty = tmpl.autoQty ? +(totalFloor).toFixed(2) : +(saved.qty != null ? saved.qty : tmpl.defaultQty);

    const price = +(saved.price || 0);

    const total = qty * price;

    if (price > 0 || qty > 0) {

      if (!hasOcSum) {

        const ocHdr = Array(sumCols).fill('');

        const rom = catRomNums[catRomIdx++];

        ocHdr[0] = rom;

        ocHdr[1] = 'CHI PHÍ KHÁC';

        aoaSum.push(ocHdr);

        // mergesSum.push({ s: { r: curRowSum, c: 1 }, e: { r: curRowSum, c: sumCols - 1 } });

        curRowSum++;

        hasOcSum = true;

      }

      const row = [ocStt++, tmpl.label, tmpl.unit];

      rooms.forEach(() => row.push(''));

      row.push(qty);

      row.push(price);

      row.push(total);

      row.push(saved.note || '');

      aoaSum.push(row);

      grandTotalSum += total;

      curRowSum++;

    }

  });

  

  const vatRateExcel = +(project.vatRate ?? 8) / 100;

  const vatAmtExcel  = Math.round(grandTotalSum * vatRateExcel);

  const grandWithVat = grandTotalSum + vatAmtExcel;

  

  // ── Subtotal

  const subRowSum = Array(sumCols).fill(''); subRowSum[1] = 'Cộng trước VAT';

  if (grandTotalSum > 0) subRowSum[sumCols - 2] = fmtNum(grandTotalSum, 0);

  aoaSum.push(subRowSum);

  mergesSum.push({s:{r:curRowSum,c:1}, e:{r:curRowSum,c:sumCols - 3}});

  curRowSum++;

  // ── VAT

  const vatRowSum = Array(sumCols).fill(''); vatRowSum[1] = `Thuế VAT (${Math.round(vatRateExcel * 100)}%)`;

  if (vatAmtExcel > 0) vatRowSum[sumCols - 2] = fmtNum(vatAmtExcel, 0);

  aoaSum.push(vatRowSum);

  mergesSum.push({s:{r:curRowSum,c:1}, e:{r:curRowSum,c:sumCols - 3}});

  curRowSum++;

  // ── Tổng cộng

  const thRowSum = Array(sumCols).fill(''); thRowSum[1] = 'TỔNG CỘNG';

  if (grandWithVat > 0) thRowSum[sumCols - 2] = fmtNum(grandWithVat, 0);

  aoaSum.push(thRowSum);

  mergesSum.push({s:{r:curRowSum,c:1}, e:{r:curRowSum,c:sumCols - 3}});

  curRowSum++;

  // ── Bằng chữ

  const wordsRow = Array(sumCols).fill('');

  wordsRow[1] = `Bằng chữ: ${numberToWords(grandWithVat)}`;

  aoaSum.push(wordsRow);

  mergesSum.push({s:{r:curRowSum,c:1}, e:{r:curRowSum,c:sumCols - 1}});

  curRowSum++;



  const noteRow1 = Array(sumCols).fill('');

  noteRow1[1] = 'Báo giá trên có giá trị trong vòng 30 ngày';

  aoaSum.push(noteRow1);

  mergesSum.push({ s: { r: curRowSum, c: 1 }, e: { r: curRowSum, c: sumCols - 1 } });

  curRowSum++;



  const noteRow2 = Array(sumCols).fill('');

  noteRow2[1] = '_ Báo giá trên không bao gồm:';

  aoaSum.push(noteRow2);

  mergesSum.push({ s: { r: curRowSum, c: 1 }, e: { r: curRowSum, c: sumCols - 1 } });

  curRowSum++;



  const noteRow3 = Array(sumCols).fill('');

  noteRow3[0] = '_ Thời gian thi công:';

  aoaSum.push(noteRow3);

  mergesSum.push({ s: { r: curRowSum, c: 0 }, e: { r: curRowSum, c: sumCols - 1 } });

  curRowSum++;



  aoaSum.push(Array(sumCols).fill(''));

  curRowSum++;



  const rightColIdx = Math.max(4, sumCols - 4);

  const signRow = Array(sumCols).fill('');

  signRow[1] = 'Xác nhận của khách hàng';

  signRow[rightColIdx] = 'TP. HCM ngày ...... tháng ...... năm 2026';

  aoaSum.push(signRow);

  mergesSum.push({ s: { r: curRowSum, c: 1 }, e: { r: curRowSum, c: rightColIdx - 1 } });

  mergesSum.push({ s: { r: curRowSum, c: rightColIdx }, e: { r: curRowSum, c: sumCols - 1 } });

  curRowSum++;



  const directorRow = Array(sumCols).fill('');

  directorRow[rightColIdx] = 'Giám đốc';

  aoaSum.push(directorRow);

  mergesSum.push({ s: { r: curRowSum, c: rightColIdx }, e: { r: curRowSum, c: sumCols - 1 } });

  curRowSum++;



  aoaSum.push(Array(sumCols).fill(''));

  curRowSum++;



  const nameRow = Array(sumCols).fill('');

  nameRow[rightColIdx] = 'VŨ THỊ KIM CHÚC';

  aoaSum.push(nameRow);

  mergesSum.push({ s: { r: curRowSum, c: rightColIdx }, e: { r: curRowSum, c: sumCols - 1 } });

  curRowSum++;

  const wsSum = XLSX.utils.aoa_to_sheet(aoaSum);

  wsSum['!merges'] = mergesSum;

  // Cột: STT(5)+HM(32)+ĐV(6)+[phòng×10]+Tổng(11)+ĐG(12)+TT(13) → vừa A4 ngang

  const sumColWidths = [{ wch:6.33 }, { wch:35.0 }, { wch:6 }];

  rooms.forEach(() => sumColWidths.push({ wch:10 }));

  sumColWidths.push({ wch:11 }, { wch:12 }, { wch:13 }, { wch:24 });

  wsSum['!cols'] = sumColWidths;

  applyPageSetup(wsSum, 9);

  applySheetStyles(wsSum, 8, 'sum');

  applyBoldSectionRows(wsSum, 7);

  applyBoldSectionRows(wsSum, 7);

  

  XLSX.utils.book_append_sheet(wb, wsSum, "Tổng hợp");



  // ==========================================================



  // ==========================================================



  project.rooms.forEach((room, idx) => {



    const aoa = [];



    const merges = [];



    buildHeader(aoa, merges, `BẢNG KHỐI LƯỢNG - ${room.name.toUpperCase()}`, 10, 0);



    // Row 8 & 9: Table Header



    aoa.push(['STT', 'HẠNG MỤC', 'KÍCH THƯỚC', '', '', 'Đ. VỊ', 'SỐ LƯỢNG', 'ĐƠN GIÁ', 'THÀNH TIỀN', 'GHI CHÚ']);



    aoa.push(['', '', 'DÀI', 'RỘNG', 'CAO', '', '', '', '', '']);



    // Table header merges



    merges.push({s:{r:8,c:0},  e:{r:9,c:0}});  // STT



    merges.push({s:{r:8,c:1},  e:{r:9,c:1}});  // HẠNG MỤC



    merges.push({s:{r:8,c:2},  e:{r:8,c:4}});  // KÍCH THƯỚC



    merges.push({s:{r:8,c:5},  e:{r:9,c:5}});  // Đ. VỊ



    merges.push({s:{r:8,c:6},  e:{r:9,c:6}});  // SỐ LƯỢNG



    merges.push({s:{r:8,c:7},  e:{r:9,c:7}});  // ĐƠN GIÁ



    merges.push({s:{r:8,c:8},  e:{r:9,c:8}});  // THÀNH TIỀN



    merges.push({s:{r:8,c:9},  e:{r:9,c:9}});  // GHI CHÚ



    let curRow = 10;



    let itemStt = 1;



    const blkDetail = () => Array(10).fill('');



    const calc = CALC.room(room);

    let excelSubRomIdx = 1; // Khởi đầu phân mục con từ II

    // Dòng phân mục XÂY DỰNG CƠ BẢN

    const secRow = blkDetail();

    const romanNums = ['I','II','III','IV','V','VI','VII','VIII','IX','X','XI','XII','XIII','XIV','XV','XVI','XVII','XVIII','XIX','XX'];

    const roman = 'I';

    secRow[0] = roman;

    secRow[1] = 'XÂY DỰNG CƠ BẢN';

    aoa.push(secRow);



    // merges.push({s:{r:curRow,c:1}, e:{r:curRow,c:9}});



    curRow++;



    // Ghi chú phòng (không render infoRow nữa)



    if (room.roomNote) {



      const noteR = blkDetail();



      noteR[1] = `• ${room.roomNote}`;



      aoa.push(noteR);



      merges.push({s:{r:curRow,c:1}, e:{r:curRow,c:9}});



      curRow++;



    }



    let roomTotal = 0;



    const formulaMap = []; // {r: aoa_row, c: col, f: formula_string}



    if (calc.items.length === 0) {



      const er = blkDetail(); er[1] = '(Chưa chọn vật liệu)';



      aoa.push(er);



      curRow++;



    } else {



      calc.items.forEach(item => {



        // Skip các header section (render riêng)



        if (item.surface === 'custom') {

          const ci = (room.customItems || []).find(c => c.id === item.itemId);

          if (ci) {

            const labelTrim = (ci.label || '').trim();

            const isSubHdr = labelTrim.length > 1 && labelTrim === labelTrim.toUpperCase();

            if (isSubHdr) {

              const hdr = blkDetail();

              hdr[0] = romanNums[excelSubRomIdx] || excelSubRomIdx;

              hdr[1] = ci.label;

              excelSubRomIdx++;

              itemStt = 1; // reset STT

              aoa.push(hdr);

              // merges.push({s:{r:curRow,c:1}, e:{r:curRow,c:9}});

              curRow++;

              return;

            }

          }

        }

        if (item.surface === 'elecHeader') {



          const hdr = blkDetail();



          hdr[0] = romanNums[excelSubRomIdx] || excelSubRomIdx;

          hdr[1] = 'THIẾT BỊ ĐIỆN';

          excelSubRomIdx++;

          itemStt = 1;



          aoa.push(hdr);



          // merges.push({s:{r:curRow,c:1}, e:{r:curRow,c:9}});



          curRow++;



          return;



        }



        if (item.surface === 'noteHeader') {



          const hdr = blkDetail();



          hdr[0] = romanNums[excelSubRomIdx] || excelSubRomIdx;

          hdr[1] = 'CHI TIẾT TỪ GHI CHÚ';

          excelSubRomIdx++;

          itemStt = 1;



          aoa.push(hdr);



          // merges.push({s:{r:curRow,c:1}, e:{r:curRow,c:9}});



          curRow++;



          return;



        }



        const noStt = false;



        const isManual = item.surface === 'elecManual';



        const sttVal = noStt ? '' : itemStt++;



        // ─ Dùng số thực (mm) cho DÀI/RỘNG/CAO để formula tham chiếu được



        const daiNum  = item.dai  ? +item.dai  : '';



        const rongNum = item.rong ? +item.rong : '';



        const caoNum  = item.cao  ? +item.cao  : '';



        // ─ Số lượng: đặt số tĩnh trước, sau sẽ ghi đè formula



        const qtyVal = (isManual && item.qty === 0) ? '' : fmtNum(item.qty, 2);



        const priceVal = item.price ? fmtNum(item.price, 0) : '';



        const totalVal = item.total ? fmtNum(item.total, 0) : '';



        // ─ Định mức hao hụt: chỉ lấy phần note (% hao hụt)



        const wasteStr = item.note || '';



        const aoaRow = curRow; // lưu row index trước khi push



        aoa.push([

          sttVal,


          item.label,

          daiNum,

          rongNum,

          caoNum,

          item.unit,

          qtyVal,

          priceVal,

          totalVal,

          wasteStr,

        ]);

        // ─ Đăng ký formula cho cột SỐ LƯỢNG (col G = idx 6)

        // Excel row = aoaRow + 1 (1-indexed), cols A=1 B=2 C=3 D=4 E=5 F=6 G=7 H=8 I=9 J=10

        const exR = aoaRow + 1;

        let qtyFormula = null;

        if (item.surface === 'floor' && daiNum && rongNum) {
          // Diện tích sàn: (DÀI/1000) × (RỘNG/1000) × (1 + hao hụt)
          const waste = item.qty > 0 ? +(item.qty / ((+item.dai/1000)*(+item.rong/1000))).toFixed(4) : 1;
          qtyFormula = `C${exR}/1000*D${exR}/1000*${waste.toFixed(4)}`;

        } else if (item.surface === 'ceiling' && daiNum && rongNum) {

          const waste = item.qty > 0 ? +(item.qty / ((+item.dai/1000)*(+item.rong/1000))).toFixed(4) : 1;

          qtyFormula = `C${exR}/1000*D${exR}/1000*${waste.toFixed(4)}`;

        } else if (item.surface === 'perimeter' && daiNum && rongNum) {

          qtyFormula = `(C${exR}*2+D${exR}*2)/1000`;

        } else if (item.surface === 'ceilPerim' && daiNum && rongNum) {

          qtyFormula = `(C${exR}*2+D${exR}*2)/1000`;

        } else if (item.surface === 'wall' && daiNum && caoNum) {

          // Diện tích tường: (Chu vi/1000) × (Chiều cao/1000) × tỷ lệ thực tế
          const waste = item.qty > 0 ? +(item.qty / ((+item.dai/1000)*(+item.cao/1000))).toFixed(4) : 1;
          qtyFormula = `C${exR}/1000*E${exR}/1000*${waste.toFixed(4)}`;

        } else if ((item.surface === 'door' || item.surface === 'window') && rongNum && caoNum) {

          // Diện tích cửa: (Rộng/1000) × (Cao/1000) × số bộ cửa
          const factor = item.qty > 0 ? +(item.qty / ((+item.rong/1000)*(+item.cao/1000))).toFixed(4) : 1;
          qtyFormula = `D${exR}/1000*E${exR}/1000*${factor.toFixed(4)}`;

        }

        if (qtyFormula) formulaMap.push({ r: aoaRow, c: 6, f: qtyFormula });



        roomTotal += item.total || 0;



        curRow++;



      });



    }



    // ── Ghi chú Mộc / Nước / Chống thấm → mỗi dòng = 1 hạng mục

[

  { text: room.noteWoodwork,   label: 'THIẾT BỊ NỘI THẤT' },

  { text: room.notePlumbing,   label: 'PHẦN NƯỚC' },

  { text: room.noteWaterproof, label: 'CHỐNG THẤM' },

].forEach(({ text, label }) => {

  if (!text || !text.trim()) return;

  // Dòng tiêu đề section

  const hdrN = blkDetail();

  hdrN[0] = romanNums[excelSubRomIdx] || excelSubRomIdx;

  hdrN[1] = label;

  excelSubRomIdx++;

  aoa.push(hdrN);

  // merges.push({ s: { r: curRow, c: 1 }, e: { r: curRow, c: 9 } });

  curRow++;

  itemStt = 1;

  // Mỗi dòng textarea → 1 hàng riêng

  const noteLines = text.split('\n').map(l => l.trim()).filter(l => l);

  noteLines.forEach((line, li) => {

    const lr = blkDetail();

    lr[0] = li + 1;          // STT

    lr[1] = line;            // keep original casing

    lr[5] = 'cái';           // ĐVT

    lr[6] = 1;               // Qty

    aoa.push(lr);

    merges.push({ s: { r: curRow, c: 1 }, e: { r: curRow, c: 4 } });

    curRow++;

  });

});

// ── CHI PHÍ KHÁC (trong sheet chi tiết phòng)

{

  const oc = project.otherCosts || {};

  const tf = (+room.D||0)/1000 * (+room.R||0)/1000;

  const OC_DETAIL = [

    { key:'transport',   label:'Phí vận chuyển',                                               unit:'gói', autoQty:false, defaultQty:1 },

    { key:'debris',      label:'Phí tháo gỡ trần, vận chuyển + đổ xà bần, bao đựng rác',       unit:'m\u00b2',  autoQty:true },

    { key:'scaffold',    label:'Phí thuê giàn giáo',                                             unit:'m\u00b2',  autoQty:true },

    { key:'design',      label:'Phí thiết kế',                                                   unit:'m\u00b2',  autoQty:true },

    { key:'supervision', label:'Phí giám sát ngoại tỉnh',                                        unit:'lần', autoQty:false, defaultQty:1 },

  ];

  let hasOcDetail = false;

  OC_DETAIL.forEach(tmpl => {

    const saved = oc[tmpl.key] || {};

    const qty = tmpl.autoQty ? +tf.toFixed(2) : +(saved.qty != null ? saved.qty : (tmpl.defaultQty||0));

    const price = +(saved.price || 0);

    const total = qty * price;

    if (price > 0 || qty > 0) {

      if (!hasOcDetail) {

        const ocHdr = blkDetail();

        ocHdr[0] = romanNums[excelSubRomIdx] || excelSubRomIdx;

        ocHdr[1] = 'CHI PHÍ KHÁC';

        excelSubRomIdx++;

        aoa.push(ocHdr);
        curRow++;

        hasOcDetail = true; itemStt = 1;

      }

      const ocRow = blkDetail();

      ocRow[0] = itemStt++;

      ocRow[1] = tmpl.label; ocRow[5] = tmpl.unit;

      ocRow[6] = qty ? fmtNum(qty,2) : '';

      ocRow[7] = price ? fmtNum(price,0) : '';

      ocRow[8] = total ? fmtNum(total,0) : '';

      aoa.push(ocRow); curRow++;

      roomTotal += total;

    }

  });

}

// ── Cộng phòng + VAT + Tổng + Bằng chữ



    aoa.push(blkDetail()); curRow++;



    const vatRateRoom   = +(project.vatRate ?? 8) / 100;



    const vatAmtRoom    = Math.round(roomTotal * vatRateRoom);



    const roomGrandTotal = roomTotal + vatAmtRoom;



    const subTotalRow = blkDetail();



    subTotalRow[0] = 'Thành tiền (trước VAT)';



    if (roomTotal > 0) subTotalRow[8] = fmtNum(roomTotal, 0);



    aoa.push(subTotalRow);



    merges.push({s:{r:curRow,c:0}, e:{r:curRow,c:7}});



    curRow++;



    const vatRowRoom = blkDetail();



    vatRowRoom[0] = `VAT (${Math.round(vatRateRoom * 100)}%)`;



    if (vatAmtRoom > 0) vatRowRoom[8] = fmtNum(vatAmtRoom, 0);



    aoa.push(vatRowRoom);



    merges.push({s:{r:curRow,c:0}, e:{r:curRow,c:7}});



    curRow++;



    const totalRowRoom = blkDetail();



    totalRowRoom[0] = 'TỔNG CỘNG';



    if (roomGrandTotal > 0) totalRowRoom[8] = fmtNum(roomGrandTotal, 0);



    aoa.push(totalRowRoom);



    merges.push({s:{r:curRow,c:0}, e:{r:curRow,c:7}});



    curRow++;



    const wordsRowRoom = blkDetail();

    wordsRowRoom[0] = `Bằng chữ: ${numberToWords(roomGrandTotal)}`;

    aoa.push(wordsRowRoom);

    merges.push({s:{r:curRow,c:0}, e:{r:curRow,c:9}});

    curRow++;



    const noteRow1 = blkDetail();

    noteRow1[0] = 'Báo giá trên có giá trị trong vòng 30 ngày';

    aoa.push(noteRow1);

    merges.push({ s: { r: curRow, c: 0 }, e: { r: curRow, c: 9 } });

    curRow++;



    const noteRow2 = blkDetail();

    noteRow2[0] = '_ Báo giá trên không bao gồm:';

    aoa.push(noteRow2);

    merges.push({ s: { r: curRow, c: 0 }, e: { r: curRow, c: 9 } });

    curRow++;



    const noteRow3 = blkDetail();

    noteRow3[0] = '_ Thời gian thi công:';

    aoa.push(noteRow3);

    merges.push({ s: { r: curRow, c: 0 }, e: { r: curRow, c: 9 } });

    curRow++;



    aoa.push(blkDetail());

    curRow++;



    const signRow = blkDetail();

    signRow[1] = 'Xác nhận của khách hàng';

    signRow[6] = 'TP. HCM ngày ...... tháng ...... năm 2026';

    aoa.push(signRow);

    merges.push({ s: { r: curRow, c: 1 }, e: { r: curRow, c: 5 } });

    merges.push({ s: { r: curRow, c: 6 }, e: { r: curRow, c: 9 } });

    curRow++;



    const directorRow = blkDetail();

    directorRow[6] = 'Giám đốc';

    aoa.push(directorRow);

    merges.push({ s: { r: curRow, c: 6 }, e: { r: curRow, c: 9 } });

    curRow++;



    aoa.push(blkDetail());

    curRow++;



    const nameRow = blkDetail();

    nameRow[6] = 'VŨ THỊ KIM CHÚC';

    aoa.push(nameRow);

    merges.push({ s: { r: curRow, c: 6 }, e: { r: curRow, c: 9 } });

    curRow++;



    const wsDetail = XLSX.utils.aoa_to_sheet(aoa);
    wsDetail.isDetail = true;



    // Áp dụng công thức Excel vào cột SỐ LƯỢNG



    formulaMap.forEach(({r, c, f}) => {



      const cellRef = XLSX.utils.encode_cell({r, c});



      wsDetail[cellRef] = { t: 'n', f };



    });



    wsDetail['!merges'] = merges;



    wsDetail['!cols'] = [

      { wch: 6.33 },  // STT Column A

      { wch: 35.0 },  // HẠNG MỤC Column B

      { wch: 9  },  // DÀI Column C

      { wch: 9  },  // RỘNG Column D

      { wch: 9  },  // CAO Column E

      { wch: 6  },  // Đ. VỊ Column F

      { wch: 10 },  // SỐ LƯỢNG Column G

      { wch: 13.41 },  // ĐƠN GIÁ Column H

      { wch: 12.75 },  // THÀNH TIỀN Column I

      { wch: 24 }   // GHI CHÚ Column J

    ];  // Tổng = 134 vừa A4 ngang



    applyPageSetup(wsDetail, 10);  // A4 ngang + số trang



    applySheetStyles(wsDetail, 8, 'detail');

    applyBoldSectionRows(wsDetail, 8, 0);



    // Sanitize sheet name: limit to 30 chars, remove invalid chars \ / ? * [ ]



    let sheetName = room.name.replace(/[\\\/\?\*\[\]]/g, '').trim();



    if (sheetName.length > 30) {



      sheetName = sheetName.substring(0, 30);



    }



    let finalSheetName = sheetName || `Phong_${idx + 1}`;



    let suffix = 1;



    while (wb.SheetNames.includes(finalSheetName)) {



      finalSheetName = `${sheetName.substring(0, 25)}_${suffix++}`;



    }



    XLSX.utils.book_append_sheet(wb, wsDetail, finalSheetName);

    roomSheets.push({ room, ws: wsDetail, finalSheetName });



  });



  let wsVT;

  // SHEET 2: DANH SÁCH VẬT TƯ CẦN MUA



  // ==========================================================



  (() => {



    // ── Thu thập toàn bộ items từ tất cả phòng ──────────────



    // Map: key = `${label}||${unit}` → { label, unit, surface, price, rooms:[], totalQty, totalAmt }



    const matMap = new Map();



    // Nhóm surface → tên nhóm tiếng Việt



    const GROUP_LABEL = {



      floor:      'SÀN',



      wall:       'TƯỜNG SƠN NƯỚC',



      ceiling:    'TRẦN SƠN NƯỚC',



      perimeter:  'CHU VI / ĐỊA ĐẲNG',



      ceilPerim:  'CHU VI TRẦN',



      window:     'CỬA',



      ceilMat:    'ỐP TRẦN VẬT LIỆU',



      floorMat:   'ỐP SÀN VẬT LIỆU',



      wallMat:    'ỐP TƯỜNG VẬT LIỆU',



      elec:       'THIẾT BỊ ĐIỆN',



      elecManual: 'THIẾT BỊ ĐIỆN',



      noteItem:   'VẬT TƯ KHÁC',



    };



    (project.rooms || []).forEach(room => {



      const calc = CALC.room(room);



      calc.items.forEach(item => {



        if (['elecHeader','noteHeader','perimeter','ceilPerim'].includes(item.surface)) return;



        if (!item.qty || item.qty <= 0) return;



        const key = `${item.surface}||${item.label}||${item.unit}`;



        if (!matMap.has(key)) {



          matMap.set(key, {



            surface:  item.surface,



            group:    GROUP_LABEL[item.surface] || 'KHÁC',



            label:    item.label,



            unit:     item.unit,



            price:    item.price || 0,



            note:     item.note  || '',



            rooms:    [],



            totalQty: 0,



            totalAmt: 0,



          });



        }



        const m = matMap.get(key);



        m.totalQty += item.qty || 0;



        m.totalAmt += item.total || 0;



        m.rooms.push(room.name);



        // Giữ giá mới nhất nếu trùng



        if (item.price) m.price = item.price;



      });



    });



    // ── Sắp xếp: theo nhóm surface rồi theo tên ─────────────



    const surfaceOrder = ['floor','wall','ceiling','ceilMat','floorMat','wallMat','window','elec','elecManual','noteItem'];



    const matList = [...matMap.values()].sort((a,b) => {



      const ga = surfaceOrder.indexOf(a.surface);



      const gb = surfaceOrder.indexOf(b.surface);



      if (ga !== gb) return ga - gb;



      return a.label.localeCompare(b.label);



    });



    // ── Build AOA ────────────────────────────────────────────



    const VT_COLS = 9; // Vật tư|ĐV|Tổng KL|KL + Dự phòng|Đơn giá|Thành tiền|Phòng|NCC|Ghi chú



    const aoaVT  = [];



    const mergesVT = [];



    buildHeader(aoaVT, mergesVT, 'DANH SÁCH VẬT TƯ CẦN MUA', VT_COLS);



    // Header bảng



    aoaVT.push(['STT', 'TÊN VẬT TƯ / HẠNG MỤC', 'ĐVT',

      'KL TÍNH TOÁN', 'KL CẦN MUA (+ 5% DP)',

      'ĐƠN GIÁ', 'THÀNH TIỀN (DT)',

      'PHÒNG SỬ DỤNG', 'NHÀ CUNG CẤP', 'GHI CHÚ']);



    let curRowVT = aoaVT.length - 1; // header row index



    // Merge header cells







    curRowVT++;



    let stt = 1;



    let prevGroup = null;



    let groupTotal = 0;



    let groupStartRow = curRowVT;



    let grandTotal = 0;



    const pushGroupTotal = (group) => {



      if (prevGroup === null) return;



      const gRow = Array(VT_COLS).fill('');



      gRow[0] = `CỘNG ${prevGroup}`;



      gRow[5] = fmtNum(groupTotal, 0);



      aoaVT.push(gRow);



      mergesVT.push({s:{r:curRowVT,c:0}, e:{r:curRowVT,c:5}});



      curRowVT++;



      groupTotal = 0;



    };



          const vtRomNums = ['I','II','III','IV','V','VI','VII','VIII','IX','X',

        'XI','XII','XIII','XIV','XV','XVI','XVII','XVIII','XIX','XX'];

      let vtRomIdx = 0;

matList.forEach(m => {



      // Dòng nhóm mới



      if (m.group !== prevGroup) {



        pushGroupTotal(prevGroup);



        const gHdr = Array(VT_COLS).fill('');



        gHdr[0] = vtRomNums[vtRomIdx++] || '';

          gHdr[1] = m.group;



        aoaVT.push(gHdr);



        // mergesVT.push({s:{r:curRowVT,c:1}, e:{r:curRowVT,c:VT_COLS-1}});



        curRowVT++;



        prevGroup = m.group;



        groupStartRow = curRowVT;

        stt = 1; // Reset STT for the new group



      }



      const buyQty = m.totalQty * 1.05; // +5% dự phòng



      const dptAmt = buyQty * m.price;



      groupTotal += m.totalAmt;



      grandTotal += m.totalAmt;



      aoaVT.push([

        stt++,

        m.label,

        m.unit,

        fmtNum(m.totalQty, 2),

        fmtNum(buyQty, 2),

        m.price ? fmtNum(m.price, 0) : '',

        m.totalAmt ? fmtNum(m.totalAmt, 0) : '',

        [...new Set(m.rooms)].join(', '),

        '',   // NCC — để trống điền tay

        m.note || '',

      ]);



      curRowVT++;



    });



    // Cộng nhóm cuối



    pushGroupTotal(prevGroup);



    // Dòng trống



    aoaVT.push(Array(VT_COLS).fill('')); curRowVT++;



    // Tổng cộng vật tư



    const sumRow = Array(VT_COLS).fill('');



    sumRow[0] = 'TỔNG CỘNG VẬT TƯ (THEO DỰ TOÁN)';



    sumRow[6] = fmtNum(grandTotal, 0);



    aoaVT.push(sumRow);



    mergesVT.push({s:{r:curRowVT,c:0}, e:{r:curRowVT,c:5}});



    curRowVT++;



    // Ghi chú cuối



    const noteVT1 = Array(VT_COLS).fill('');



    noteVT1[0] = '* Cột "KL Cần Mua" đã cộng thêm 5% dự phòng hao hụt vận chuyển';



    aoaVT.push(noteVT1); mergesVT.push({s:{r:curRowVT,c:0}, e:{r:curRowVT,c:VT_COLS-1}}); curRowVT++;



    const noteVT2 = Array(VT_COLS).fill('');



    noteVT2[0] = '* Cột "Nhà Cung Cấp" để trống cho nhân viên điền khi đặt hàng';



    aoaVT.push(noteVT2); mergesVT.push({s:{r:curRowVT,c:0}, e:{r:curRowVT,c:VT_COLS-1}}); curRowVT++;



    const noteVT3 = Array(VT_COLS).fill('');



    noteVT3[0] = `* Ngày lập: ${project.date ? new Date(project.date).toLocaleDateString('vi-VN') : new Date().toLocaleDateString('vi-VN')}`;



    aoaVT.push(noteVT3); mergesVT.push({s:{r:curRowVT,c:0}, e:{r:curRowVT,c:VT_COLS-1}}); curRowVT++;



    // Khối chữ ký cuối bảng

    aoaVT.push(Array(VT_COLS).fill('')); curRowVT++;

    const signRow = Array(VT_COLS).fill('');
    signRow[1] = 'Người lập bảng';
    signRow[6] = 'TP. HCM ngày ...... tháng ...... năm 2026';
    aoaVT.push(signRow);
    mergesVT.push({ s: { r: curRowVT, c: 1 }, e: { r: curRowVT, c: 5 } });
    mergesVT.push({ s: { r: curRowVT, c: 6 }, e: { r: curRowVT, c: 9 } });
    curRowVT++;

    const directorRow = Array(VT_COLS).fill('');
    directorRow[6] = 'Giám đốc';
    aoaVT.push(directorRow);
    mergesVT.push({ s: { r: curRowVT, c: 6 }, e: { r: curRowVT, c: 9 } });
    curRowVT++;

    aoaVT.push(Array(VT_COLS).fill(''));
    curRowVT++;

    const nameRow = Array(VT_COLS).fill('');
    nameRow[6] = 'VŨ THỊ KIM CHÚC';
    aoaVT.push(nameRow);
    mergesVT.push({ s: { r: curRowVT, c: 6 }, e: { r: curRowVT, c: 9 } });
    curRowVT++;

    // ── Tạo sheet ────────────────────────────────────────────



    wsVT = XLSX.utils.aoa_to_sheet(aoaVT);



    wsVT['!merges'] = mergesVT;



    wsVT['!cols'] = [

      { wch: 6  },  // STT

      { wch: 32 },  // Tên vật tư



      { wch: 6  },  // ĐVT



      { wch: 11 },  // KL tính toán



      { wch: 13 },  // KL cần mua (+5%)



      { wch: 12 },  // Đơn giá



      { wch: 13 },  // Thành tiền



      { wch: 20 },  // Phòng sử dụng



      { wch: 16 },  // Nhà cung cấp



      { wch: 20 },  // Ghi chú



    ];  // Tổng ≈ 148 ký tự → vừa A4 ngang



    applyPageSetup(wsVT, 9);



    applySheetStyles(wsVT, 8, 'vt');

    applyBoldSectionRows(wsVT, 7);



    XLSX.utils.book_append_sheet(wb, wsVT, "Vật Tư Cần Mua");



  })();



  // ==========================================================



  



  



  // Thiết lập dòng lặp lại ở đầu trang khi in (Print Titles) cho từng sheet
  wb.Workbook = wb.Workbook || {};
  wb.Workbook.Names = wb.Workbook.Names || [];

  // Sheet 1: Tổng hợp (Lặp lại dòng 9)
  wb.Workbook.Names.push({
    Name: '_xlnm.Print_Titles',
    Ref: "'Tổng hợp'!$9:$9",
    Sheet: 0
  });

  // Sheet chi tiết các phòng (Lặp lại dòng 9 và 10)
  roomSheets.forEach((rs, idx) => {
    wb.Workbook.Names.push({
      Name: '_xlnm.Print_Titles',
      Ref: `'${rs.finalSheetName}'!$9:$10`,
      Sheet: 1 + idx
    });
  });

  // Sheet Vật Tư Cần Mua (Lặp lại dòng 9)
  if (wsVT) {
    wb.Workbook.Names.push({
      Name: '_xlnm.Print_Titles',
      Ref: "'Vật Tư Cần Mua'!$9:$9",
      Sheet: 1 + roomSheets.length
    });
  }

  return { wb, wsSum, roomSheets, wsVT };



}

function exportExcel() {

  const project = DB.get(state.currentProjectId);

  if (!project) return;

  const wbData = generateWorkbook(project);

  if (!wbData) return;

  const dateStr  = new Date().toLocaleDateString('vi-VN').replace(/\//g, '-');

  const fileName = `BaoGia_${project.name.replace(/\s+/g, '_')}_${dateStr}.xlsx`;

  xlsxWrite(wbData.wb, fileName);

}



// Trạng thái tab preview



let _pvTab = 'summary';



function switchPreviewTab(tab) {



  _pvTab = tab;



  const isSummary = tab === 'summary';



  // Cập nhật style tab button



  document.getElementById('pv-tab-summary').style.background = isSummary ? 'var(--brand-gold)' : 'var(--bg-elevated)';



  document.getElementById('pv-tab-summary').style.color      = isSummary ? '#000' : 'var(--text-secondary)';



  document.getElementById('pv-tab-detail').style.background  = !isSummary ? 'var(--brand-gold)' : 'var(--bg-elevated)';



  document.getElementById('pv-tab-detail').style.color       = !isSummary ? '#000' : 'var(--text-secondary)';



  // Hiện/ẩn panel



  document.getElementById('pv-panel-summary').style.display = isSummary ? '' : 'none';



  document.getElementById('pv-panel-detail').style.display  = !isSummary ? '' : 'none';



  // Hiện/ẩn dropdown phòng



  document.getElementById('pv-room-select').style.display = !isSummary ? '' : 'none';



  openPreview();



}



// Feature #12: In bảng từ Preview modal



function printPreview() {



  // Lấy nội dung panel đang hiện



  const activePanel = _pvTab === 'summary'



    ? document.getElementById('pv-panel-summary')



    : document.getElementById('pv-panel-detail');



  if (!activePanel) return;



  const project = DB.get(state.currentProjectId);



  const title    = document.getElementById('pv-doc-title')?.textContent || 'BẢNG DỰ TOÁN';



  const projName = project?.name || '';



  const company  = project?.company || '';



  const dateStr  = project?.date ? new Date(project.date).toLocaleDateString('vi-VN') : '';



  // Lấy CSS của trang hiện tại để dùng lại trong cửa sổ in



  const styles = Array.from(document.styleSheets).map(ss => {



    try { return Array.from(ss.cssRules).map(r => r.cssText).join('\n'); }



    catch { return ''; }



  }).join('\n');



  const w = window.open('', '_blank', 'width=900,height=700');



  w.document.write(`<!DOCTYPE html><html><head>



    <meta charset="UTF-8">



    <title>${title} — ${projName}</title>



    <style>



      ${styles}



      body { background:#fff !important; color:#111 !important; padding:20px; font-family:Arial,sans-serif; }



      .pv-head { margin-bottom:16px; }



      table { width:100%; border-collapse:collapse; font-size:12px; }



      th, td { border:1px solid #ccc; padding:5px 8px; }



      th { background:#1a1a2e; color:#fff; }



      .pv-room-hdr td {
        background:#fff !important;
        color:#000 !important;
        font-weight:800;
        border-top:1px solid #000 !important;
        border-bottom:1px solid #000 !important;
        border-left:none !important;
        border-right:none !important;
      }
      .pv-room-hdr td:first-child {
        border-left:1px solid #000 !important;
      }
      .pv-room-hdr td:last-child {
        border-right:1px solid #000 !important;
      }



      .pv-subtotal td { background:#f5f0e0; font-weight:700; }



      @media print { button { display:none !important; } body { padding:0; } }



    </style>



  </head><body>



    <div class="pv-head">



      <h2 style="margin:0 0 4px;font-size:16px;">${company}</h2>



      <h3 style="margin:0 0 8px;font-size:14px;">${title}</h3>



      <p style="margin:0;font-size:12px;color:#555;">${projName} ${dateStr ? '· Ngày: '+dateStr : ''}</p>



    </div>



    ${activePanel.querySelector('table')?.outerHTML || activePanel.innerHTML}



  </body></html>`);



  w.document.close();



  setTimeout(() => { w.focus(); w.print(); }, 400);



}



function openPreview() {



  const project = DB.get(state.currentProjectId);



  if (!project) return;



  // Điền thông tin project



  if (document.getElementById('pv-subtitle')) {



    document.getElementById('pv-subtitle').textContent = project.subtitle || project.name || '';



  }



  if (document.getElementById('pv-project-name')) {



    document.getElementById('pv-project-name').textContent = `CÔNG TRÌNH: ${project.name || ''}`.toUpperCase();



  }



  if (document.getElementById('pv-sender-name')) {



    document.getElementById('pv-sender-name').textContent = project.sender || '';



  }



  if (document.getElementById('pv-sender-company')) {



    document.getElementById('pv-sender-company').textContent = project.company || '';



  }



  if (document.getElementById('pv-sender-addr')) {



    document.getElementById('pv-sender-addr').textContent = project.companyAddr || '';



  }



  if (document.getElementById('pv-client-name')) {



    document.getElementById('pv-client-name').textContent = project.recipient || project.client || '';



  }



  if (document.getElementById('pv-client-company')) {



    document.getElementById('pv-client-company').textContent = project.clientCo || '';



  }



  if (document.getElementById('pv-client-addr')) {



    document.getElementById('pv-client-addr').textContent = project.clientAddr || project.address || '';



  }



  const allRooms = project.rooms || [];



  // Cập nhật dropdown phòng trong preview



  const pvRoomSel = document.getElementById('pv-room-select');



  if (pvRoomSel) {



    const prevPvRoom = pvRoomSel.value;



    pvRoomSel.innerHTML = '<option value="all">File tổng</option>' +



      allRooms.map(r => `<option value="${r.id}">${r.name}</option>`).join('');



    if (Array.from(pvRoomSel.options).some(o => o.value === prevPvRoom)) {



      pvRoomSel.value = prevPvRoom;



    }



  }



  // ── Tab Tổng Hợp ──────────────────────────────



  if (_pvTab === 'summary') {



    document.getElementById('pv-doc-title').textContent = 'BẢNG TỔNG HỢP KHỐI LƯỢNG';



    if (document.getElementById('pv-subtitle'))      document.getElementById('pv-subtitle').textContent      = project.subtitle || project.name || '';



    if (document.getElementById('pv-project-name')) document.getElementById('pv-project-name').textContent = `CÔNG TRÌNH: ${project.name || ''}`.toUpperCase();



    _renderPreviewSummary(project, allRooms);



  } else {



    // ── Tab Chi Tiết ──────────────────────────────



    const selRoomId = pvRoomSel ? pvRoomSel.value : 'all';



    const filteredRooms = selRoomId === 'all' ? allRooms : allRooms.filter(r => r.id === selRoomId);



    const titleRoom = selRoomId === 'all' ? '' : ` — ${(allRooms.find(r=>r.id===selRoomId)?.name||'').toUpperCase()}`;



    document.getElementById('pv-doc-title').textContent = selRoomId === 'all' ? 'BẢNG KHỐI LƯỢNG' : 'BẢNG KHỐI LƯỢNG - ' + (allRooms.find(r=>r.id===selRoomId)?.name||'').toUpperCase();



    if (document.getElementById('pv-subtitle'))      document.getElementById('pv-subtitle').textContent      = project.subtitle || project.name || '';



    if (document.getElementById('pv-project-name')) document.getElementById('pv-project-name').textContent = `CÔNG TRÌNH: ${project.name || ''}`.toUpperCase();



    _renderPreviewDetail(project, filteredRooms, selRoomId === 'all');



  }



  document.getElementById('modal-preview').classList.add('open');



  reIcons();



}



// Render tab Tổng Hợp (có cột từng phòng)



function _renderPreviewSummary(project, rooms) {



  const summaryItems = CALC.projectSummary(project);



  // Rebuild thead động mỗi lần (tránh bug sau lần gọi thứ 2+)



  const sumTable = document.getElementById('pv-sum-table');



  if (sumTable) {



    const roomThCols = rooms.map(r =>



      `<th style="width:90px;text-align:right;font-size:11px;color:var(--brand-blue-light);">${r.name.length > 12 ? r.name.substring(0,12)+'…' : r.name}</th>`



    ).join('');



    sumTable.querySelector('thead').innerHTML = `<tr class="pv-head-row-1">



      <th style="width:36px;">STT</th>



      <th>HẠNG MỤC</th>



      <th style="width:48px;">Đ.VỊ</th>



      ${roomThCols}



      <th style="width:100px;">TỔNG SL</th>



      <th style="width:110px;">ĐƠN GIÁ (đ)</th>



      <th style="width:130px;">THÀNH TIỀN (đ)</th>



      <th style="width:150px;">GHI CHÚ</th>



    </tr>`;



  }



  let sumHtml = '';

  const groups = { construction: [], furniture: [], elec: [], sanitary: [] };

  summaryItems.forEach(item => {

    groups[categorizeSummaryItem(item)].push(item);

  });

  const catRomNums = ['I', 'II', 'III', 'IV', 'V', 'VI'];

  let catRomIdx = 0;

  const categoriesConfig = [

    { key: 'construction', label: 'XÂY DỰNG CƠ BẢN (bao gồm tất cả các hạng mục sàn tường trần)' },

    { key: 'furniture',    label: 'THIẾT BỊ NỘI THẤT' },

    { key: 'elec',         label: 'THIẾT BỊ ĐIỆN' },

    { key: 'sanitary',     label: 'THIẾT BỊ VỆ SINH' }

  ];

  categoriesConfig.forEach(catConf => {

    const itemsInCat = groups[catConf.key];

    if (itemsInCat && itemsInCat.length > 0) {

      const rom = catRomNums[catRomIdx++];

      sumHtml += `<tr class="pv-room-hdr"><td style="text-align:center;font-weight:700;">${rom}</td><td style="font-weight:700;text-align:left;">${catConf.label.toUpperCase()}</td>${Array(rooms.length + 5).fill('<td></td>').join('')}</tr>`;

      let itemStt = 1;

      itemsInCat.forEach(item => {

        const roomQtyCells = rooms.map(r => {

          const calc = CALC.room(r);

          const match = calc.items.find(it => it.label === item.label && it.unit === item.unit);

          const q = match ? match.qty : 0;

          return `<td style="text-align:right;font-size:12px;padding:4px 8px;">${q > 0 ? fmt(q) : '—'}</td>`;

        }).join('');

        grandTotal += item.total || 0;

        sumHtml += `<tr class="pv-item">

          <td class="pv-stt">${itemStt++}</td>

          <td style="padding-left:15px !important;">${item.label}</td>

          <td class="pv-center">${item.unit}</td>

          ${roomQtyCells}

          <td class="pv-num" style="font-weight:700;color:var(--brand-blue-light);">${fmt(item.qty)}</td>

          <td class="pv-num">${item.price ? fmt(item.price, 0) : ''}</td>

          <td class="pv-num" style="font-weight:700;">${item.total ? fmt(item.total, 0) : ''}</td>

          <td class="pv-note">${item.note || ''}</td>

        </tr>`;

      });

    }

  });

  // Chi phí khác

  const totalFloor = rooms.reduce((s, r) => s + (+r.D||0)/1000 * (+r.R||0)/1000, 0);

  const OC_TEMPLATE = [

    { key:'transport',   label:'Phí vận chuyển',   unit:'gói', autoQty:false, defaultQty:1 },

    { key:'debris',      label:'Phí tháo gỡ trần, vận chuyển + đổ xà bần, bao đựng rác', unit:'m²', autoQty:true },

    { key:'scaffold',    label:'Phí thuê giàn giáo', unit:'m²',  autoQty:true },

    { key:'design',      label:'Phí thiết kế',      unit:'m²',   autoQty:true },

    { key:'supervision', label:'Phí giám sát ngoại tỉnh', unit:'lần', autoQty:false, defaultQty:1 },

  ];

  const oc = project.otherCosts || {};

  let hasOc = false, ocStt = 1;

  OC_TEMPLATE.forEach(tmpl => {

    const saved = oc[tmpl.key] || {};

    const qty = tmpl.autoQty ? totalFloor : (saved.qty != null ? saved.qty : tmpl.defaultQty);

    const price = saved.price || 0;

    const total = qty * price;

    if (price > 0 || qty > 0) {

      if (!hasOc) {

        const rom = catRomNums[catRomIdx++];

        sumHtml += `<tr class="pv-room-hdr"><td style="text-align:center;font-weight:700;">${rom}</td><td style="font-weight:700;text-align:left;">CHI PHÍ KHÁC</td>${Array(rooms.length + 5).fill('<td></td>').join('')}</tr>`;

        hasOc = true;

      }

      grandTotal += total;

      const blankCols = rooms.map(() => '<td>—</td>').join('');

      sumHtml += `<tr class="pv-item">

        <td class="pv-stt">${ocStt++}</td>

        <td>${tmpl.label}</td>

        <td class="pv-center">${tmpl.unit}</td>

        ${blankCols}

        <td class="pv-num">${fmt(qty)}</td>

        <td class="pv-num">${price ? fmt(price, 0) : ''}</td>

        <td class="pv-num">${total ? fmt(total, 0) : ''}</td>

        <td class="pv-note">${saved.note || ''}</td>

      </tr>`;

    }

  });

  document.getElementById('pv-sum-tbody').innerHTML = sumHtml;



  document.getElementById('pv-grand-total-label').textContent = 'TỔNG CỘNG';



  document.getElementById('pv-grand-total-value').textContent =



    grandTotal > 0 ? fmt(grandTotal, 0) + ' đ' : '(Chưa nhập đơn giá)';



}



// Render tab Chi Tiết (lọc theo phòng)



function _renderPreviewDetail(project, filteredRooms, showOtherCosts = false) {



  const romanNums = ['I','II','III','IV','V','VI','VII','VIII','IX','X',



                     'XI','XII','XIII','XIV','XV','XVI','XVII','XVIII','XIX','XX'];



  const allRooms = project.rooms || [];



  let html = '';



  let stt = 1;



  let grandTotal = 0;



  filteredRooms.forEach((room) => {

    const globalIdx = allRooms.indexOf(room);

    const calc  = CALC.room(room);

    const D = (+room.D || 0) / 1000;

    const R = (+room.R || 0) / 1000;

    const perimStr = (2*(D+R)).toFixed(2).replace('.',',');

    const roman = 'I';

    let roomTotal = 0;

    stt = 1; // reset STT mỗi phòng

    let pvSubRomIdx = 1;

    html += `<tr class="pv-room-title-row" style="background:rgba(255,255,255,0.02);"><td colspan="10" style="text-align:center;font-weight:800;font-size:13px;color:var(--brand-blue-light);padding:6px 0;">BẢNG KHỐI LƯỢNG - ${room.name.toUpperCase()}</td></tr>`;

    html += `<tr class="pv-room-hdr"><td class="pv-stt" style="text-align:center;font-weight:700;">${roman}</td><td style="font-weight:700;text-align:left;">XÂY DỰNG CƠ BẢN — ${room.name.toUpperCase()}</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>`;

    html += `<tr class="pv-room-info"><td colspan="10">

      📏 ${fmtMM(room.D)} × ${fmtMM(room.R)} × cao ${fmtMM(room.H)} mm

      &nbsp;|&nbsp; <strong>Chu vi: ${perimStr} m</strong>

      ${room.roomNote ? `&nbsp;|&nbsp; ${room.roomNote}` : ''}

    </td></tr>`;

    calc.items.forEach(item => {

      roomTotal += item.total || 0;

      grandTotal += item.total || 0;

      if (item.surface === 'elecHeader') {

        stt = 1;

        const rom = romanNums[pvSubRomIdx++] || pvSubRomIdx;

        html += `<tr class="pv-room-hdr"><td class="pv-stt" style="text-align:center;font-weight:700;">${rom}</td><td style="font-weight:700;text-align:left;">THIẾT BỊ ĐIỆN</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>`;

        return;

      }

      if (item.surface === 'noteHeader') {

        stt = 1;

        const rom = romanNums[pvSubRomIdx++] || pvSubRomIdx;

        html += `<tr class="pv-room-hdr"><td class="pv-stt" style="text-align:center;font-weight:700;">${rom}</td><td style="font-weight:700;text-align:left;">CHI TIẾT TỪ GHI CHÚ</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>`;

        return;

      }

      if (item.surface === 'custom') {

        const ci = (room.customItems||[]).find(c => c.id === item.itemId);

        if (ci) {

          const labelTrim = (ci.label||'').trim();

          const isSubHdr  = labelTrim.length > 1 && labelTrim === labelTrim.toUpperCase();

          if (isSubHdr) {

            stt = 1; // reset STT

            const rom = romanNums[pvSubRomIdx++] || pvSubRomIdx;

            html += `<tr class="pv-room-hdr"><td class="pv-stt" style="text-align:center;font-weight:700;">${rom}</td><td style="font-weight:700;text-align:left;">${ci.label}</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>`;

            return;

          }

        }

      }

      const noStt = false;

      const isManual = item.surface === 'elecManual';

      const rowClass = item.surface === 'perimeter' ? 'pv-perim' : 'pv-item';

      const qtyDisplay = isManual && item.qty === 0 ? '<em style="color:var(--brand-gold)">tự điền</em>' : (item.formula || fmt(item.qty));

      html += `<tr class="${rowClass}">

        <td class="pv-stt">${noStt ? '' : stt++}</td>

        <td style="${isManual ? 'color:var(--brand-gold);font-style:italic;' : ''} padding-left:15px !important;">${item.label}</td>

        <td class="pv-num">${item.dai  ? fmtMM(item.dai)  : ''}</td>

        <td class="pv-num">${item.rong ? fmtMM(item.rong) : ''}</td>

        <td class="pv-num">${item.cao  ? fmtMM(item.cao)  : ''}</td>

        <td class="pv-center">${item.unit}</td>

        <td class="pv-num" style="white-space:normal;font-size:10.5px;">${qtyDisplay}</td>

        <td class="pv-num">${item.price ? fmt(item.price, 0) : ''}</td>

        <td class="pv-num">${item.total ? fmt(item.total, 0) : ''}</td>

        <td class="pv-note">${item.note || ''}</td>

      </tr>`;

    });

    // ── Ghi chú Mộc / Nước / Chống thấm vào preview chi tiết phòng ──
    [
      { text: room.noteWoodwork,   label: 'THIẾT BỊ NỘI THẤT' },
      { text: room.notePlumbing,   label: 'PHẦN NƯỚC' },
      { text: room.noteWaterproof, label: 'CHỐNG THẤM' },
    ].forEach(({ text, label }) => {
      if (!text || !text.trim()) return;

      const rom = romanNums[pvSubRomIdx++] || pvSubRomIdx;
      html += `<tr class="pv-room-hdr">
        <td class="pv-stt" style="text-align:center;font-weight:700;">${rom}</td>
        <td style="font-weight:700;text-align:left;">${label}</td>
        <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
      </tr>`;

      stt = 1;
      const noteLines = text.split('\n').map(l => l.trim()).filter(l => l);
      noteLines.forEach((line, li) => {
        html += `<tr class="pv-item">
          <td class="pv-stt">${stt++}</td>
          <td colspan="4" style="padding-left:15px !important;">${line}</td>
          <td class="pv-center">cái</td>
          <td class="pv-num">1</td>
          <td class="pv-num"></td>
          <td class="pv-num"></td>
          <td class="pv-note"></td>
        </tr>`;
      });
    });

    if (roomTotal > 0) {

      html += `<tr class="pv-subtotal">

        <td colspan="8" style="text-align:right;padding-right:10px;">Cộng ${room.name}:</td>

        <td class="pv-num">${fmt(roomTotal, 0)}</td>

        <td></td>

      </tr>`;

    }

  });



  // Chi phí khác (chỉ khi xem tất cả phòng — dùng tham số showOtherCosts)



  if (showOtherCosts) {



    const totalFloor = allRooms.reduce((s, r) => s + (+r.D||0)/1000 * (+r.R||0)/1000, 0);



    const OC_TEMPLATE = [



      { key:'transport',   label:'Phí vận chuyển',   unit:'gói', autoQty:false, defaultQty:1 },



      { key:'debris',      label:'Phí tháo gỡ trần, vận chuyển + đổ xà bần, bao đựng rác', unit:'m²', autoQty:true },



      { key:'scaffold',    label:'Phí thuê giàn giáo', unit:'m²',  autoQty:true },



      { key:'design',      label:'Phí thiết kế',      unit:'m²',   autoQty:true },



      { key:'supervision', label:'Phí giám sát ngoại tỉnh', unit:'lần', autoQty:false, defaultQty:1 },



    ];



    const oc = project.otherCosts || {};



    let hasOc = false, ocStt2 = 1;



    OC_TEMPLATE.forEach(tmpl => {



      const saved = oc[tmpl.key] || {};



      const qty = tmpl.autoQty ? totalFloor : (saved.qty != null ? saved.qty : tmpl.defaultQty);



      const price = saved.price || 0;



      const total = qty * price;



      if (price > 0 || qty > 0) {



        if (!hasOc) { html += `<tr class="pv-room-hdr"><td class="pv-stt" style="text-align:center;font-weight:700;"></td><td style="font-weight:700;text-align:left;">CHI PHÍ KHÁC</td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>`; hasOc = true; }



        grandTotal += total;



        html += `<tr class="pv-item">



          <td class="pv-stt">${ocStt2++}</td>



          <td>${tmpl.label}</td>



          <td class="pv-num"></td><td class="pv-num"></td><td class="pv-num"></td>



          <td class="pv-center">${tmpl.unit}</td>



          <td class="pv-num">${fmt(qty)}</td>



          <td class="pv-num">${price ? fmt(price, 0) : ''}</td>



          <td class="pv-num">${total ? fmt(total, 0) : ''}</td>



          <td class="pv-note">${saved.note || ''}</td>



        </tr>`;



      }



    });



  }



  document.getElementById('pv-tbody').innerHTML = html;



  document.getElementById('pv-grand-total-label').textContent = 'TỔNG CỘNG';



  document.getElementById('pv-grand-total-value').textContent =



    grandTotal > 0 ? fmt(grandTotal, 0) + ' đ' : '(Chưa nhập đơn giá)';



}



// =============================================



// 16. KHỞI TẠO



// =============================================



function init() {



  // --- Buttons dự án ---



  document.getElementById('btn-new-project').addEventListener('click', () => openProjectModal());



  document.getElementById('btn-new-project-empty').addEventListener('click', () => openProjectModal());



  document.getElementById('btn-close-project-modal').addEventListener('click', closeProjectModal);



  document.getElementById('btn-cancel-project').addEventListener('click', closeProjectModal);



  document.getElementById('btn-save-project').addEventListener('click', saveProject);



  document.getElementById('btn-edit-project').addEventListener('click', () => openProjectModal(DB.get(state.currentProjectId)));



  document.getElementById('btn-delete-project').addEventListener('click', deleteCurrentProject);



  // --- Buttons phòng ---



  document.getElementById('btn-add-room').addEventListener('click', () => openRoomModal());



  document.getElementById('btn-close-room-modal').addEventListener('click', closeRoomModal);



  document.getElementById('btn-cancel-room').addEventListener('click', closeRoomModal);



  document.getElementById('btn-save-room').addEventListener('click', saveRoom);



  // --- Quick buttons tên phòng ---



  document.querySelectorAll('.quick-btn').forEach(btn => {



    btn.addEventListener('click', () => {



      document.getElementById('room-name').value = btn.dataset.name;



      document.getElementById('room-name').focus();



    });



  });



  // --- Live preview khi nhập kích thước ---



  ['room-D','room-R','room-H','room-doors','room-door-w','room-door-h','room-windows','room-window-w','room-window-h']



    .forEach(id => document.getElementById(id).addEventListener('input', () => { updatePreview(); updateZ2HDisplay(); }));



  // --- Zone toggle ---



  document.getElementById('wall-zone-toggle').addEventListener('change', function() {



    state.wallZoneMode = this.checked;



    document.getElementById('wall-single-mode').style.display = this.checked ? 'none' : '';



    document.getElementById('wall-zone-mode').style.display   = this.checked ? '' : 'none';



    updatePreview();



  });



  document.getElementById('wall-z1-h').addEventListener('input', () => { updateZ2HDisplay(); updatePreview(); });



  // --- Export Excel ---



  document.getElementById('btn-export-excel')?.addEventListener('click', exportExcel);



  document.getElementById('btn-export-excel-2')?.addEventListener('click', exportExcel);



  // --- Preview ---



  document.getElementById('btn-preview-excel')?.addEventListener('click', openPreview);



  document.getElementById('btn-preview-excel-2')?.addEventListener('click', openPreview);



  document.getElementById('btn-close-preview').addEventListener('click', () =>



    document.getElementById('modal-preview').classList.remove('open'));



  document.getElementById('btn-export-from-preview').addEventListener('click', () => {



    document.getElementById('modal-preview').classList.remove('open');



    exportExcel();



  });



  document.getElementById('modal-preview').addEventListener('click', e => {



    if (e.target === e.currentTarget) e.currentTarget.classList.remove('open');



  });



  // --- Workspace tabs ---



  document.querySelectorAll('.ws-tab').forEach(tab => {



    tab.addEventListener('click', () => {



      document.querySelectorAll('.ws-tab').forEach(t => t.classList.remove('active'));



      document.querySelectorAll('.ws-panel').forEach(p => p.classList.remove('active'));



      tab.classList.add('active');



      document.getElementById(`ws-panel-${tab.dataset.wsTab}`).classList.add('active');



    });



  });



  // --- Đóng modal khi click nền ---



  ['modal-project', 'modal-room'].forEach(id => {



    document.getElementById(id).addEventListener('click', e => {



      if (e.target === e.currentTarget) {



        if (id === 'modal-room') {



          closeRoomModal();



        } else {



          e.currentTarget.classList.remove('open');



        }



      }



    });



  });



  // --- Phím tắt ---



  document.addEventListener('keydown', e => {



    if (e.key === 'Escape') {



      closeProjectModal();



      closeRoomModal();



    }



    if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {



      const roomModal = document.getElementById('modal-room');



      const projModal = document.getElementById('modal-project');



      if (roomModal.classList.contains('open'))  saveRoom();



      if (projModal.classList.contains('open'))  saveProject();



    }



  });



  // --- Cảnh báo khi reload trang (F5) nếu có thay đổi chưa lưu ---



  window.addEventListener('beforeunload', e => {



    const hasUnsavedRoom = isRoomFormDirty();



    const hasUnsavedInline = !!document.querySelector('tr.ci-edit-row');



    if (hasUnsavedRoom || hasUnsavedInline) {



      e.preventDefault();



      e.returnValue = '';



    }



  });



  // --- Render ban đầu ---



  renderProjectList();



  // --- Tự mở dự án cuối cùng ---



  const projects = DB.all();



  if (projects.length > 0) {



    openProject(projects[projects.length - 1].id);



  }



}



// =============================================



// 17. TÀI LIỆU — ẢNH HIỆN TRẠNG & FILE THIẾT KẾ



// =============================================



// Nén ảnh về tối đa 1200px, JPEG 0.75 chất lượng



function compressImage(file, maxW = 1200) {



  return new Promise(resolve => {



    const reader = new FileReader();



    reader.onload = e => {



      const img = new Image();



      img.onload = () => {



        let w = img.width, h = img.height;



        if (w > maxW) { h = Math.round(h * maxW / w); w = maxW; }



        const canvas = document.createElement('canvas');



        canvas.width = w; canvas.height = h;



        canvas.getContext('2d').drawImage(img, 0, 0, w, h);



        resolve({ name: file.name, data: canvas.toDataURL('image/jpeg', 0.75) });



      };



      img.src = e.target.result;



    };



    reader.readAsDataURL(file);



  });



}



function fileIcon(name) {



  const ext = name.split('.').pop().toLowerCase();



  const map = {



    pdf: '📄', dwg: '📐', dxf: '📐', skp: '🏠',



    '3ds': '🧊', fbx: '🧊', obj: '🧊',



    png: '🖼️', jpg: '🖼️', jpeg: '🖼️',



    zip: '🗜️', rar: '🗜️',



  };



  return map[ext] || '📁';



}



function fmtBytes(b) {



  if (b < 1024) return `${b} B`;



  if (b < 1048576) return `${(b/1024).toFixed(0)} KB`;



  return `${(b/1048576).toFixed(1)} MB`;



}



// Render ảnh hiện trạng



function renderSitePhotos() {



  const project = DB.get(state.currentProjectId);



  if (!project) return;



  const photos = project.sitePhotos || [];



  const grid = document.getElementById('site-photos-grid');



  const zone = document.getElementById('site-photos-dropzone');



  if (photos.length === 0) {



    grid.innerHTML = '';



    zone.classList.remove('has-files');



    return;



  }



  zone.classList.add('has-files');



  grid.innerHTML = photos.map((p, i) => `



    <div class="photo-thumb" onclick="openLightbox('${i}','site')">



      <img src="${p.data}" alt="${p.name}" loading="lazy">



      <div class="photo-thumb-overlay">



        <button class="photo-thumb-del" onclick="event.stopPropagation();deletePhoto(${i},'site')">×</button>



      </div>



      <div class="photo-thumb-name">${p.name}</div>



    </div>`).join('');



}



// Render file thiết kế



function renderDesignFiles() {



  const project = DB.get(state.currentProjectId);



  if (!project) return;



  const files = project.designFiles || [];



  const list = document.getElementById('design-files-list');



  const zone = document.getElementById('design-files-dropzone');



  if (files.length === 0) {



    list.innerHTML = '';



    zone.classList.remove('has-files');



    return;



  }



  zone.classList.add('has-files');



  list.innerHTML = files.map((f, i) => {



    const isImg = /\.(png|jpg|jpeg)$/i.test(f.name) && f.data;



    return `



    <div class="file-item">



      <div class="file-icon">${isImg ? `<img src="${f.data}" style="width:32px;height:32px;object-fit:cover;border-radius:4px;">` : fileIcon(f.name)}</div>



      <div class="file-info">



        <div class="file-name">${f.name}</div>



        <div class="file-meta">${fmtBytes(f.size || 0)} • ${f.type || 'File'}</div>



      </div>



      ${f.data ? `<button class="file-del" title="Xem" onclick="openLightbox(${i},'design')">🔍</button>` : ''}



      <button class="file-del" title="Xóa" onclick="deletePhoto(${i},'design')">🗑️</button>



    </div>`}).join('');



}



function deletePhoto(idx, type) {



  const project = DB.get(state.currentProjectId);



  if (!project) return;



  const key = type === 'site' ? 'sitePhotos' : 'designFiles';



  const arr = [...(project[key] || [])];



  arr.splice(idx, 1);



  DB.update(state.currentProjectId, { [key]: arr });



  type === 'site' ? renderSitePhotos() : renderDesignFiles();



}



function openLightbox(idx, type) {



  const project = DB.get(state.currentProjectId);



  if (!project) return;



  const key = type === 'site' ? 'sitePhotos' : 'designFiles';



  const item = (project[key] || [])[idx];



  if (!item?.data) return;



  const isImg = item.type?.startsWith('image/') || /\.(png|jpg|jpeg|gif|webp)$/i.test(item.name);



  if (isImg) {



    // Hiện lightbox ảnh



    const lb = document.createElement('div');



    lb.className = 'lightbox';



    lb.innerHTML = `<span class="lightbox-close">✕</span><img src="${item.data}" alt="${item.name}">`;



    lb.addEventListener('click', () => lb.remove());



    document.body.appendChild(lb);



  } else {



    // File không phải ảnh: tạo link tải về



    const a = document.createElement('a');



    a.href = item.data;



    a.download = item.name;



    a.click();



  }



}



// Xử lý upload ảnh hiện trạng



async function handleSitePhotos(files) {



  const project = DB.get(state.currentProjectId);



  if (!project) return;



  const existing = project.sitePhotos || [];



  const newPhotos = [];



  let skipped = 0;



  for (const f of files) {



    if (!f.type.startsWith('image/')) continue;



    if (f.size > 15 * 1024 * 1024) { skipped++; continue; }



    try {



      const compressed = await compressImage(f);



      newPhotos.push(compressed);



    } catch (e) { console.warn('Compress failed:', f.name); }



  }



  if (skipped > 0) alert(`${skipped} ảnh bị bỏ qua (quá 15MB hoặc không phải ảnh)`);



  DB.update(state.currentProjectId, { sitePhotos: [...existing, ...newPhotos] });



  renderSitePhotos();



}



// Xử lý upload file thiết kế



async function handleDesignFiles(files) {



  const project = DB.get(state.currentProjectId);



  if (!project) return;



  const existing = project.designFiles || [];



  const newFiles = [];



  for (const f of files) {



    const isImg = f.type.startsWith('image/');



    if (isImg && f.size < 10 * 1024 * 1024) {



      // Ảnh: nén trước khi lưu



      const compressed = await compressImage(f, 1600);



      newFiles.push({ name: f.name, size: f.size, type: f.type, data: compressed.data });



    } else if (!isImg && f.size < 5 * 1024 * 1024) {



      // File nhỏ (< 5MB, PDF/DWG...): lưu base64 để xem/tải lại



      const data = await new Promise(resolve => {



        const reader = new FileReader();



        reader.onload = e => resolve(e.target.result);



        reader.readAsDataURL(f);



      });



      newFiles.push({ name: f.name, size: f.size, type: f.type, data });



    } else {



      // File quá lớn (> 5MB): chỉ lưu metadata, không thể xem lại



      newFiles.push({ name: f.name, size: f.size, type: f.type, note: 'File > 5MB — không lưu được nội dung' });



    }



  }



  DB.update(state.currentProjectId, { designFiles: [...existing, ...newFiles] });



  renderDesignFiles();



}



// Gọi render khi chuyển sang tab media



function renderMediaPanel() {



  renderSitePhotos();



  renderDesignFiles();



}



// Init media listeners (gọi từ init)



function initMediaListeners() {



  // Upload ảnh hiện trạng



  const siteInput = document.getElementById('upload-site-photos');



  siteInput.addEventListener('change', e => { handleSitePhotos([...e.target.files]); siteInput.value=''; });



  // Upload file thiết kế



  const designInput = document.getElementById('upload-design-files');



  designInput.addEventListener('change', e => { handleDesignFiles([...e.target.files]); designInput.value=''; });



  // Drag & drop — site photos



  const siteZone = document.getElementById('site-photos-dropzone');



  siteZone.addEventListener('dragover', e => { e.preventDefault(); siteZone.classList.add('drag-over'); });



  siteZone.addEventListener('dragleave', () => siteZone.classList.remove('drag-over'));



  siteZone.addEventListener('drop', e => {



    e.preventDefault();



    siteZone.classList.remove('drag-over');



    handleSitePhotos([...e.dataTransfer.files]);



  });



  // Drag & drop — design files



  const designZone = document.getElementById('design-files-dropzone');



  designZone.addEventListener('dragover', e => { e.preventDefault(); designZone.classList.add('drag-over'); });



  designZone.addEventListener('dragleave', () => designZone.classList.remove('drag-over'));



  designZone.addEventListener('drop', e => {



    e.preventDefault();



    designZone.classList.remove('drag-over');



    handleDesignFiles([...e.dataTransfer.files]);



  });



  // Render khi bấm tab Tài Liệu



  document.querySelector('[data-ws-tab="media"]')?.addEventListener('click', renderMediaPanel);



}



// ============ DOM STRUCTURE FIX ============

// Fix: neu browser da auto-correct modal-footer ra ngoai modal-card

// thi di chuyen no vao dung cho truoc khi bat ky gi xay ra

(function fixModalLayout() {

  var overlay = document.getElementById('modal-room');

  if (!overlay) return;

  var card = overlay.querySelector('.modal-room-card');

  var footer = overlay.querySelector('.modal-footer');

  if (card && footer && footer.parentElement !== card) {

    // Footer bi parse ngoai card → move vao cuoi card

    card.appendChild(footer);

    console.log('[FIX] modal-footer moved into modal-card');

  }

  // Dam bao modal-overlay la flex container cho dung 1 con (modal-card)

  // Xoa tat ca direct children cua overlay khong phai modal-card

  if (card && overlay) {

    Array.from(overlay.children).forEach(function(child) {

      if (child !== card) {

        // Child bi lenh: co the la footer hoac gi do khac

        card.appendChild(child);

        console.log('[FIX] extra child moved into modal-card:', child.className);

      }

    });

  }

})();



document.addEventListener('DOMContentLoaded', () => { init(); initMediaListeners(); });



// =============================================



// 16. THƯ VIỆN VẬT TƯ



// =============================================



const VatTuDB = {



  KEY: 'bluedecor_vattu_v1',



  get()    { try { return JSON.parse(localStorage.getItem(this.KEY) || '[]'); } catch { return []; } },



  set(arr) { localStorage.setItem(this.KEY, JSON.stringify(arr)); },



  clear()  { localStorage.removeItem(this.KEY); },



};



// Trạng thái Vật Tư



let _vtPage = 1;



const _vtPageSize = 50;



let _vtImportData = [];   // raw rows từ Excel



let _vtColCount = 0;



let _vtHeaders = [];



// ── Nhận diện cột tự động ─────────────────────────────────



const VT_FIELD_ALIASES = {



  code:     ['mã','ma','code','id','sku','mã vật tư'],



  name:     ['tên','ten','name','hạng mục','vật tư','tên vật tư','ten vat tu','mô tả','mo ta','description','item','hàng'],



  unit:     ['đơn vị','đvt','unit','đv','dvt'],



  price:    ['đơn giá','gia','giá','price','don gia','đơn giá (vnđ)','giá bán','đg'],



  supplier: ['nhà cung cấp','ncc','supplier','nhà cc','nha cung cap','vendor'],



  category: ['danh mục','loại','category','nhóm','cat','danh muc','nhóm hàng'],



  note:     ['ghi chú','note','notes','ghi chu','remark','remarks','mô tả thêm'],



};



const VT_FIELD_LABELS = {



  code: 'Mã vật tư', name: 'Tên vật tư *', unit: 'Đơn vị',



  price: 'Đơn giá', supplier: 'Nhà cung cấp', category: 'Danh mục', note: 'Ghi chú',



};



function autoDetectVtCols(headers) {



  const result = {};



  headers.forEach((h, idx) => {



    const hLower = (h || '').toLowerCase().trim();



    for (const [field, aliases] of Object.entries(VT_FIELD_ALIASES)) {



      if (result[field] !== undefined) continue;



      if (aliases.some(a => hLower.includes(a) || a.includes(hLower))) {



        result[field] = idx;



      }



    }



  });



  return result;



}



// ── Chọn file ─────────────────────────────────────────────



function onVatTuFileSelect(event) {



  const file = event.target.files[0];



  if (!file) return;



  event.target.value = '';



  const reader = new FileReader();



  reader.onload = (e) => {



    const wb = XLSX.read(e.target.result, { type: 'array' });



    const ws = wb.Sheets[wb.SheetNames[0]];



    const rows = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });



    // Tìm hàng header: hàng đầu tiên có ít nhất 2 ô text



    let headerRow = 0;



    for (let i = 0; i < Math.min(10, rows.length); i++) {



      const textCells = rows[i].filter(c => typeof c === 'string' && c.trim().length > 1);



      if (textCells.length >= 2) { headerRow = i; break; }



    }



    _vtHeaders   = (rows[headerRow] || []).map(c => String(c));



    _vtImportData = rows.slice(headerRow + 1).filter(r => r.some(c => c !== '' && c != null));



    _vtColCount  = _vtHeaders.length;



    openVatTuMapModal();



  };



  reader.readAsArrayBuffer(file);



}



// ── Modal ánh xạ cột ──────────────────────────────────────



function openVatTuMapModal() {



  const autoMap = autoDetectVtCols(_vtHeaders);



  const colOptions = ['<option value="">— Bỏ qua —</option>',



    ..._vtHeaders.map((h,i) => `<option value="${i}">${String.fromCharCode(65+i) || i}: ${h}</option>`)



  ].join('');



  const fieldsHtml = Object.entries(VT_FIELD_LABELS).map(([field, label]) => {



    const selected = autoMap[field] !== undefined ? autoMap[field] : '';



    const opts = colOptions.replace(`value="${selected}"`, `value="${selected}" selected`);



    return `<div><label>${label}</label><select id="vtmap-${field}">${opts}</select></div>`;



  }).join('');



  document.getElementById('vattu-map-fields').innerHTML = fieldsHtml;



  // Preview 5 dòng



  const previewRows = _vtImportData.slice(0, 5);



  let previewHtml = '<table><thead><tr>' +



    _vtHeaders.map(h => `<th>${h}</th>`).join('') + '</tr></thead><tbody>' +



    previewRows.map(r =>



      '<tr>' + _vtHeaders.map((_,i) => `<td>${r[i] ?? ''}</td>`).join('') + '</tr>'



    ).join('') + '</tbody></table>';



  document.getElementById('vattu-preview-table').innerHTML = previewHtml;



  document.getElementById('modal-vattu-map').classList.add('active');



  if (window.lucide) lucide.createIcons();



}



// ── Xác nhận import ───────────────────────────────────────



function confirmImportVatTu() {



  const getCol = (field) => {



    const val = document.getElementById(`vtmap-${field}`)?.value;



    return val !== '' && val !== undefined ? +val : -1;



  };



  const nameCol = getCol('name');



  if (nameCol < 0) { alert('Vui lòng chọn cột "Tên vật tư"!'); return; }



  const colMap = {};



  Object.keys(VT_FIELD_LABELS).forEach(f => { colMap[f] = getCol(f); });



  const existing = VatTuDB.get();



  let added = 0, skipped = 0;



  _vtImportData.forEach((row, idx) => {



    const name = String(row[colMap.name] ?? '').trim();



    if (!name) { skipped++; return; }



    const record = {



      id:       `vt_${Date.now()}_${idx}`,



      code:     colMap.code    >= 0 ? String(row[colMap.code]     ?? '').trim() : '',



      name,



      unit:     colMap.unit    >= 0 ? String(row[colMap.unit]     ?? '').trim() : '',



      price:    colMap.price   >= 0 ? parseFloat(String(row[colMap.price] ?? '').replace(/[^0-9.]/g,'')) || 0 : 0,



      supplier: colMap.supplier>= 0 ? String(row[colMap.supplier] ?? '').trim() : '',



      category: colMap.category>= 0 ? String(row[colMap.category] ?? '').trim() : '',



      note:     colMap.note    >= 0 ? String(row[colMap.note]     ?? '').trim() : '',



    };



    existing.push(record);



    added++;



  });



  VatTuDB.set(existing);



  document.getElementById('modal-vattu-map').classList.remove('active');



  renderVatTuTable();



  refreshVatTuCategories();



  alert(`✅ Import xong: ${added} vật tư được thêm${skipped > 0 ? `, ${skipped} dòng bỏ qua (trống tên)` : ''}.`);



}



// ── Render bảng ────────────────────────────────────────────



function renderVatTuTable() {



  const search  = (document.getElementById('vattu-search')?.value || '').toLowerCase().trim();



  const catFilter = document.getElementById('vattu-filter-cat')?.value || '';



  let all = VatTuDB.get();



  // Lọc



  if (search)    all = all.filter(v => v.name.toLowerCase().includes(search) || (v.code||'').toLowerCase().includes(search) || (v.supplier||'').toLowerCase().includes(search));



  if (catFilter) all = all.filter(v => v.category === catFilter);



  const total = all.length;



  const totalPages = Math.max(1, Math.ceil(total / _vtPageSize));



  if (_vtPage > totalPages) _vtPage = 1;



  const page = all.slice((_vtPage - 1) * _vtPageSize, _vtPage * _vtPageSize);



  // Stats



  const rawAll = VatTuDB.get();



  document.getElementById('vattu-stats').textContent =



    `${rawAll.length.toLocaleString()} vật tư trong thư viện  ·  hiển thị ${total.toLocaleString()} kết quả`;



  // Empty



  document.getElementById('vattu-empty').style.display      = rawAll.length === 0 ? 'block' : 'none';



  document.getElementById('vattu-table-wrap').style.display = rawAll.length === 0 ? 'none'  : '';



  // Rows



  const tbody = document.getElementById('vattu-tbody');



  const offset = (_vtPage - 1) * _vtPageSize;



  tbody.innerHTML = page.map((v, i) => `



    <tr>



      <td style="color:var(--text-muted);font-size:11px;text-align:center;">${offset + i + 1}</td>



      <td class="td-code">${v.code || '—'}</td>



      <td style="font-weight:500;">${v.name}</td>



      <td style="text-align:center;color:var(--text-secondary);">${v.unit || ''}</td>



      <td class="td-price">${v.price ? v.price.toLocaleString('vi-VN') + ' đ' : '—'}</td>



      <td class="td-supplier">${v.supplier || '—'}</td>



      <td><span class="td-cat">${v.category || ''}</span></td>



      <td style="font-size:12px;color:var(--text-muted);">${v.note || ''}</td>



      <td>



        <div class="td-actions">



          <button onclick="deleteVatTu('${v.id}')" title="Xóa">



            <i data-lucide="trash-2" style="width:13px;height:13px;"></i>



          </button>



        </div>



      </td>



    </tr>`).join('');



  // Pagination



  const pg = document.getElementById('vattu-pagination');



  if (totalPages <= 1) { pg.innerHTML = ''; } else {



    let pgHtml = '';



    for (let p = 1; p <= totalPages; p++) {



      if (totalPages > 10 && p > 3 && p < totalPages - 2 && Math.abs(p - _vtPage) > 2) {



        if (p === 4) pgHtml += '<span style="color:var(--text-muted)">…</span>';



        continue;



      }



      pgHtml += `<button class="vattu-page-btn${p === _vtPage ? ' active' : ''}" onclick="_vtPage=${p};renderVatTuTable()">${p}</button>`;



    }



    pg.innerHTML = `<span style="font-size:12px;color:var(--text-muted);margin-right:4px;">Trang ${_vtPage}/${totalPages}</span>${pgHtml}`;



  }



  if (window.lucide) lucide.createIcons();



}



function refreshVatTuCategories() {



  const all  = VatTuDB.get();



  const cats = [...new Set(all.map(v => v.category).filter(Boolean))].sort();



  const sel  = document.getElementById('vattu-filter-cat');



  if (!sel) return;



  const cur  = sel.value;



  sel.innerHTML = '<option value="">Tất cả danh mục</option>' +



    cats.map(c => `<option value="${c}"${c === cur ? ' selected' : ''}>${c}</option>`).join('');



}



function deleteVatTu(id) {



  if (!confirm('Xóa vật tư này?')) return;



  VatTuDB.set(VatTuDB.get().filter(v => v.id !== id));



  renderVatTuTable();



  refreshVatTuCategories();



}



function clearVatTuDB() {



  const n = VatTuDB.get().length;



  if (n === 0) { alert('Thư viện đang trống.'); return; }



  if (!confirm(`Xóa toàn bộ ${n} vật tư trong thư viện?`)) return;



  VatTuDB.clear();



  renderVatTuTable();



  refreshVatTuCategories();



}



// ── Tải file mẫu Excel ────────────────────────────────────



function exportVatTuTemplate() {



  const wb  = XLSX.utils.book_new();



  const aoa = [



    ['Mã Vật Tư', 'Tên Vật Tư', 'Đơn Vị', 'Đơn Giá', 'Nhà Cung Cấp', 'Danh Mục', 'Ghi Chú'],



    ['VT001', 'Sơn Dulux nội thất A1', 'kg', 150000, 'Dulux Vietnam', 'Sơn', ''],



    ['VT002', 'Gạch lát nền Viglacera 60x60', 'm²', 320000, 'Viglacera', 'Gạch', 'Màu kem'],



    ['VT003', 'Bóng đèn LED 12W', 'bộ', 85000, 'Điện Quang', 'Điện', ''],



    ['VT004', 'Xi măng Hà Tiên PCB40', 'bao', 125000, 'Hà Tiên', 'Vật liệu xây', '50kg/bao'],



  ];



  const ws = XLSX.utils.aoa_to_sheet(aoa);



  ws['!cols'] = [10,35,8,14,22,15,25].map(w => ({wch:w}));



  XLSX.utils.book_append_sheet(wb, ws, 'Danh Sách Vật Tư');



  xlsxWrite(wb, 'Mau_DanhSachVatTu_BluDecor.xlsx');



}



// ── Kích hoạt tab ──────────────────────────────────────────



document.querySelector('[data-ws-tab="vattu"]')?.addEventListener('click', () => {



  refreshVatTuCategories();



  renderVatTuTable();



});



