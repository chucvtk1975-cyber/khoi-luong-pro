  word-break: break-word;
}
#excel-pdf-content table td {
  padding: 3px 3px;
  border: 0.5pt solid #000;
  vertical-align: middle;
  word-break: break-word;
}
#excel-pdf-content .ep-room-hdr td {
  background: #fff !important;
  color: #000 !important;
  font-weight: 800;
  border: 0.5pt solid #000 !important;
