/* Số trang CSS */
@page {
  size: A4 landscape;
  margin: 0 !important;
}
/* ============================================
   THƯ VIỆN VẬT TƯ
   ============================================ */
.vattu-wrap {
  padding: 16px 20px;
  display: flex;
  flex-direction: column;
  height: 100%;
}
.vattu-toolbar {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 4px;
}
.vattu-search-box {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--bg-elevated);
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  padding: 0 10px;
  height: 34px;
  min-width: 220px;
}
.vattu-search-box input {
  border: none;
  background: transparent;
  color: var(--text-primary);
  font-size: 13px;
  outline: none;
  width: 100%;
}
.vattu-table-wrap {
  overflow: auto;
  flex: 1;
  border: 1px solid var(--border-subtle);
  border-radius: 10px;
}
.vattu-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}
.vattu-table th {
  background: var(--bg-elevated);
  color: var(--text-secondary);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .05em;
  text-transform: uppercase;
  padding: 9px 10px;
  text-align: left;
  border-bottom: 1px solid var(--border-subtle);
  position: sticky;
  top: 0;
  z-index: 2;
  white-space: nowrap;
}
.vattu-table td {
  padding: 8px 10px;
  border-bottom: 1px solid var(--border-faint, rgba(255,255,255,.06));
  vertical-align: middle;
  color: var(--text-primary);
}
.vattu-table tr:hover td { background: var(--bg-elevated); }
.vattu-table .td-price { text-align: right; font-variant-numeric: tabular-nums; color: var(--brand-gold); font-weight: 600; }
.vattu-table .td-code  { color: var(--text-muted); font-size: 11px; font-family: monospace; }
.vattu-table .td-cat   { display: inline-block; background: rgba(212,175,55,.15); color: var(--brand-gold); border-radius: 99px; padding: 2px 8px; font-size: 11px; }
.vattu-table .td-supplier { color: var(--text-secondary); font-size: 12px; }
.vattu-table .td-actions { display: flex; gap: 4px; }
.vattu-table .td-actions button {
  width: 28px; height: 28px; border-radius: 6px;
  border: none; background: transparent; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-muted); transition: all .15s;
}
.vattu-table .td-actions button:hover { background: var(--bg-card); color: var(--text-primary); }
/* Pagination */
.vattu-page-btn {
  padding: 5px 10px; border-radius: 6px; border: 1px solid var(--border-subtle);
  background: var(--bg-elevated); color: var(--text-secondary); cursor: pointer;
  font-size: 12px; transition: all .15s;
}
.vattu-page-btn.active { background: var(--brand-gold); color: #000; border-color: var(--brand-gold); font-weight: 700; }
.vattu-page-btn:hover:not(.active) { border-color: var(--brand-gold); color: var(--brand-gold); }
/* Map modal selects */
#vattu-map-fields label { font-size: 12px; color: var(--text-secondary); display: block; margin-bottom: 4px; font-weight: 600; }
#vattu-map-fields select {
  width: 100%; padding: 7px 10px; border-radius: 8px;
  border: 1px solid var(--border-subtle); background: var(--bg-card);
  color: var(--text-primary); font-size: 13px;
}
#vattu-preview-table table { border-collapse: collapse; width: 100%; }
#vattu-preview-table th, #vattu-preview-table td {
  border: 1px solid var(--border-subtle);
  padding: 4px 7px; font-size: 11px;
}
#vattu-preview-table th { background: var(--bg-elevated); }


@media print {
  @page {
    margin: 0 !important;
  }
