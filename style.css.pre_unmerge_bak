  position: relative;
  page-break-after: always;
  padding: 12mm 10mm 15mm 10mm !important;
  box-sizing: border-box;
}
#excel-pdf-content .ep-page:last-child {
  page-break-after: avoid;
}
#excel-pdf-content .ep-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 2pt solid #333;
  padding-bottom: 4px;
  margin-bottom: 8px;
}
#excel-pdf-content .ep-header img {
  height: 36px;
  object-fit: contain;
}
#excel-pdf-content .ep-header-right {
  text-align: right;
}
#excel-pdf-content .ep-title {
  font-size: 13pt;
  font-weight: 800;
  margin: 0;
}
#excel-pdf-content .ep-meta {
  font-size: 8pt;
  color: #444;
  margin: 2px 0 0 0;
}
#excel-pdf-content .ep-section-hdr {
