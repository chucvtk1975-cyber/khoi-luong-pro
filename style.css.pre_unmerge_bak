#excel-pdf-content .ep-note-hdr td {
  background: #fff !important;
  font-weight: 700;
  color: #000;
  border: 0.5pt solid #000 !important;
}
#excel-pdf-content .ep-subtotal td {
  background: #D9E2F3 !important;
  font-weight: 700;
  border: 0.5pt solid #000 !important;
}
#excel-pdf-content .ep-vat td {
  background: #fff !important;
  color: #555;
}
#excel-pdf-content .ep-grand td {
  background: #D9E2F3 !important;
  color: #000 !important;
  font-weight: 800;
  font-size: 10pt;
  border: 0.5pt solid #000 !important;
}
#excel-pdf-content .ep-words td {
  font-style: italic;
  color: #000;
  font-size: 8pt;
  border: 0.5pt solid #000 !important;
}
#excel-pdf-content .ep-footer {
  position: absolute;
